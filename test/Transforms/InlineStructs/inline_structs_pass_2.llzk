// TESTS: The relevant member is an array of subcomponents
module attributes {llzk.main = !struct.type<@Main>, llzk.lang} {
  poly.template @TPair {
    poly.param @Fst
    poly.param @Snd

    struct.def @Pair {
      function.def @compute() -> !struct.type<@TPair::@Pair<[@Fst, @Snd]>> {
        %self = struct.new : !struct.type<@TPair::@Pair<[@Fst, @Snd]>>
        function.return %self : !struct.type<@TPair::@Pair<[@Fst, @Snd]>>
      }
      function.def @constrain(%self: !struct.type<@TPair::@Pair<[@Fst, @Snd]>>) {
        function.return
      }
    }
  }

  poly.template @TMakeGuess {
    poly.param @PEGS

    struct.def @MakeGuess {
      struct.member @dat : !array.type<4 x !struct.type<@TPair::@Pair<[!felt.type, @PEGS]>>>

      function.def @compute() -> !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>> {
        %self = struct.new : !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>
        %c0 = arith.constant 0 : index
        %c1 = arith.constant 1 : index
        %c4 = arith.constant 4 : index
        %arr = array.new : !array.type<4 x !struct.type<@TPair::@Pair<[!felt.type, @PEGS]>>>
        scf.for %i = %c0 to %c4 step %c1 {
          %sub = function.call @TPair::@Pair::@compute() : () -> (!struct.type<@TPair::@Pair<[!felt.type, @PEGS]>>)
          array.write %arr[%i] = %sub : !array.type<4 x !struct.type<@TPair::@Pair<[!felt.type, @PEGS]>>>, !struct.type<@TPair::@Pair<[!felt.type, @PEGS]>>
        }
        struct.writem %self[@dat] = %arr : !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>, !array.type<4 x !struct.type<@TPair::@Pair<[!felt.type, @PEGS]>>>
        function.return %self : !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>
      }

      function.def @constrain(%self: !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>) {
        %c0 = arith.constant 0 : index
        %c1 = arith.constant 1 : index
        %arr = struct.readm %self[@dat] : !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>, !array.type<4 x !struct.type<@TPair::@Pair<[!felt.type, @PEGS]>>>
        %len = array.len %arr, %c0 : !array.type<4 x !struct.type<@TPair::@Pair<[!felt.type, @PEGS]>>>
        scf.for %i = %c0 to %len step %c1 {
          %sub = array.read %arr[%i] : !array.type<4 x !struct.type<@TPair::@Pair<[!felt.type, @PEGS]>>>, !struct.type<@TPair::@Pair<[!felt.type, @PEGS]>>
          // Note: the `canInline()` check fails here because the "self" parameter of this "@constrain"
          // call does not come from a `struct.writem` which is (currently) the only pattern supported.
          function.call @TPair::@Pair::@constrain(%sub) : (!struct.type<@TPair::@Pair<[!felt.type, @PEGS]>>) -> ()
        }
        function.return
      }
    }
  }

  poly.template @TMain {
    struct.def @Main {
      struct.member @sub : !struct.type<@TMakeGuess::@MakeGuess<[77]>>

      function.def @compute() -> !struct.type<@TMain::@Main<[]>> {
        %self = struct.new : !struct.type<@TMain::@Main<[]>>
        %c = function.call @TMakeGuess::@MakeGuess::@compute() : () -> !struct.type<@TMakeGuess::@MakeGuess<[77]>>
        struct.writem %self[@sub] = %c : !struct.type<@TMain::@Main<[]>>, !struct.type<@TMakeGuess::@MakeGuess<[77]>>
        function.return %self : !struct.type<@TMain::@Main<[]>>
      }

      function.def @constrain(%self: !struct.type<@TMain::@Main<[]>>) {
        %c = struct.readm %self[@sub] : !struct.type<@TMain::@Main<[]>>, !struct.type<@TMakeGuess::@MakeGuess<[77]>>
        function.call @TMakeGuess::@MakeGuess::@constrain(%c) : (!struct.type<@TMakeGuess::@MakeGuess<[77]>>) -> ()
        function.return
      }
    }
  }
}

// RUN: llzk-opt -llzk-flatten -llzk-inline-structs -verify-diagnostics %s | FileCheck %s

module attributes {llzk.main = !struct.type<@Main>, llzk.lang} {
  struct.def @ShapeCarrier {
    struct.member @shape : !array.type<? x none>

    function.def @compute(%shape: !array.type<? x none>) -> !struct.type<@ShapeCarrier> {
      %self = struct.new : !struct.type<@ShapeCarrier>
      struct.writem %self[@shape] = %shape : !struct.type<@ShapeCarrier>, !array.type<? x none>
      function.return %self : !struct.type<@ShapeCarrier>
    }

    function.def @constrain(%self: !struct.type<@ShapeCarrier>, %shape: !array.type<? x none>) {
      %stored = struct.readm %self[@shape] : !struct.type<@ShapeCarrier>, !array.type<? x none>
      constrain.eq %stored, %shape : !array.type<? x none>
      function.return
    }
  }

  struct.def @Main {
    struct.member @carrier : !struct.type<@ShapeCarrier>
    struct.member @shape : !array.type<? x none>

    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %shape = llzk.nondet : !array.type<? x none>
      %carrier = function.call @ShapeCarrier::@compute(%shape)
        : (!array.type<? x none>) -> !struct.type<@ShapeCarrier>
      struct.writem %self[@carrier] = %carrier : !struct.type<@Main>, !struct.type<@ShapeCarrier>
      struct.writem %self[@shape] = %shape : !struct.type<@Main>, !array.type<? x none>
      function.return %self : !struct.type<@Main>
    }

    function.def @constrain(%self: !struct.type<@Main>) {
      %carrier = struct.readm %self[@carrier] : !struct.type<@Main>, !struct.type<@ShapeCarrier>
      %shape = struct.readm %self[@shape] : !struct.type<@Main>, !array.type<? x none>
      function.call @ShapeCarrier::@constrain(%carrier, %shape)
        : (!struct.type<@ShapeCarrier>, !array.type<? x none>) -> ()
      function.return
    }
  }
}
// CHECK-LABEL: module attributes {llzk.lang, llzk.main = !struct.type<@Main>} {
// CHECK-NEXT:    struct.def @ShapeCarrier {
// CHECK-NEXT:      struct.member @shape : !array.type<? x none>
// CHECK-NEXT:      function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<? x none>) -> !struct.type<@ShapeCarrier> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@ShapeCarrier>
// CHECK-NEXT:        struct.writem %[[VAL_1]][@shape] = %[[VAL_0]] : <@ShapeCarrier>, !array.type<? x none>
// CHECK-NEXT:        function.return %[[VAL_1]] : !struct.type<@ShapeCarrier>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@ShapeCarrier>, %[[VAL_3:[0-9a-zA-Z_\.]+]]: !array.type<? x none>) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_4:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_2]][@shape] : <@ShapeCarrier>, !array.type<? x none>
// CHECK-NEXT:        constrain.eq %[[VAL_4]], %[[VAL_3]] : !array.type<? x none>, !array.type<? x none>
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @Main {
// CHECK-NEXT:      struct.member @"carrier:!s<@ShapeCarrier>+shape" : !array.type<? x none>
// CHECK-NEXT:      struct.member @shape : !array.type<? x none>
// CHECK-NEXT:      function.def @compute() -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = llzk.nondet : !array.type<? x none>
// CHECK-NEXT:        struct.writem %[[VAL_5]][@"carrier:!s<@ShapeCarrier>+shape"] = %[[VAL_6]] : <@Main>, !array.type<? x none>
// CHECK-NEXT:        struct.writem %[[VAL_5]][@shape] = %[[VAL_6]] : <@Main>, !array.type<? x none>
// CHECK-NEXT:        function.return %[[VAL_5]] : !struct.type<@Main>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_7:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_8:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_7]][@shape] : <@Main>, !array.type<? x none>
// CHECK-NEXT:        %[[VAL_9:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_7]][@"carrier:!s<@ShapeCarrier>+shape"] : <@Main>, !array.type<? x none>
// CHECK-NEXT:        constrain.eq %[[VAL_9]], %[[VAL_8]] : !array.type<? x none>, !array.type<? x none>
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

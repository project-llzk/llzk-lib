// RUN: llzk-opt -split-input-file -llzk-flatten %s | FileCheck --enable-var-scope %s
// REQUIRES: todo-update-passes-for-template

// TEST: partial instantiation where 'read_const' cannot be removed
#id = affine_map<(i)->(i)>
module attributes {llzk.lang} {
  poly.template @TZip {
    poly.param @Lhs
    poly.param @Rhs
    poly.param @N

    struct.def @Zip {
      struct.member @"$array" : !array.type<#id x !felt.type>

      function.def @compute() -> !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>> {
        %self = struct.new : !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>>
        %1 = poly.read_const @N : index
        %array = array.new{(%1)[]} : !array.type<#id x !felt.type>
        struct.writem %self[@"$array"] = %array : !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>>, !array.type<#id x !felt.type>
        function.return %self : !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>>
      }

      function.def @constrain(%arg0: !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>>) {
        %1 = poly.read_const @N : index
        %array = array.new{(%1)[]} : <#id x !felt.type>
        function.return
      }
    }
  }

  poly.template @TTop {
    poly.param @N

    struct.def @Top {
      function.def @compute() -> !struct.type<@TTop::@Top<[@N]>> {
        %self = struct.new : !struct.type<@TTop::@Top<[@N]>>
        function.call @TZip::@Zip::@compute() : () -> !struct.type<@TZip::@Zip<[!felt.type, !felt.type, @N]>>
        function.return %self : !struct.type<@TTop::@Top<[@N]>>
      }
      function.def @constrain(%arg0: !struct.type<@TTop::@Top<[@N]>>) {
        function.return
      }
    }
  }
}
// CHECK-LABEL: TODO

// CHECK-NEXT: function.return %[[VAL_4]] : index
// CHECK-NEXT: }
// CHECK-NEXT: }
// CHECK-NEXT: struct.def @Main {
// CHECK-NEXT: function.def @compute() -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT: %[[VAL_5:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>

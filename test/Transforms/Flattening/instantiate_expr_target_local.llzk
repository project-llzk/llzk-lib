// -----

module attributes {llzk.lang} {
  poly.template @UnusedFunctionExpr {
    poly.param @N : index
    poly.expr @Unused {
      %value = scf.execute_region -> index {
        %n = poly.read_const @N : index
        scf.yield %n : index
      }
      poly.yield %value : index
    }
    function.def @other() -> index {
      %value = poly.read_const @Unused : index
      function.return %value : index
    }
    function.def @value() -> index {
      %result = arith.constant 1 : index
      function.return %result : index
    }
  }

  struct.def @Main {
    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : <@Main>
      %result = function.call @UnusedFunctionExpr::@value<[5]>() : () -> index
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>) {
      function.return
    }
  }
}


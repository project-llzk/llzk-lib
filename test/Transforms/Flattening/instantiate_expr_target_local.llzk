// CHECK-NEXT: %[[VAL_0:[0-9a-zA-Z_\.]+]] = arith.constant 1 : index
// CHECK-NEXT: function.return %[[VAL_0]] : index
// CHECK-NEXT: }
// CHECK-NEXT: poly.template @UnusedFunctionExpr {
// CHECK-NEXT: poly.param @N : index
// CHECK-NEXT: poly.expr @Unused {

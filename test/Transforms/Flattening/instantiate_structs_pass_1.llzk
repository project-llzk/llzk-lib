      }
      function.def @constrain(%self: !struct.type<@TTestReadConstAsBool0::@TestReadConstAsBool0<[@A]>>, %0: i1) {
        %1 = poly.read_const @A : i1
        constrain.eq %0, %1 : i1
        function.return

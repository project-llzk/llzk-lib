  struct.def @Main {
    struct.member @sub : !struct.type<@TTestReadConstAsBool0::@TestReadConstAsBool0<[0]>>

    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %0 = arith.constant false
      %1 = function.call @TTestReadConstAsBool0::@TestReadConstAsBool0::@compute(%0) : (i1) -> !struct.type<@TTestReadConstAsBool0::@TestReadConstAsBool0<[0]>>
      struct.writem %self[@sub] = %1 : !struct.type<@Main>, !struct.type<@TTestReadConstAsBool0::@TestReadConstAsBool0<[0]>>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>) {
      %0 = arith.constant false
      %1 = struct.readm %self[@sub] : !struct.type<@Main>, !struct.type<@TTestReadConstAsBool0::@TestReadConstAsBool0<[0]>>
      function.call @TTestReadConstAsBool0::@TestReadConstAsBool0::@constrain(%1, %0) : (!struct.type<@TTestReadConstAsBool0::@TestReadConstAsBool0<[0]>>, i1) -> ()
      function.return
    }
  }
}

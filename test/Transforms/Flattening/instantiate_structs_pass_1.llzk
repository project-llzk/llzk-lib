/// Test "Parameterized struct still has uses!" warning
module attributes {llzk.lang} {
  // expected-warning@+1 {{Parameterized struct still has uses!}}
  poly.template @TComponent07A {
    poly.param @C

    struct.def @Component07A {
      struct.member @f1 : !poly.tvar<@C>

      function.def @compute() -> !struct.type<@TComponent07A::@Component07A<[@C]>> {
        %self = struct.new : !struct.type<@TComponent07A::@Component07A<[@C]>>
        function.return %self : !struct.type<@TComponent07A::@Component07A<[@C]>>
      }

      function.def @constrain(%self: !struct.type<@TComponent07A::@Component07A<[@C]>>) {
        function.return
      }
    }
  }

  poly.template @TComponent07B {
    poly.param @T

    struct.def @Component07B {
      struct.member @f2 : !struct.type<@TComponent07A::@Component07A<[!array.type<@T x i1>]>>

      function.def @compute() -> !struct.type<@TComponent07B::@Component07B<[@T]>> {
        %self = struct.new : !struct.type<@TComponent07B::@Component07B<[@T]>>
        %x = function.call @TComponent07A::@Component07A::@compute() : () -> (!struct.type<@TComponent07A::@Component07A<[!array.type<@T x i1>]>>)
        struct.writem %self[@f2] = %x : !struct.type<@TComponent07B::@Component07B<[@T]>>, !struct.type<@TComponent07A::@Component07A<[!array.type<@T x i1>]>>
        function.return %self : !struct.type<@TComponent07B::@Component07B<[@T]>>
      }

      function.def @constrain(%self: !struct.type<@TComponent07B::@Component07B<[@T]>>) {
        %b = struct.readm %self[@f2] : !struct.type<@TComponent07B::@Component07B<[@T]>>, !struct.type<@TComponent07A::@Component07A<[!array.type<@T x i1>]>>
        function.call @TComponent07A::@Component07A::@constrain(%b) : (!struct.type<@TComponent07A::@Component07A<[!array.type<@T x i1>]>>) -> ()
        function.return
      }
    }
  }

  struct.def @Component07C {
    struct.member @f2 : !struct.type<@TComponent07A::@Component07A<[!array.type<2 x i1>]>>

    function.def @compute() -> !struct.type<@Component07C> {
      %self = struct.new : !struct.type<@Component07C>
      %x = function.call @TComponent07A::@Component07A::@compute() : () -> (!struct.type<@TComponent07A::@Component07A<[!array.type<2 x i1>]>>)
      struct.writem %self[@f2] = %x : !struct.type<@Component07C>, !struct.type<@TComponent07A::@Component07A<[!array.type<2 x i1>]>>
      function.return %self : !struct.type<@Component07C>
    }

    function.def @constrain(%self: !struct.type<@Component07C>) {
      %b = struct.readm %self[@f2] : !struct.type<@Component07C>, !struct.type<@TComponent07A::@Component07A<[!array.type<2 x i1>]>>
      function.call @TComponent07A::@Component07A::@constrain(%b) : (!struct.type<@TComponent07A::@Component07A<[!array.type<2 x i1>]>>) -> ()
      function.return
    }
  }
}

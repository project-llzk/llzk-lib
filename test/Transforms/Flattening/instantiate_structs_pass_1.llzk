module attributes {llzk.lang} {
  poly.template @TTestReadConstAsBool0 {
    poly.param @A

    struct.def @TestReadConstAsBool0 {
      function.def @compute(%0: i1) -> !struct.type<@TTestReadConstAsBool0::@TestReadConstAsBool0<[@A]>> {
        %self = struct.new : !struct.type<@TTestReadConstAsBool0::@TestReadConstAsBool0<[@A]>>

// RUN: llzk-opt -split-input-file -llzk-flatten -verify-diagnostics %s | FileCheck --enable-var-scope %s
// REQUIRES: todo-update-passes-for-template

#map = affine_map<()[s0, s1] -> (s0 floordiv s1)>
module attributes {llzk.lang = "zirgen"} {
  poly.template @TS {
    poly.param @X
    poly.param @N
    poly.param @P

    struct.def @S {
      function.def @compute(%arg0: !array.type<@X x !felt.type>) -> !struct.type<@TS::@S<[@X, @N, @P]>> {
        %self = struct.new : !struct.type<@TS::@S<[@X, @N, @P]>>
        %c0 = arith.constant 0 : index
        %0 = array.read %arg0[%c0] : !array.type<@X x !felt.type>, !felt.type
        function.return %self : !struct.type<@TS::@S<[@X, @N, @P]>>
      }
      function.def @constrain(%arg0: !struct.type<@TS::@S<[@X, @N, @P]>>, %arg1: !array.type<@X x !felt.type>) {
        function.return
      }
    }
  }
  poly.template @TB {
    poly.param @N

    struct.def @B {
      function.def @compute() -> !struct.type<@TB::@B<[@N]>> {
        %self = struct.new : !struct.type<@TB::@B<[@N]>>
        function.return %self : !struct.type<@TB::@B<[@N]>>
      }
      function.def @constrain(%arg0: !struct.type<@TB::@B<[@N]>>) {
        function.return
      }
    }
  }
  poly.template @TA {
    poly.param @N

    struct.def @A {
      function.def @compute() -> !struct.type<@TA::@A<[@N]>> {
        %self = struct.new : !struct.type<@TA::@A<[@N]>>
        %0 = poly.read_const @N : index
        %c2 = arith.constant 2 : index
        %array = array.new{()[%0, %c2]} : !array.type<#map x !felt.type>
        %1 = function.call @TS::@S::@compute(%array) {()[%0, %c2]} : (!array.type<#map x !felt.type>) -> !struct.type<@TS::@S<[#map, @N, 2]>>
        %2 = function.call @TB::@B::@compute() {()[%0, %c2]} : () -> !struct.type<@TB::@B<[#map]>>
        function.return %self : !struct.type<@TA::@A<[@N]>>
      }
      function.def @constrain(%arg0: !struct.type<@TA::@A<[@N]>>) {
        function.return
      }
    }
  }
  struct.def @Main {
    function.def @compute() -> !struct.type<@Main> {
      %s = function.call @TA::@A::@compute() : () -> !struct.type<@TA::@A<[4]>>
      %self = struct.new : !struct.type<@Main>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%arg0: !struct.type<@Main>) {
      function.return
    }
  }
}
// CHECK-LABEL: TODO

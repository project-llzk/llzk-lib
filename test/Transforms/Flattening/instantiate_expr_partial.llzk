// CHECK:         arith.constant 14 : index
// CHECK-NOT:     poly.read_const @TwiceM
// -----

module attributes {llzk.lang} {
  poly.template @InnerFunc {
    poly.param @N : index
    poly.param @M : index
    poly.expr @TwiceM {
      %m = poly.read_const @M : index
      %two = arith.constant 2 : index
      %result = arith.muli %m, %two : index
      poly.yield %result : index
    }
    function.def @value(%input: !array.type<@N,@M x !felt.type>) -> index {
      %twice = poly.read_const @TwiceM : index
      function.return %twice : index
    }
  }

  poly.template @OuterFunc {
    poly.param @M : index
    function.def @value(%input: !array.type<5,@M x !felt.type>) -> index {
      %result = function.call @InnerFunc::@value(%input) : (!array.type<5,@M x !felt.type>) -> index
      function.return %result : index
    }
  }
}


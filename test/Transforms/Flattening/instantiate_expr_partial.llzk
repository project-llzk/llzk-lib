      function.def @compute() -> !struct.type<@Inner::@Value<[@N, @M]>> {
        %sum = poly.read_const @NPlusM : index
        %self = struct.new : <@Inner::@Value<[@N, @M]>>
        %values = array.new{(%sum)[]} : !array.type<#id x !felt.type>
        struct.writem %self[@values] = %values : <@Inner::@Value<[@N, @M]>>, !array.type<#id x !felt.type>

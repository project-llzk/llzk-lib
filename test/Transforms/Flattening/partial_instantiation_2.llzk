// RUN: llzk-opt -split-input-file -llzk-flatten %s | FileCheck --enable-var-scope %s

// TEST: partial instantiation of '@Zip' in first round of flattening pass and then the loop in '@Main'
//  unrolls allowing a subsequent round of the flattening pass loop to make complete instantiations.
#id = affine_map<(i)->(i)>
module attributes {llzk.lang} {
  poly.template @TPair {
    poly.param @Fst
    poly.param @Snd

    struct.def @Pair {
      function.def @compute() -> !struct.type<@TPair::@Pair<[@Fst, @Snd]>> {
        %self = struct.new : !struct.type<@TPair::@Pair<[@Fst, @Snd]>>
        function.return %self : !struct.type<@TPair::@Pair<[@Fst, @Snd]>>
      }
      function.def @constrain(%arg0: !struct.type<@TPair::@Pair<[@Fst, @Snd]>>) {
        function.return
      }
    }
  }

  poly.template @TZip {
    poly.param @N
    poly.param @Lhs
    poly.param @Rhs

    struct.def @Zip {
      struct.member @"$super" : !array.type<9 x !struct.type<@TPair::@Pair<[!poly.tvar<@Lhs>, !poly.tvar<@Rhs>]>>> {llzk.pub}
      function.def @compute() -> !struct.type<@TZip::@Zip<[@N, @Lhs, @Rhs]>> {
        %self = struct.new : !struct.type<@TZip::@Zip<[@N, @Lhs, @Rhs]>>
        function.return %self : !struct.type<@TZip::@Zip<[@N, @Lhs, @Rhs]>>
      }
      function.def @constrain(%arg0: !struct.type<@TZip::@Zip<[@N, @Lhs, @Rhs]>>) {
        function.return
      }
    }
  }

  poly.template @TMakeGuess {
    poly.param @PEGS

    struct.def @MakeGuess {
      struct.member @"$temp" : !struct.type<@TZip::@Zip<[@PEGS, !felt.type, !felt.type]>>

      function.def @compute() -> !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>> {
        %self = struct.new : !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>
        function.return %self : !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>
      }

      function.def @constrain(%arg0: !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>) {
        %c1 = arith.constant 1 : index
        %c0 = arith.constant 0 : index
        %14 = struct.readm %arg0[@"$temp"] : !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>, !struct.type<@TZip::@Zip<[@PEGS, !felt.type, !felt.type]>>
        %15 = struct.readm %14[@"$super"] : !struct.type<@TZip::@Zip<[@PEGS, !felt.type, !felt.type]>>, !array.type<9 x !struct.type<@TPair::@Pair<[!felt.type, !felt.type]>>>
        %17 = array.len %15, %c0 : !array.type<9 x !struct.type<@TPair::@Pair<[!felt.type, !felt.type]>>>
        scf.for %arg5 = %c0 to %17 step %c1 {
          %34 = array.read %15[%arg5] : !array.type<9 x !struct.type<@TPair::@Pair<[!felt.type, !felt.type]>>>, !struct.type<@TPair::@Pair<[!felt.type, !felt.type]>>
        }
        function.return
      }
    }
  }

  struct.def @Main {
    function.def @compute() -> !struct.type<@Main<[]>> {
      %self = struct.new : !struct.type<@Main<[]>>
      %c0 = arith.constant 0 : index
      %c1 = arith.constant 1 : index
      %c5 = arith.constant 5 : index
      scf.for %i = %c0 to %c5 step %c1 {
        function.call @TMakeGuess::@MakeGuess::@compute(){(%i)} : () -> !struct.type<@TMakeGuess::@MakeGuess<[#id]>>
      }
      function.return %self : !struct.type<@Main<[]>>
    }
    function.def @constrain(%arg0: !struct.type<@Main<[]>>) {
      function.return
    }
  }
}

// RUN: llzk-opt -split-input-file -llzk-flatten %s | FileCheck --enable-var-scope %s
// REQUIRES: todo-update-passes-for-template

module attributes {llzk.lang} {
  poly.template @TComponent1A {
    struct.def @Component1A {
      function.def @constrain(%self: !struct.type<@TComponent1A::@Component1A<[]>>) { function.return }
      function.def @compute() -> !struct.type<@TComponent1A::@Component1A<[]>> {
        %self = struct.new : !struct.type<@TComponent1A::@Component1A<[]>>
        function.return %self : !struct.type<@TComponent1A::@Component1A<[]>>
      }
    }
  }

  struct.def @Component1B {
    function.def @compute(%p: !struct.type<@TComponent1A::@Component1A<[]>>) -> !struct.type<@Component1B> {
      %self = struct.new : !struct.type<@Component1B>
      function.return %self : !struct.type<@Component1B>
    }

    function.def @constrain(%self: !struct.type<@Component1B>, %p: !struct.type<@TComponent1A::@Component1A<[]>>) {
      function.return
    }
  }
}
// CHECK-LABEL: TODO
// -----

module attributes {llzk.lang} {
  poly.template @TComponent2A {
    struct.def @Component2A {
      function.def @constrain(%self: !struct.type<@TComponent2A::@Component2A<[]>>) { function.return }
      function.def @compute() -> !struct.type<@TComponent2A::@Component2A<[]>> {
        %self = struct.new : !struct.type<@TComponent2A::@Component2A<[]>>
        function.return %self : !struct.type<@TComponent2A::@Component2A<[]>>
      }
    }
  }

  struct.def @Main {
    struct.member @b : !struct.type<@TComponent2A::@Component2A<[]>>
    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %b = function.call @TComponent2A::@Component2A::@compute() : () -> !struct.type<@TComponent2A::@Component2A<[]>>
      struct.writem %self[@b] = %b : !struct.type<@Main>, !struct.type<@TComponent2A::@Component2A<[]>>
      function.return %self : !struct.type<@Main>
    }

    function.def @constrain(%self: !struct.type<@Main>) {
      function.return
    }
  }
}
// CHECK-LABEL: TODO

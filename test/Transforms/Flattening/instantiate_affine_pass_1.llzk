// RUN: llzk-opt -split-input-file -llzk-flatten -verify-diagnostics %s | FileCheck --enable-var-scope %s

#IdxToLen = affine_map<(i)->(2*i)>
#Values = affine_map<(i,j)->(5*j+i)>
!ToFelt = !struct.type<@TToFelt::@ToFelt<[#Values]>>
!HeterArr = !struct.type<@TVarArray::@VarArray<[#IdxToLen, !ToFelt]>>
module attributes {llzk.lang} {
  // pre-defined
  poly.template @TVarArray {
    poly.param @N
    poly.param @T

    struct.def @VarArray {
      struct.member @val: !array.type<@N x !poly.tvar<@T>>

      function.def @compute(%inp: !array.type<@N x !poly.tvar<@T>>) -> !struct.type<@TVarArray::@VarArray<[@N, @T]>> {
        %self = struct.new : !struct.type<@TVarArray::@VarArray<[@N, @T]>>
        struct.writem %self[@val] = %inp : !struct.type<@TVarArray::@VarArray<[@N, @T]>>, !array.type<@N x !poly.tvar<@T>>
        function.return %self : !struct.type<@TVarArray::@VarArray<[@N, @T]>>
      }

      function.def @constrain(%self: !struct.type<@TVarArray::@VarArray<[@N, @T]>>, %inp: !array.type<@N x !poly.tvar<@T>>) {
        function.return
      }
    }
  }

  poly.template @TToFelt {
    poly.param @A

    struct.def @ToFelt {
      struct.member @out: !felt.type {llzk.pub}

      function.def @compute() -> !struct.type<@TToFelt::@ToFelt<[@A]>> {
        %self = struct.new : !struct.type<@TToFelt::@ToFelt<[@A]>>
        %constA = poly.read_const @A : !felt.type
        struct.writem %self[@out] = %constA : !struct.type<@TToFelt::@ToFelt<[@A]>>, !felt.type
        function.return %self: !struct.type<@TToFelt::@ToFelt<[@A]>>
      }

      function.def @constrain(%self: !struct.type<@TToFelt::@ToFelt<[@A]>>) {
        function.return
      }
    }
  }

  poly.template @TTestLoopWithAffineArrayStruct {
    poly.param @N

    struct.def @TestLoopWithAffineArrayStruct {
      // The `pub` here is intended to test that attributes are copied by
      //  UpdateMemberTypeFromWrite when creating a new MemberDefOp.
      struct.member @arrs: !array.type<@N x !HeterArr> {llzk.pub}

      function.def @compute() -> !struct.type<@TTestLoopWithAffineArrayStruct::@TestLoopWithAffineArrayStruct<[@N]>> {
        %arrs_temp = array.new : !array.type<@N x !HeterArr>

        %0 = arith.constant 0 : index
        %1 = arith.constant 1 : index
        %n = poly.read_const @N : index
        %step = arith.constant 1 : index
        scf.for %i = %1 to %n step %step { // range: [1,N)
          // The array length is a function of 'i' and it contains non-homogeneous structs
          //    !ToFelt = !struct.type<@ToFelt<[#Values]>>
          %arr = array.new{(%i)} : !array.type<#IdxToLen x !ToFelt>
          scf.for %j = %0 to %i step %step { // range: [0,i)
            %v = function.call @TToFelt::@ToFelt::@compute(){(%i, %j)} : () -> !ToFelt
            array.write %arr[%j] = %v : !array.type<#IdxToLen x !ToFelt>, !ToFelt
          }
          // Create a VarArray with length as a function of 'i' and non-homogeneous element type
          %va = function.call @TVarArray::@VarArray::@compute(%arr){(%i)} : (!array.type<#IdxToLen x !ToFelt>) -> !HeterArr
          array.write %arrs_temp[%i] = %va : !array.type<@N x !HeterArr>, !HeterArr
        }
        //
        %self = struct.new : !struct.type<@TTestLoopWithAffineArrayStruct::@TestLoopWithAffineArrayStruct<[@N]>>
        struct.writem %self[@arrs] = %arrs_temp
              : !struct.type<@TTestLoopWithAffineArrayStruct::@TestLoopWithAffineArrayStruct<[@N]>>, !array.type<@N x !HeterArr>
        function.return %self : !struct.type<@TTestLoopWithAffineArrayStruct::@TestLoopWithAffineArrayStruct<[@N]>>
      }

      function.def @constrain(%self: !struct.type<@TTestLoopWithAffineArrayStruct::@TestLoopWithAffineArrayStruct<[@N]>>) {
        function.return
      }
    }
  }

  struct.def @Main {
    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %x = function.call @TTestLoopWithAffineArrayStruct::@TestLoopWithAffineArrayStruct::@compute()
            : () -> !struct.type<@TTestLoopWithAffineArrayStruct::@TestLoopWithAffineArrayStruct<[2]>>
      function.return %self: !struct.type<@Main>
    }

    function.def @constrain(%self: !struct.type<@Main>) {
      function.return
    }
  }
}
// CHECK-LABEL: struct.def @"VarArray_2_!s<@ToFelt_1>" {
// CHECK-NEXT:    struct.member @val : !array.type<2 x !struct.type<@ToFelt_1>>
// CHECK-NEXT:    function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<2 x !struct.type<@ToFelt_1>>) -> !struct.type<@"VarArray_2_!s<@ToFelt_1>"> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@"VarArray_2_!s<@ToFelt_1>">
// CHECK-NEXT:      struct.writem %[[VAL_1]][@val] = %[[VAL_0]] : <@"VarArray_2_!s<@ToFelt_1>">, !array.type<2 x !struct.type<@ToFelt_1>>
// CHECK-NEXT:      function.return %[[VAL_1]] : !struct.type<@"VarArray_2_!s<@ToFelt_1>">
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@"VarArray_2_!s<@ToFelt_1>">, %[[VAL_3:[0-9a-zA-Z_\.]+]]: !array.type<2 x !struct.type<@ToFelt_1>>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }

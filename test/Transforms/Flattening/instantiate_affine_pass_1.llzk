// CHECK-LABEL: struct.def @TestLoopWithAffineArrayStruct_2 {
// CHECK-NEXT:    struct.member @arrs : !array.type<2 x !struct.type<@"VarArray_2_!s<@ToFelt_1>">> {llzk.pub}
// CHECK-NEXT:    function.def @compute() -> !struct.type<@TestLoopWithAffineArrayStruct_2> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_7:[0-9a-zA-Z_\.]+]] = arith.constant 1 : index
// CHECK-NEXT:      %[[VAL_8:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[VAL_9:[0-9a-zA-Z_\.]+]] = array.new  : <2 x !struct.type<@"VarArray_2_!s<@ToFelt_1>">>
// CHECK-NEXT:      %[[VAL_10:[0-9a-zA-Z_\.]+]] = array.new  : <2 x !struct.type<@ToFelt_1>>
// CHECK-NEXT:      %[[VAL_11:[0-9a-zA-Z_\.]+]] = function.call @ToFelt_1::@compute() : () -> !struct.type<@ToFelt_1>
// CHECK-NEXT:      array.write %[[VAL_10]]{{\[}}%[[VAL_8]]] = %[[VAL_11]] : <2 x !struct.type<@ToFelt_1>>, !struct.type<@ToFelt_1>
// CHECK-NEXT:      %[[VAL_12:[0-9a-zA-Z_\.]+]] = function.call @"VarArray_2_!s<@ToFelt_1>"::@compute(%[[VAL_10]]) : (!array.type<2 x !struct.type<@ToFelt_1>>) -> !struct.type<@"VarArray_2_!s<@ToFelt_1>">
// CHECK-NEXT:      array.write %[[VAL_9]]{{\[}}%[[VAL_7]]] = %[[VAL_12]] : <2 x !struct.type<@"VarArray_2_!s<@ToFelt_1>">>, !struct.type<@"VarArray_2_!s<@ToFelt_1>">
// CHECK-NEXT:      %[[VAL_13:[0-9a-zA-Z_\.]+]] = struct.new : <@TestLoopWithAffineArrayStruct_2>
// CHECK-NEXT:      struct.writem %[[VAL_13]][@arrs] = %[[VAL_9]] : <@TestLoopWithAffineArrayStruct_2>, !array.type<2 x !struct.type<@"VarArray_2_!s<@ToFelt_1>">>
// CHECK-NEXT:      function.return %[[VAL_13]] : !struct.type<@TestLoopWithAffineArrayStruct_2>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[VAL_14:[0-9a-zA-Z_\.]+]]: !struct.type<@TestLoopWithAffineArrayStruct_2>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }

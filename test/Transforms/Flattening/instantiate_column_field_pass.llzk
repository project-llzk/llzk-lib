module attributes {llzk.lang} {
  poly.template @TComponentA1 {
    poly.param @T

    struct.def @ComponentA1 {
      struct.member @f1 : !poly.tvar<@T> {column, llzk.pub}

      function.def @constrain(%self: !struct.type<@TComponentA1::@ComponentA1<[@T]>>) { function.return }
      function.def @compute() -> !struct.type<@TComponentA1::@ComponentA1<[@T]>> {

module attributes {llzk.lang} {
  struct.def @ComponentA1 {
    struct.member @f1 : !felt.type {column, llzk.pub}

    function.def @constrain(%self: !struct.type<@ComponentA1>) { function.return }
    function.def @compute() -> !struct.type<@ComponentA1> {
      %self = struct.new : !struct.type<@ComponentA1>
      function.return %self : !struct.type<@ComponentA1>
    }
  }

  poly.template @TComponentA2 {
    poly.param @N

    struct.def @ComponentA2 {
      function.def @compute(%p: !struct.type<@ComponentA1>) -> !struct.type<@TComponentA2::@ComponentA2<[@N]>> {
        %self = struct.new : !struct.type<@TComponentA2::@ComponentA2<[@N]>>
        %r = struct.readm %p[@f1] : !struct.type<@ComponentA1>, !felt.type {tableOffset = @N}
        function.return %self : !struct.type<@TComponentA2::@ComponentA2<[@N]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentA2::@ComponentA2<[@N]>>, %p: !struct.type<@ComponentA1>) {
        function.return
      }
    }
  }

  struct.def @ComponentA3 {
    function.def @compute(%p: !struct.type<@ComponentA1>) -> !struct.type<@ComponentA3> {
      %self = struct.new : !struct.type<@ComponentA3>
      %c0 = arith.constant 2 : index
      %c = function.call @TComponentA2::@ComponentA2::@compute(%p) {()[%c0]} : (!struct.type<@ComponentA1>) -> !struct.type<@TComponentA2::@ComponentA2<[affine_map<()[s0] -> (s0 + 1)>]>>
      function.return %self : !struct.type<@ComponentA3>
    }

    function.def @constrain(%self: !struct.type<@ComponentA3>, %p: !struct.type<@ComponentA1>) {
      function.return
    }
  }
}

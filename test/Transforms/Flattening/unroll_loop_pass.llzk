// Before the loop in Component02 can unroll, the struct must be instantiated.
module attributes {llzk.lang} {
  struct.def @Component01 {
    struct.member @f : !array.type<2 x !felt.type>

    function.def @compute(%0: !array.type<2 x !felt.type>) -> !struct.type<@Component01> {
      %self = struct.new : !struct.type<@Component01>
      struct.writem %self[@f] = %0 : !struct.type<@Component01>, !array.type<2 x !felt.type>
      function.return %self : !struct.type<@Component01>
    }
    function.def @constrain(%self: !struct.type<@Component01>, %0: !array.type<2 x !felt.type>) {
      %b = struct.readm %self[@f] : !struct.type<@Component01>, !array.type<2 x !felt.type>
      constrain.eq %b, %0 : !array.type<2 x !felt.type>
      function.return
    }
  }

  poly.template @TComponent02 {
    poly.param @N

    struct.def @Component02 {
      struct.member @g : !array.type<@N x !struct.type<@Component01>>

      function.def @compute(%in: !array.type<@N,2 x !felt.type>) -> !struct.type<@TComponent02::@Component02<[@N]>> {
        %self = struct.new : !struct.type<@TComponent02::@Component02<[@N]>>
        %a = array.new : !array.type<@N x !struct.type<@Component01>>

        %lb = arith.constant 0 : index
        %up = poly.read_const @N : index
        %step = arith.constant 1 : index
        scf.for %iv = %lb to %up step %step {
          %p = array.extract %in[%iv] : !array.type<@N,2 x !felt.type>
          %c = function.call @Component01::@compute(%p) : (!array.type<2 x !felt.type>) -> !struct.type<@Component01>
          array.write %a[%iv] = %c : !array.type<@N x !struct.type<@Component01>>, !struct.type<@Component01>
        }

        struct.writem %self[@g] = %a : !struct.type<@TComponent02::@Component02<[@N]>>, !array.type<@N x !struct.type<@Component01>>
        function.return %self : !struct.type<@TComponent02::@Component02<[@N]>>
      }

      function.def @constrain(%self: !struct.type<@TComponent02::@Component02<[@N]>>, %in: !array.type<@N,2 x !felt.type>) {
        %a = struct.readm %self[@g] : !struct.type<@TComponent02::@Component02<[@N]>>, !array.type<@N x !struct.type<@Component01>>

        %lb = arith.constant 0 : index
        %up = poly.read_const @N : index
        %step = arith.constant 1 : index
        scf.for %iv = %lb to %up step %step {
          %p = array.extract %in[%iv] : !array.type<@N,2 x !felt.type>
          %c = array.read %a[%iv] : !array.type<@N x !struct.type<@Component01>>, !struct.type<@Component01>
          function.call @Component01::@constrain(%c, %p) : (!struct.type<@Component01>, !array.type<2 x !felt.type>) -> ()
        }
        function.return
      }
    }
  }

  struct.def @Main {
    struct.member @sub: !struct.type<@TComponent02::@Component02<[3]>>

    function.def @compute(%input: !array.type<3,2 x !felt.type>) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %sub = function.call @TComponent02::@Component02::@compute(%input) : (!array.type<3,2 x !felt.type>) -> !struct.type<@TComponent02::@Component02<[3]>>
      struct.writem %self[@sub] = %sub : !struct.type<@Main>, !struct.type<@TComponent02::@Component02<[3]>>
      function.return %self: !struct.type<@Main>
    }

    function.def @constrain(%self: !struct.type<@Main>, %input: !array.type<3,2 x !felt.type>) {
      %sub = struct.readm %self[@sub] : !struct.type<@Main>, !struct.type<@TComponent02::@Component02<[3]>>
      function.call @TComponent02::@Component02::@constrain(%sub, %input) : (!struct.type<@TComponent02::@Component02<[3]>>, !array.type<3,2 x !felt.type>) -> ()
      function.return
    }
  }
}

// RUN: llzk-opt -split-input-file -llzk-flatten %s | FileCheck --enable-var-scope %s
// REQUIRES: todo-update-passes-for-template

module attributes {llzk.lang} {
  poly.template @TPair {
    poly.param @Fst
    poly.param @Snd

    struct.def @Pair {
      function.def @compute() -> !struct.type<@TPair::@Pair<[@Fst, @Snd]>> {
        %self = struct.new : !struct.type<@TPair::@Pair<[@Fst, @Snd]>>
        function.return %self : !struct.type<@TPair::@Pair<[@Fst, @Snd]>>
      }
      function.def @constrain(%arg0: !struct.type<@TPair::@Pair<[@Fst, @Snd]>>) {
        function.return
      }
    }
  }

  poly.template @TZip {
    poly.param @Lhs
    poly.param @Rhs
    poly.param @N

    struct.def @Zip {
      struct.member @"$super" : !array.type<9 x !struct.type<@TPair::@Pair<[!poly.tvar<@Lhs>, !poly.tvar<@Rhs>]>>> {llzk.pub}
      function.def @compute() -> !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>> {
        %self = struct.new : !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>>
        function.return %self : !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>>
      }
      function.def @constrain(%arg0: !struct.type<@TZip::@Zip<[@Lhs, @Rhs, @N]>>) {
        function.return
      }
    }
  }

  poly.template @TMakeGuess {
    poly.param @PEGS

    struct.def @MakeGuess {
      struct.member @"$temp" : !struct.type<@TZip::@Zip<[!felt.type, !felt.type, @PEGS]>>

      function.def @compute() -> !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>> {
        %self = struct.new : !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>
        function.return %self : !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>
      }

      function.def @constrain(%arg0: !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>) {
        %c1 = arith.constant 1 : index
        %c0 = arith.constant 0 : index
        %14 = struct.readm %arg0[@"$temp"] : !struct.type<@TMakeGuess::@MakeGuess<[@PEGS]>>, !struct.type<@TZip::@Zip<[!felt.type, !felt.type, @PEGS]>>
        %15 = struct.readm %14[@"$super"] : !struct.type<@TZip::@Zip<[!felt.type, !felt.type, @PEGS]>>, !array.type<9 x !struct.type<@TPair::@Pair<[!felt.type, !felt.type]>>>
        %17 = array.len %15, %c0 : !array.type<9 x !struct.type<@TPair::@Pair<[!felt.type, !felt.type]>>>
        scf.for %arg5 = %c0 to %17 step %c1 {
          %34 = array.read %15[%arg5] : !array.type<9 x !struct.type<@TPair::@Pair<[!felt.type, !felt.type]>>>, !struct.type<@TPair::@Pair<[!felt.type, !felt.type]>>
        }
        function.return
      }
    }
  }

  poly.template @TMain {
    struct.def @Main {
      function.def @compute() -> !struct.type<@TMain::@Main<[]>> {
        %self = struct.new : !struct.type<@TMain::@Main<[]>>
        %26 = function.call @TMakeGuess::@MakeGuess::@compute() : () -> !struct.type<@TMakeGuess::@MakeGuess<[4]>>
        function.return %self : !struct.type<@TMain::@Main<[]>>
      }
      function.def @constrain(%arg0: !struct.type<@TMain::@Main<[]>>) {
        function.return
      }
    }
  }
}

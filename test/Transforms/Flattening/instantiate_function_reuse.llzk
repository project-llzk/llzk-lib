// RUN: llzk-opt -split-input-file -llzk-flatten=cleanup=disabled %s | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
  poly.template @T {
    poly.param @N : index
    function.def @compute() -> index {
      %n = poly.read_const @N : index
      function.return %n : index
    }

    function.def @other() -> index {
      %value = arith.constant 8 : index
      function.return %value : index
    }
  }

  function.def @T_35_compute() -> index {
    %wrong = arith.constant 99 : index
    function.return %wrong : index
  }

  function.def @main() -> index {
    %got = function.call @T::@compute<[35]>() : () -> index
    %got_again = function.call @T::@compute<[35]>() : () -> index
    %different_binding = function.call @T::@compute<[36]>() : () -> index
    %different_binding_again = function.call @T::@compute<[36]>() : () -> index
    %different_source = function.call @T::@other<[35]>() : () -> index
    %different_source_again = function.call @T::@other<[35]>() : () -> index
    function.return %different_source_again : index
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK:       function.def @[[COMPUTE_35:T_35_compute_[0-9]+]]() -> index {
// CHECK:         arith.constant 35 : index
// CHECK:       function.def @[[COMPUTE_36:T_36_compute]]() -> index {
// CHECK:         arith.constant 36 : index
// CHECK:       function.def @[[OTHER_35:T_35_other]]() -> index {
// CHECK:         arith.constant 8 : index
// CHECK:       function.def @main() -> index {
// CHECK:         function.call @[[COMPUTE_35]]()
// CHECK-NEXT:    function.call @[[COMPUTE_35]]()
// CHECK-NEXT:    function.call @[[COMPUTE_36]]()
// CHECK-NEXT:    function.call @[[COMPUTE_36]]()
// CHECK-NEXT:    function.call @[[OTHER_35]]()
// CHECK-NEXT:    function.call @[[OTHER_35]]()

// -----

module attributes {llzk.lang} {
  poly.template @"T_35_\1A" {
    poly.param @Ty : !poly.tvar<@Ty>
    function.def @compute() -> index {
      %wrong = arith.constant 99 : index
      function.return %wrong : index
    }
  }

  poly.template @T {
    poly.param @N : index
    poly.param @Ty : !poly.tvar<@Ty>
    function.def @compute() -> index {
      %value = arith.constant 7 : index
      function.return %value : index
    }

    function.def @other() -> index {
      %value = arith.constant 8 : index
      function.return %value : index
    }
  }

  function.def @main() -> index {
    %got = function.call @T::@compute<[35, ?]>() : () -> index
    %got_again = function.call @T::@compute<[35, ?]>() : () -> index
    %different_binding = function.call @T::@compute<[36, ?]>() : () -> index
    %different_binding_again = function.call @T::@compute<[36, ?]>() : () -> index
    %different_source = function.call @T::@other<[35, ?]>() : () -> index
    %different_source_again = function.call @T::@other<[35, ?]>() : () -> index
    function.return %different_source_again : index
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK:       poly.template @"[[COMPUTE_35:T_35_\\1A_[0-9]+]]" {
// CHECK:         arith.constant 7 : index
// CHECK:       poly.template @"[[COMPUTE_36:T_36_\\1A]]" {
// CHECK:         arith.constant 7 : index
// CHECK:       poly.template @"[[OTHER_35:T_35_\\1A_[0-9]+]]" {
// CHECK:         arith.constant 8 : index
// CHECK:       function.def @main() -> index {
// CHECK:         function.call @"[[COMPUTE_35]]"::@compute<[?]>()
// CHECK-NEXT:    function.call @"[[COMPUTE_35]]"::@compute<[?]>()
// CHECK-NEXT:    function.call @"[[COMPUTE_36]]"::@compute<[?]>()
// CHECK-NEXT:    function.call @"[[COMPUTE_36]]"::@compute<[?]>()
// CHECK-NEXT:    function.call @"[[OTHER_35]]"::@other<[?]>()
// CHECK-NEXT:    function.call @"[[OTHER_35]]"::@other<[?]>()

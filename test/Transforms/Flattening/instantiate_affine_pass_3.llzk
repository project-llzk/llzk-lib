// RUN: llzk-opt -split-input-file -llzk-flatten -verify-diagnostics %s | FileCheck %s
// REQUIRES: todo-update-passes-for-template

#id = affine_map<(i)->(i)>
!ToFelt = !struct.type<@TToFelt::@ToFelt<[#id]>>
module attributes {llzk.lang} {
  poly.template @TToFelt {
    poly.param @A

    struct.def @ToFelt {
      function.def @compute() -> !struct.type<@TToFelt::@ToFelt<[@A]>> {
        %self = struct.new : !struct.type<@TToFelt::@ToFelt<[@A]>>
        function.return %self: !struct.type<@TToFelt::@ToFelt<[@A]>>
      }

      function.def @constrain(%self: !struct.type<@TToFelt::@ToFelt<[@A]>>) { function.return }
    }
  }

  poly.template @TComponentA {
    poly.param @T

    struct.def @ComponentA {
      function.def @compute(%inp: !struct.type<@TToFelt::@ToFelt<[@T]>>) -> !struct.type<@TComponentA::@ComponentA<[@T]>> {
        %self = struct.new : !struct.type<@TComponentA::@ComponentA<[@T]>>
        function.return %self : !struct.type<@TComponentA::@ComponentA<[@T]>>
      }

      function.def @constrain(%self: !struct.type<@TComponentA::@ComponentA<[@T]>>, %inp: !struct.type<@TToFelt::@ToFelt<[@T]>>) { function.return }
    }
  }

  struct.def @ComponentB {
    function.def @compute() -> !struct.type<@ComponentB> {
      // In real code, this should be loop induction variable
      %n = arith.constant 2 : index
      %in = function.call @TToFelt::@ToFelt::@compute(){(%n)} : () -> !ToFelt
      %out = function.call @TComponentA::@ComponentA::@compute(%in) : (!ToFelt) -> !struct.type<@TComponentA::@ComponentA<[2]>>

      %self = struct.new : !struct.type<@ComponentB>
      function.return %self : !struct.type<@ComponentB>
    }

    function.def @constrain(%self: !struct.type<@ComponentB>) { function.return }
  }
}
// CHECK-LABEL: TODO

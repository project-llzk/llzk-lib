// RUN: llzk-opt --llzk-fuse-product-loops %s | FileCheck --enable-var-scope %s

module attributes {llzk.lang = "llzk"} {
  struct.def @ResultBearingConstrain {
    struct.member @value : !felt.type

    function.def @product(%condition: i1) -> !struct.type<@ResultBearingConstrain> {
      %self = struct.new : <@ResultBearingConstrain>
      %computed = scf.if %condition -> !felt.type {
        %zero = felt.const 0
        scf.yield %zero : !felt.type
      } else {
        %one = felt.const 1
        scf.yield %one : !felt.type
      } {product_source = "compute"}
      struct.writem %self[@value] = %computed : <@ResultBearingConstrain>, !felt.type

      %observed = scf.if %condition -> !felt.type {
        %zero = felt.const 0
        constrain.eq %computed, %zero : !felt.type
        scf.yield %zero : !felt.type
      } else {
        %one = felt.const 1
        constrain.eq %computed, %one : !felt.type
        scf.yield %one : !felt.type
      } {product_source = "constrain"}
      constrain.eq %observed, %computed : !felt.type

      function.return %self : !struct.type<@ResultBearingConstrain>
    }
  }

  struct.def @ElseMismatch {
    struct.member @value : !felt.type

    function.def @product(%condition: i1) -> !struct.type<@ElseMismatch> {
      %self = struct.new : <@ElseMismatch>
      %computed = scf.if %condition -> !felt.type {
        %zero = felt.const 0
        scf.yield %zero : !felt.type
      } else {
        %one = felt.const 1
        scf.yield %one : !felt.type
      } {product_source = "compute"}
      struct.writem %self[@value] = %computed : <@ElseMismatch>, !felt.type

      scf.if %condition {
        %zero = felt.const 0
        constrain.eq %computed, %zero : !felt.type
      } {product_source = "constrain"}

      function.return %self : !struct.type<@ElseMismatch>
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang = "llzk"} {
// CHECK-NEXT:    struct.def @ResultBearingConstrain {
// CHECK-NEXT:      struct.member @value : !felt.type
// CHECK-NEXT:      function.def @product(%[[VAL_0:[0-9a-zA-Z_\.]+]]: i1) -> !struct.type<@ResultBearingConstrain> attributes {function.allow_constraint, function.allow_witness} {
// CHECK-NEXT:        %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@ResultBearingConstrain>
// CHECK-NEXT:        %[[VAL_2:[0-9a-zA-Z_\.]+]] = scf.if %[[VAL_0]] -> (!felt.type) {
// CHECK-NEXT:          %[[VAL_3:[0-9a-zA-Z_\.]+]] = felt.const  0
// CHECK-NEXT:          scf.yield %[[VAL_3]] : !felt.type
// CHECK-NEXT:        } else {
// CHECK-NEXT:          %[[VAL_4:[0-9a-zA-Z_\.]+]] = felt.const  1
// CHECK-NEXT:          scf.yield %[[VAL_4]] : !felt.type
// CHECK-NEXT:        } {product_source = "compute"}
// CHECK-NEXT:        struct.writem %[[VAL_1]][@value] = %[[VAL_2]] : <@ResultBearingConstrain>, !felt.type
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = scf.if %[[VAL_0]] -> (!felt.type) {
// CHECK-NEXT:          %[[VAL_6:[0-9a-zA-Z_\.]+]] = felt.const  0
// CHECK-NEXT:          constrain.eq %[[VAL_2]], %[[VAL_6]] : !felt.type, !felt.type
// CHECK-NEXT:          scf.yield %[[VAL_6]] : !felt.type
// CHECK-NEXT:        } else {
// CHECK-NEXT:          %[[VAL_7:[0-9a-zA-Z_\.]+]] = felt.const  1
// CHECK-NEXT:          constrain.eq %[[VAL_2]], %[[VAL_7]] : !felt.type, !felt.type
// CHECK-NEXT:          scf.yield %[[VAL_7]] : !felt.type
// CHECK-NEXT:        } {product_source = "constrain"}
// CHECK-NEXT:        constrain.eq %[[VAL_5]], %[[VAL_2]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return %[[VAL_1]] : !struct.type<@ResultBearingConstrain>
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @ElseMismatch {
// CHECK-NEXT:      struct.member @value : !felt.type
// CHECK-NEXT:      function.def @product(%[[VAL_8:[0-9a-zA-Z_\.]+]]: i1) -> !struct.type<@ElseMismatch> attributes {function.allow_constraint, function.allow_witness} {
// CHECK-NEXT:        %[[VAL_9:[0-9a-zA-Z_\.]+]] = struct.new : <@ElseMismatch>
// CHECK-NEXT:        %[[VAL_10:[0-9a-zA-Z_\.]+]] = scf.if %[[VAL_8]] -> (!felt.type) {
// CHECK-NEXT:          %[[VAL_11:[0-9a-zA-Z_\.]+]] = felt.const  0
// CHECK-NEXT:          scf.yield %[[VAL_11]] : !felt.type
// CHECK-NEXT:        } else {
// CHECK-NEXT:          %[[VAL_12:[0-9a-zA-Z_\.]+]] = felt.const  1
// CHECK-NEXT:          scf.yield %[[VAL_12]] : !felt.type
// CHECK-NEXT:        } {product_source = "compute"}
// CHECK-NEXT:        struct.writem %[[VAL_9]][@value] = %[[VAL_10]] : <@ElseMismatch>, !felt.type
// CHECK-NEXT:        scf.if %[[VAL_8]] {
// CHECK-NEXT:          %[[VAL_13:[0-9a-zA-Z_\.]+]] = felt.const  0
// CHECK-NEXT:          constrain.eq %[[VAL_10]], %[[VAL_13]] : !felt.type, !felt.type
// CHECK-NEXT:        } {product_source = "constrain"}
// CHECK-NEXT:        function.return %[[VAL_9]] : !struct.type<@ElseMismatch>
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

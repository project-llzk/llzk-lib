// RUN: llzk-opt --llzk-fuse-product-loops %s | FileCheck --enable-var-scope %s

module attributes {llzk.lang = "llzk"} {
  struct.def @A {
    struct.member @foo : !felt.type

    function.def @product(%b: i1) -> !struct.type<@A> {
      %self = struct.new : <@A>
      %idx = arith.constant 0 : index
      %arr = array.new : !array.type<1,1 x !felt.type>
      %row0 = array.new : !array.type<1 x !felt.type>
      %row1 = array.new : !array.type<1 x !felt.type>

      %0 = scf.if %b -> !felt.type {
        %zero = felt.const 0
        scf.yield %zero : !felt.type
      } else {
        %one = felt.const 1
        scf.yield %one : !felt.type
      } {product_source = "compute"}

      struct.writem %self[@foo] = %0 : <@A>, !felt.type

      scf.if %b {
        array.insert %arr[%idx] = %row0 : !array.type<1,1 x !felt.type>, !array.type<1 x !felt.type>
      } else {
        array.insert %arr[%idx] = %row1 : !array.type<1,1 x !felt.type>, !array.type<1 x !felt.type>
      } {product_source = "constrain"}

      function.return %self : !struct.type<@A>
    }
  }
}

// CHECK-LABEL: function.def @product
// CHECK-SAME:  (%[[B:[0-9a-zA-Z_\.]+]]: i1) -> !struct.type<@A>
// CHECK:         %[[SELF:[0-9a-zA-Z_\.]+]] = struct.new : <@A>
// CHECK:         %[[IDX:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK:         %[[ARR:[0-9a-zA-Z_\.]+]] = array.new
// CHECK:         %[[ROW0:[0-9a-zA-Z_\.]+]] = array.new
// CHECK:         %[[ROW1:[0-9a-zA-Z_\.]+]] = array.new
// CHECK:         %[[RESULT:[0-9a-zA-Z_\.]+]] = scf.if %[[B]] -> (!felt.type)
// CHECK:         } {product_source = "compute"}
// CHECK-NEXT:    struct.writem %[[SELF]][@foo] = %[[RESULT]] : <@A>, !felt.type
// CHECK-NEXT:    scf.if %[[B]] {
// CHECK:           array.insert %[[ARR]][%[[IDX]]] = %[[ROW0]]
// CHECK:         } else {
// CHECK:           array.insert %[[ARR]][%[[IDX]]] = %[[ROW1]]
// CHECK:         } {product_source = "constrain"}

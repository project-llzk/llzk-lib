// RUN: llzk-opt --llzk-compute-constrain-to-product="root-struct=A" --llzk-fuse-product-loops %s | FileCheck --enable-var-scope %s

module attributes {llzk.lang = "llzk"} {
  struct.def @A {
    struct.member @foo : !felt.type

    function.def @compute(%b: i1) -> !struct.type<@A> {
      %self = struct.new : <@A>

      %0 = scf.if %b -> !felt.type {
        %a = felt.const 0
        scf.yield %a : !felt.type
      } else {
        %a = felt.const 1
        scf.yield %a : !felt.type
      }

      struct.writem %self[@foo] = %0 : <@A>, !felt.type
      function.return %self : !struct.type<@A>
    }

    function.def @constrain(%self: !struct.type<@A>, %b: i1) {
      scf.if %b {
        %zero = felt.const 0
        function.call @A::@check_foo(%self, %zero) : (!struct.type<@A>, !felt.type) -> ()
      } else {
        %one = felt.const 1
        function.call @A::@check_foo(%self, %one) : (!struct.type<@A>, !felt.type) -> ()
      }

      function.return
    }

    function.def @check_foo(%self: !struct.type<@A>, %expected: !felt.type) attributes {function.allow_constraint} {
      %foo = struct.readm %self[@foo] : <@A>, !felt.type
      constrain.eq %foo, %expected : !felt.type
      function.return
    }
  }
}

// CHECK-LABEL: function.def @product
// CHECK-SAME:  (%[[B:[0-9a-zA-Z_\.]+]]: i1) -> !struct.type<@A>
// CHECK:         %[[SELF:[0-9a-zA-Z_\.]+]] = struct.new : <@A>
// CHECK:         %[[RESULT:[0-9a-zA-Z_\.]+]] = scf.if %[[B]] -> (!felt.type)
// CHECK:         struct.writem %[[SELF]][@foo] = %[[RESULT]] : <@A>, !felt.type
// CHECK:         scf.if %[[B]] {
// CHECK:           function.call @A::@check_foo(%[[SELF]]
// CHECK:         } else {
// CHECK:           function.call @A::@check_foo(%[[SELF]]

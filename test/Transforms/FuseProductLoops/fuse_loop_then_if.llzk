// RUN: llzk-opt --llzk-compute-constrain-to-product="root-struct=A" --llzk-fuse-product-loops %s | FileCheck --enable-var-scope %s
module attributes {llzk.lang = "llzk"} {
  struct.def @A {
    struct.member @foo : !felt.type

    function.def @compute(%b: i1) -> !struct.type<@A> {
      %self = struct.new : <@A>
      %c0 = arith.constant 0 : index
      %c2 = arith.constant 2 : index
      %c1 = arith.constant 1 : index

      scf.for %i = %c0 to %c2 step %c1 {
        %0 = scf.if %b -> !felt.type {
          %a = felt.const 0
          scf.yield %a : !felt.type
        } else {
          %a = felt.const 1
          scf.yield %a : !felt.type
        }

        struct.writem %self[@foo] = %0 : <@A>, !felt.type
      }

      function.return %self : !struct.type<@A>
    }

    function.def @constrain(%self: !struct.type<@A>, %b: i1) {
      %c0 = arith.constant 0 : index
      %c2 = arith.constant 2 : index
      %c1 = arith.constant 1 : index

      scf.for %i = %c0 to %c2 step %c1 {
        %foo = struct.readm %self[@foo] : <@A>, !felt.type
        scf.if %b {
          %val = felt.const 0
          constrain.eq %foo, %val : !felt.type
        } else {
          %val = felt.const 1
          constrain.eq %foo, %val : !felt.type
        }
      }

      function.return
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang = "llzk"} {
// CHECK-NEXT:    struct.def @A {
// CHECK-NEXT:      struct.member @foo : !felt.type
// CHECK-NEXT:      function.def @product(%[[VAL_0:[0-9a-zA-Z_\.]+]]: i1) -> !struct.type<@A> attributes {function.allow_constraint, function.allow_witness, llzk.derived} {
// CHECK-NEXT:        %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@A> {product_source = "compute"}
// CHECK-NEXT:        %[[VAL_2:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "compute"} 0 : index
// CHECK-NEXT:        %[[VAL_3:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "compute"} 2 : index
// CHECK-NEXT:        %[[VAL_4:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "compute"} 1 : index
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "constrain"} 0 : index
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "constrain"} 2 : index
// CHECK-NEXT:        %[[VAL_7:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "constrain"} 1 : index
// CHECK-NEXT:        scf.for %[[VAL_8:[0-9a-zA-Z_\.]+]] = %[[VAL_5]] to %[[VAL_6]] step %[[VAL_7]] {
// CHECK-NEXT:          %[[VAL_9:[0-9a-zA-Z_\.]+]] = scf.if %[[VAL_0]] -> (!felt.type) {
// CHECK-NEXT:            %[[VAL_10:[0-9a-zA-Z_\.]+]] = felt.const  0 {product_source = "compute"}
// CHECK-NEXT:            scf.yield {product_source = "compute"} %[[VAL_10]] : !felt.type
// CHECK-NEXT:          } else {
// CHECK-NEXT:            %[[VAL_11:[0-9a-zA-Z_\.]+]] = felt.const  1 {product_source = "compute"}
// CHECK-NEXT:            scf.yield {product_source = "compute"} %[[VAL_11]] : !felt.type
// CHECK-NEXT:          } {product_source = "compute"}
// CHECK-NEXT:          struct.writem %[[VAL_1]][@foo] = %[[VAL_9]] : <@A>, !felt.type {product_source = "compute"}
// CHECK-NEXT:          %[[VAL_12:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_1]][@foo] : <@A>, !felt.type {product_source = "constrain"}
// CHECK-NEXT:          scf.if %[[VAL_0]] {
// CHECK-NEXT:            %[[VAL_13:[0-9a-zA-Z_\.]+]] = felt.const  0 {product_source = "constrain"}
// CHECK-NEXT:            constrain.eq %[[VAL_12]], %[[VAL_13]] : !felt.type, !felt.type {product_source = "constrain"}
// CHECK-NEXT:          } else {
// CHECK-NEXT:            %[[VAL_14:[0-9a-zA-Z_\.]+]] = felt.const  1 {product_source = "constrain"}
// CHECK-NEXT:            constrain.eq %[[VAL_12]], %[[VAL_14]] : !felt.type, !felt.type {product_source = "constrain"}
// CHECK-NEXT:          } {product_source = "constrain"}
// CHECK-NEXT:        } {product_source = "fused"}
// CHECK-NEXT:        function.return %[[VAL_1]] : !struct.type<@A>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @compute(%[[VAL_15:[0-9a-zA-Z_\.]+]]: i1) -> !struct.type<@A> attributes {function.allow_witness, product_source = "compute"} {
// CHECK-NEXT:        %[[VAL_16:[0-9a-zA-Z_\.]+]] = struct.new : <@A> {product_source = "compute"}
// CHECK-NEXT:        %[[VAL_17:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "compute"} 0 : index
// CHECK-NEXT:        %[[VAL_18:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "compute"} 2 : index
// CHECK-NEXT:        %[[VAL_19:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "compute"} 1 : index
// CHECK-NEXT:        scf.for %[[VAL_20:[0-9a-zA-Z_\.]+]] = %[[VAL_17]] to %[[VAL_18]] step %[[VAL_19]] {
// CHECK-NEXT:          %[[VAL_21:[0-9a-zA-Z_\.]+]] = scf.if %[[VAL_15]] -> (!felt.type) {
// CHECK-NEXT:            %[[VAL_22:[0-9a-zA-Z_\.]+]] = felt.const  0 {product_source = "compute"}
// CHECK-NEXT:            scf.yield {product_source = "compute"} %[[VAL_22]] : !felt.type
// CHECK-NEXT:          } else {
// CHECK-NEXT:            %[[VAL_23:[0-9a-zA-Z_\.]+]] = felt.const  1 {product_source = "compute"}
// CHECK-NEXT:            scf.yield {product_source = "compute"} %[[VAL_23]] : !felt.type
// CHECK-NEXT:          } {product_source = "compute"}
// CHECK-NEXT:          struct.writem %[[VAL_16]][@foo] = %[[VAL_21]] : <@A>, !felt.type {product_source = "compute"}
// CHECK-NEXT:        } {product_source = "compute"}
// CHECK-NEXT:        function.return {product_source = "compute"} %[[VAL_16]] : !struct.type<@A>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_24:[0-9a-zA-Z_\.]+]]: !struct.type<@A>, %[[VAL_25:[0-9a-zA-Z_\.]+]]: i1) attributes {function.allow_constraint, product_source = "constrain"} {
// CHECK-NEXT:        %[[VAL_26:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "constrain"} 0 : index
// CHECK-NEXT:        %[[VAL_27:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "constrain"} 2 : index
// CHECK-NEXT:        %[[VAL_28:[0-9a-zA-Z_\.]+]] = arith.constant {product_source = "constrain"} 1 : index
// CHECK-NEXT:        scf.for %[[VAL_29:[0-9a-zA-Z_\.]+]] = %[[VAL_26]] to %[[VAL_27]] step %[[VAL_28]] {
// CHECK-NEXT:          %[[VAL_30:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_24]][@foo] : <@A>, !felt.type {product_source = "constrain"}
// CHECK-NEXT:          scf.if %[[VAL_25]] {
// CHECK-NEXT:            %[[VAL_31:[0-9a-zA-Z_\.]+]] = felt.const  0 {product_source = "constrain"}
// CHECK-NEXT:            constrain.eq %[[VAL_30]], %[[VAL_31]] : !felt.type, !felt.type {product_source = "constrain"}
// CHECK-NEXT:          } else {
// CHECK-NEXT:            %[[VAL_32:[0-9a-zA-Z_\.]+]] = felt.const  1 {product_source = "constrain"}
// CHECK-NEXT:            constrain.eq %[[VAL_30]], %[[VAL_32]] : !felt.type, !felt.type {product_source = "constrain"}
// CHECK-NEXT:          } {product_source = "constrain"}
// CHECK-NEXT:        } {product_source = "constrain"}
// CHECK-NEXT:        function.return {product_source = "constrain"}
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

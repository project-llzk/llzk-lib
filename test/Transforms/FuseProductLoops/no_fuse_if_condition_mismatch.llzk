// RUN: llzk-opt --llzk-compute-constrain-to-product="root-struct=A" --llzk-fuse-product-loops %s | FileCheck --enable-var-scope %s

module attributes {llzk.lang = "llzk"} {
  struct.def @A {
    struct.member @foo : !felt.type

    function.def @compute(%b: i1, %c: i1) -> !struct.type<@A> {
      %self = struct.new : <@A>

      %0 = scf.if %b -> !felt.type {
        %a = felt.const 0
        scf.yield %a : !felt.type
      } else {
        %a = felt.const 1
        scf.yield %a : !felt.type
      }

      struct.writem %self[@foo] = %0 : <@A>, !felt.type
      function.return %self : !struct.type<@A>
    }

    function.def @constrain(%self: !struct.type<@A>, %b: i1, %c: i1) {
      %foo = struct.readm %self[@foo] : <@A>, !felt.type
      scf.if %c {
        %val = felt.const 0
        constrain.eq %foo, %val : !felt.type
      } else {
        %val = felt.const 1
        constrain.eq %foo, %val : !felt.type
      }

      function.return
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang = "llzk"} {
// CHECK-NEXT:    struct.def @A {
// CHECK-NEXT:      struct.member @foo : !felt.type
// CHECK-NEXT:      function.def @product(%[[VAL_0:[0-9a-zA-Z_\.]+]]: i1, %[[VAL_1:[0-9a-zA-Z_\.]+]]: i1) -> !struct.type<@A> attributes {function.allow_constraint, function.allow_witness, llzk.derived} {
// CHECK-NEXT:        %[[VAL_2:[0-9a-zA-Z_\.]+]] = struct.new : <@A> {product_source = "compute"}
// CHECK-NEXT:        %[[VAL_3:[0-9a-zA-Z_\.]+]] = scf.if %[[VAL_0]] -> (!felt.type) {
// CHECK-NEXT:          %[[VAL_4:[0-9a-zA-Z_\.]+]] = felt.const  0 {product_source = "compute"}
// CHECK-NEXT:          scf.yield {product_source = "compute"} %[[VAL_4]] : !felt.type
// CHECK-NEXT:        } else {
// CHECK-NEXT:          %[[VAL_5:[0-9a-zA-Z_\.]+]] = felt.const  1 {product_source = "compute"}
// CHECK-NEXT:          scf.yield {product_source = "compute"} %[[VAL_5]] : !felt.type
// CHECK-NEXT:        } {product_source = "compute"}
// CHECK-NEXT:        struct.writem %[[VAL_2]][@foo] = %[[VAL_3]] : <@A>, !felt.type {product_source = "compute"}
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_2]][@foo] : <@A>, !felt.type {product_source = "constrain"}
// CHECK-NEXT:        scf.if %[[VAL_1]] {
// CHECK-NEXT:          %[[VAL_7:[0-9a-zA-Z_\.]+]] = felt.const  0 {product_source = "constrain"}
// CHECK-NEXT:          constrain.eq %[[VAL_6]], %[[VAL_7]] : !felt.type, !felt.type {product_source = "constrain"}
// CHECK-NEXT:        } else {
// CHECK-NEXT:          %[[VAL_8:[0-9a-zA-Z_\.]+]] = felt.const  1 {product_source = "constrain"}
// CHECK-NEXT:          constrain.eq %[[VAL_6]], %[[VAL_8]] : !felt.type, !felt.type {product_source = "constrain"}
// CHECK-NEXT:        } {product_source = "constrain"}
// CHECK-NEXT:        function.return %[[VAL_2]] : !struct.type<@A>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @compute(%[[VAL_9:[0-9a-zA-Z_\.]+]]: i1, %[[VAL_10:[0-9a-zA-Z_\.]+]]: i1) -> !struct.type<@A> attributes {function.allow_witness, product_source = "compute"} {
// CHECK-NEXT:        %[[VAL_11:[0-9a-zA-Z_\.]+]] = struct.new : <@A> {product_source = "compute"}
// CHECK-NEXT:        %[[VAL_12:[0-9a-zA-Z_\.]+]] = scf.if %[[VAL_9]] -> (!felt.type) {
// CHECK-NEXT:          %[[VAL_13:[0-9a-zA-Z_\.]+]] = felt.const  0 {product_source = "compute"}
// CHECK-NEXT:          scf.yield {product_source = "compute"} %[[VAL_13]] : !felt.type
// CHECK-NEXT:        } else {
// CHECK-NEXT:          %[[VAL_14:[0-9a-zA-Z_\.]+]] = felt.const  1 {product_source = "compute"}
// CHECK-NEXT:          scf.yield {product_source = "compute"} %[[VAL_14]] : !felt.type
// CHECK-NEXT:        } {product_source = "compute"}
// CHECK-NEXT:        struct.writem %[[VAL_11]][@foo] = %[[VAL_12]] : <@A>, !felt.type {product_source = "compute"}
// CHECK-NEXT:        function.return {product_source = "compute"} %[[VAL_11]] : !struct.type<@A>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_15:[0-9a-zA-Z_\.]+]]: !struct.type<@A>, %[[VAL_16:[0-9a-zA-Z_\.]+]]: i1, %[[VAL_17:[0-9a-zA-Z_\.]+]]: i1) attributes {function.allow_constraint, product_source = "constrain"} {
// CHECK-NEXT:        %[[VAL_18:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_15]][@foo] : <@A>, !felt.type {product_source = "constrain"}
// CHECK-NEXT:        scf.if %[[VAL_17]] {
// CHECK-NEXT:          %[[VAL_19:[0-9a-zA-Z_\.]+]] = felt.const  0 {product_source = "constrain"}
// CHECK-NEXT:          constrain.eq %[[VAL_18]], %[[VAL_19]] : !felt.type, !felt.type {product_source = "constrain"}
// CHECK-NEXT:        } else {
// CHECK-NEXT:          %[[VAL_20:[0-9a-zA-Z_\.]+]] = felt.const  1 {product_source = "constrain"}
// CHECK-NEXT:          constrain.eq %[[VAL_18]], %[[VAL_20]] : !felt.type, !felt.type {product_source = "constrain"}
// CHECK-NEXT:        } {product_source = "constrain"}
// CHECK-NEXT:        function.return {product_source = "constrain"}
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

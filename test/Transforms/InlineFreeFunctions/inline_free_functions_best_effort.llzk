// RUN: llzk-opt -llzk-inline-free-functions -verify-diagnostics %s > %t
// RUN: FileCheck --enable-var-scope %s < %t

// If a callee fails to inline, its calls are left in place with a warning
// while other eligible callees are still inlined. Normal cleanup still
// removes functions that become unused. RAM has no inlining interface, so
// @mem and @dead_mem exercise the failure path.
// NOTE: Assertions have been autogenerated by scripts/generate-test-checks.py

module attributes {llzk.lang} {
  function.def @dead_mem(%addr: index, %v: !felt.type) -> !felt.type attributes {function.allow_witness} {
    ram.store %addr, %v : !felt.type
    %r = ram.load %addr : !felt.type
    function.return %r : !felt.type
  }

  function.def @unused_wrapper(%addr: index, %v: !felt.type) -> !felt.type attributes {function.allow_witness} {
    // expected-warning@+1 {{failed to inline free function call; skipping this callee}}
    %r = function.call @dead_mem(%addr, %v) : (index, !felt.type) -> !felt.type
    function.return %r : !felt.type
  }

  function.def @mem(%addr: index, %v: !felt.type) -> !felt.type attributes {function.allow_witness} {
    ram.store %addr, %v : !felt.type
    %r = ram.load %addr : !felt.type
    function.return %r : !felt.type
  }

  function.def @add_one(%x: !felt.type) -> !felt.type {
    %one = felt.const 1
    %r = felt.add %x, %one : !felt.type, !felt.type
    function.return %r : !felt.type
  }

  struct.def @Main {
    struct.member @out : !felt.type {llzk.pub}
    function.def @compute(%x: !felt.type) -> !struct.type<@Main> attributes {function.allow_witness} {
      %self = struct.new : !struct.type<@Main>
      %i = arith.constant 0 : index
      // expected-warning@+1 {{failed to inline free function call; skipping this callee}}
      %m = function.call @mem(%i, %x) : (index, !felt.type) -> !felt.type
      struct.writem %self[@out] = %m : !struct.type<@Main>, !felt.type
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %x: !felt.type) {
      %r = function.call @add_one(%x) : (!felt.type) -> !felt.type
      %o = struct.readm %self[@out] : !struct.type<@Main>, !felt.type
      constrain.eq %o, %r : !felt.type, !felt.type
      function.return
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @mem(%[[VAL_0:[0-9a-zA-Z_\.]+]]: index, %[[VAL_1:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:      ram.store %[[VAL_0]], %[[VAL_1]] : !felt.type
// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = ram.load %[[VAL_0]] : !felt.type
// CHECK-NEXT:      function.return %[[VAL_2]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @Main {
// CHECK-NEXT:      struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_3:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_4:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = function.call @mem(%[[VAL_5]], %[[VAL_3]]) : (index, !felt.type) -> !felt.type
// CHECK-NEXT:        struct.writem %[[VAL_4]][@out] = %[[VAL_6]] : <@Main>, !felt.type
// CHECK-NEXT:        function.return %[[VAL_4]] : !struct.type<@Main>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_7:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>, %[[VAL_8:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_9:[0-9a-zA-Z_\.]+]] = felt.const  1
// CHECK-NEXT:        %[[VAL_10:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_8]], %[[VAL_9]] : !felt.type, !felt.type
// CHECK-NEXT:        %[[VAL_11:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_7]][@out] : <@Main>, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_11]], %[[VAL_10]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

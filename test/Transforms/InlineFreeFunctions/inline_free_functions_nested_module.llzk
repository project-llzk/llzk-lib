// The script is designed to make adding checks to
// a test case fast, it is *not* designed to be authoritative
// about what constitutes a good test! The CHECK should be
// minimized and named to reflect the test intent.

// RUN: llzk-opt -llzk-inline-free-functions %s | FileCheck --enable-var-scope %s

// Functions in nested modules are outside this pass's scope. Calls to them
// and their definitions stay unchanged.
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    module @lib {
// CHECK-NEXT:      function.def @helper(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type {
// CHECK-NEXT:        function.return %[[VAL_0]] : !felt.type
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @Main {
// CHECK-NEXT:      struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_1:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_2:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:        function.return %[[VAL_2]] : !struct.type<@Main>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_3:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>, %[[VAL_4:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = function.call @lib::@helper(%[[VAL_4]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_3]][@out] : <@Main>, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_6]], %[[VAL_5]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
module attributes {llzk.lang} {
  module @lib {
    function.def @helper(%x: !felt.type) -> !felt.type {
      function.return %x : !felt.type
    }
  }

  struct.def @Main {
    struct.member @out : !felt.type {llzk.pub}
    function.def @compute(%x: !felt.type) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %x: !felt.type) {
      %r = function.call @lib::@helper(%x) : (!felt.type) -> !felt.type
      %out = struct.readm %self[@out] : !struct.type<@Main>, !felt.type
      constrain.eq %out, %r : !felt.type, !felt.type
      function.return
    }
  }
}

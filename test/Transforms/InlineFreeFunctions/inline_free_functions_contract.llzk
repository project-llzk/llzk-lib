// NOTE: Assertions have been autogenerated by scripts/generate-test-checks.py

// The script is designed to make adding checks to
// a test case fast, it is *not* designed to be authoritative
// about what constitutes a good test! The CHECK should be
// minimized and named to reflect the test intent.

// RUN: llzk-opt -llzk-inline-free-functions -verify-diagnostics %s | FileCheck --enable-var-scope %s

// Calls outside function.def bodies are outside this pass's scope and should
// be left alone without an inlining-failure warning. Contract includes must
// also remain unchanged and must not crash call-graph construction.
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @target(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> (!felt.type {function.res_name = "ret_value"}) {
// CHECK-NEXT:      function.return %[[VAL_0]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @helper(%[[VAL_1:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type {
// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = felt.const  1
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_1]], %[[VAL_2]] : !felt.type, !felt.type
// CHECK-NEXT:      function.return %[[VAL_3]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:    verif.contract @Base for @target (%[[VAL_4:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_5:[0-9a-zA-Z_\.]+]]: !felt.type {function.res_name = "ret_value"}) {
// CHECK-NEXT:      %[[VAL_6:[0-9a-zA-Z_\.]+]] = bool.cmp eq(%[[VAL_4]], %[[VAL_5]]) : !felt.type, !felt.type
// CHECK-NEXT:      verif.ensure_compute %[[VAL_6]]
// CHECK-NEXT:    }
// CHECK-NEXT:    verif.contract @C for @target (%[[VAL_7:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_8:[0-9a-zA-Z_\.]+]]: !felt.type {function.res_name = "ret_value"}) {
// CHECK-NEXT:      %[[VAL_9:[0-9a-zA-Z_\.]+]] = function.call @helper(%[[VAL_7]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:      %[[VAL_10:[0-9a-zA-Z_\.]+]] = bool.cmp eq(%[[VAL_9]], %[[VAL_8]]) : !felt.type, !felt.type
// CHECK-NEXT:      verif.include @Base(%[[VAL_7]], %[[VAL_8]]) : (!felt.type, !felt.type) -> ()
// CHECK-NEXT:      verif.ensure_compute %[[VAL_10]]
// CHECK-NEXT:    }
// CHECK-NEXT:  }
module attributes {llzk.lang} {
  function.def @target(%x: !felt.type) -> (!felt.type {function.res_name = "ret_value"}) {
    function.return %x : !felt.type
  }

  function.def @helper(%x: !felt.type) -> !felt.type {
    %one = felt.const 1
    %result = felt.add %x, %one : !felt.type, !felt.type
    function.return %result : !felt.type
  }

  verif.contract @Base for @target (%x: !felt.type, %ret_value: !felt.type {function.res_name = "ret_value"}) {
    %ok = bool.cmp eq(%x, %ret_value) : !felt.type, !felt.type
    verif.ensure_compute %ok
  }

  verif.contract @C for @target (%x: !felt.type, %ret_value: !felt.type {function.res_name = "ret_value"}) {
    %result = function.call @helper(%x) : (!felt.type) -> !felt.type
    %ok = bool.cmp eq(%result, %ret_value) : !felt.type, !felt.type
    verif.include @Base(%x, %ret_value) : (!felt.type, !felt.type) -> ()
    verif.ensure_compute %ok
  }
}

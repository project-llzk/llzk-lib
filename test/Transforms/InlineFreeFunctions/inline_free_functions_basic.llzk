// RUN: llzk-opt -split-input-file -llzk-inline-free-functions %s | FileCheck --enable-var-scope %s

// Simple single-callee scenario.
// NOTE: Assertions have been autogenerated by scripts/generate-test-checks.py

module attributes {llzk.lang} {
  function.def @add_one(%x: !felt.type) -> !felt.type {
    %one = felt.const 1
    %r = felt.add %x, %one : !felt.type, !felt.type
    function.return %r : !felt.type
  }

  struct.def @Main {
    struct.member @out : !felt.type {llzk.pub}
    function.def @compute(%x: !felt.type) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %x: !felt.type) {
      %r = function.call @add_one(%x) : (!felt.type) -> !felt.type
      %o = struct.readm %self[@out] : !struct.type<@Main>, !felt.type
      constrain.eq %o, %r : !felt.type, !felt.type
      function.return
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    struct.def @Main {
// CHECK-NEXT:      struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:        function.return %[[VAL_1]] : !struct.type<@Main>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>, %[[VAL_3:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_4:[0-9a-zA-Z_\.]+]] = felt.const  1
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_3]], %[[VAL_4]] : !felt.type, !felt.type
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_2]][@out] : <@Main>, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_6]], %[[VAL_5]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

// -----


// Multiple call sites of the same helper.
module attributes {llzk.lang} {
  function.def @double(%x: !felt.type) -> !felt.type {
    %r = felt.add %x, %x : !felt.type, !felt.type
    function.return %r : !felt.type
  }

  struct.def @Main {
    struct.member @out : !felt.type {llzk.pub}
    function.def @compute(%x: !felt.type, %y: !felt.type) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %x: !felt.type, %y: !felt.type) {
      %a = function.call @double(%x) : (!felt.type) -> !felt.type
      %b = function.call @double(%y) : (!felt.type) -> !felt.type
      %sum = felt.add %a, %b : !felt.type, !felt.type
      %o = struct.readm %self[@out] : !struct.type<@Main>, !felt.type
      constrain.eq %o, %sum : !felt.type, !felt.type
      function.return
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    struct.def @Main {
// CHECK-NEXT:      struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_1:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_2:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:        function.return %[[VAL_2]] : !struct.type<@Main>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_3:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>, %[[VAL_4:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_5:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_4]], %[[VAL_4]] : !felt.type, !felt.type
// CHECK-NEXT:        %[[VAL_7:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_5]], %[[VAL_5]] : !felt.type, !felt.type
// CHECK-NEXT:        %[[VAL_8:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_6]], %[[VAL_7]] : !felt.type, !felt.type
// CHECK-NEXT:        %[[VAL_9:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_3]][@out] : <@Main>, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_9]], %[[VAL_8]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

// -----


// A call to a struct-scoped function must be left alone, and the containing
// struct must not be erased by the cleanup sweep.
// Also exercises the `isExternal()` guard.
module attributes {llzk.lang} {
  function.def @top_helper(%x: !felt.type) -> !felt.type {
    %two = felt.const 2
    %r = felt.mul %x, %two : !felt.type, !felt.type
    function.return %r : !felt.type
  }

  function.def private @abort()

  struct.def @Helper {
    function.def @compute() -> !struct.type<@Helper> {
      %self = struct.new : !struct.type<@Helper>
      function.return %self : !struct.type<@Helper>
    }
    function.def @constrain(%self: !struct.type<@Helper>) {
      function.return
    }
  }

  struct.def @Main {
    struct.member @h : !struct.type<@Helper>
    struct.member @out : !felt.type {llzk.pub}
    function.def @compute(%x: !felt.type) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %x: !felt.type) {
      %r = function.call @top_helper(%x) : (!felt.type) -> !felt.type
      %h = struct.readm %self[@h] : !struct.type<@Main>, !struct.type<@Helper>
      function.call @Helper::@constrain(%h) : (!struct.type<@Helper>) -> ()
      function.call @abort() : () -> ()
      %o = struct.readm %self[@out] : !struct.type<@Main>, !felt.type
      constrain.eq %o, %r : !felt.type, !felt.type
      function.return
    }
  }
}

// The free-function helper is inlined and erased; `@abort` survives.

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def private @abort()
// CHECK-NEXT:    struct.def @Helper {
// CHECK-NEXT:      function.def @compute() -> !struct.type<@Helper> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_0:[0-9a-zA-Z_\.]+]] = struct.new : <@Helper>
// CHECK-NEXT:        function.return %[[VAL_0]] : !struct.type<@Helper>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_1:[0-9a-zA-Z_\.]+]]: !struct.type<@Helper>) attributes {function.allow_constraint} {
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @Main {
// CHECK-NEXT:      struct.member @h : !struct.type<@Helper>
// CHECK-NEXT:      struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_3:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:        function.return %[[VAL_3]] : !struct.type<@Main>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_4:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>, %[[VAL_5:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = felt.const  2
// CHECK-NEXT:        %[[VAL_7:[0-9a-zA-Z_\.]+]] = felt.mul %[[VAL_5]], %[[VAL_6]] : !felt.type, !felt.type
// CHECK-NEXT:        %[[VAL_8:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_4]][@h] : <@Main>, !struct.type<@Helper>
// CHECK-NEXT:        function.call @Helper::@constrain(%[[VAL_8]]) : (!struct.type<@Helper>) -> ()
// CHECK-NEXT:        function.call @abort() : () -> ()
// CHECK-NEXT:        %[[VAL_9:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_4]][@out] : <@Main>, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_9]], %[[VAL_7]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

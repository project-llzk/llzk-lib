// RUN: llzk-opt -llzk-full-inlining %s | FileCheck %s

// A struct referenced only from a root free-function body must remain alive
// until that body is inlined into @Main. Struct cleanup can then see the use
// and preserve the referenced definition.

// CHECK-LABEL: module attributes {llzk.lang, llzk.main = !struct.type<@Main>} {
// CHECK-NEXT:    struct.def @HelperBox {
// CHECK-NEXT:      struct.member @value : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@HelperBox> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@HelperBox>
// CHECK-NEXT:        struct.writem %[[VAL_1]][@value] = %[[VAL_0]] : <@HelperBox>, !felt.type
// CHECK-NEXT:        function.return %[[VAL_1]] : !struct.type<@HelperBox>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@HelperBox>, %[[VAL_3:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @Main {
// CHECK-NEXT:      struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_4:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = function.call @HelperBox::@compute(%[[VAL_4]]) : (!felt.type) -> !struct.type<@HelperBox>
// CHECK-NEXT:        %[[VAL_7:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_6]][@value] : <@HelperBox>, !felt.type
// CHECK-NEXT:        struct.writem %[[VAL_5]][@out] = %[[VAL_7]] : <@Main>, !felt.type
// CHECK-NEXT:        function.return %[[VAL_5]] : !struct.type<@Main>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_8:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>, %[[VAL_9:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_10:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_8]][@out] : <@Main>, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_10]], %[[VAL_9]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
module attributes {llzk.main = !struct.type<@Main>, llzk.lang} {
  struct.def @HelperBox {
    struct.member @value : !felt.type {llzk.pub}

    function.def @compute(%value: !felt.type) -> !struct.type<@HelperBox> {
      %self = struct.new : !struct.type<@HelperBox>
      struct.writem %self[@value] = %value : !struct.type<@HelperBox>, !felt.type
      function.return %self : !struct.type<@HelperBox>
    }

    function.def @constrain(%self: !struct.type<@HelperBox>, %value: !felt.type) {
      function.return
    }
  }

  function.def @blackbox(%value: !felt.type) -> !felt.type attributes {function.allow_witness} {
    %box = function.call @HelperBox::@compute(%value) : (!felt.type) -> !struct.type<@HelperBox>
    %result = struct.readm %box[@value] : !struct.type<@HelperBox>, !felt.type
    function.return %result : !felt.type
  }

  struct.def @Main {
    struct.member @out : !felt.type {llzk.pub}

    function.def @compute(%value: !felt.type) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %result = function.call @blackbox(%value) : (!felt.type) -> !felt.type
      struct.writem %self[@out] = %result : !struct.type<@Main>, !felt.type
      function.return %self : !struct.type<@Main>
    }

    function.def @constrain(%self: !struct.type<@Main>, %value: !felt.type) {
      %result = struct.readm %self[@out] : !struct.type<@Main>, !felt.type
      constrain.eq %result, %value : !felt.type
      function.return
    }
  }
}

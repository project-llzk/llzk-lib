// RUN: llzk-opt -split-input-file -llzk-inline-free-functions %s | FileCheck --enable-var-scope %s

// Free functions in a call cycle are skipped (inlining one would
// re-materialize its calls forever): their call sites and definitions
// survive, while everything else is still inlined.

// Self-recursive @rec is left alone; @add_one is inlined and erased.
// NOTE: Assertions have been autogenerated by scripts/generate-test-checks.py

module attributes {llzk.lang} {
  function.def @rec(%x: !felt.type) -> !felt.type {
    %r = function.call @rec(%x) : (!felt.type) -> !felt.type
    function.return %r : !felt.type
  }

  function.def @add_one(%x: !felt.type) -> !felt.type {
    %one = felt.const 1
    %r = felt.add %x, %one : !felt.type, !felt.type
    function.return %r : !felt.type
  }

  struct.def @Main {
    struct.member @out : !felt.type {llzk.pub}
    function.def @compute(%x: !felt.type) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %x: !felt.type) {
      %a = function.call @rec(%x) : (!felt.type) -> !felt.type
      %b = function.call @add_one(%a) : (!felt.type) -> !felt.type
      %o = struct.readm %self[@out] : !struct.type<@Main>, !felt.type
      constrain.eq %o, %b : !felt.type, !felt.type
      function.return
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @rec(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type {
// CHECK-NEXT:      %[[VAL_1:[0-9a-zA-Z_\.]+]] = function.call @rec(%[[VAL_0]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:      function.return %[[VAL_1]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @Main {
// CHECK-NEXT:      struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_3:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:        function.return %[[VAL_3]] : !struct.type<@Main>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_4:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>, %[[VAL_5:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = function.call @rec(%[[VAL_5]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:        %[[VAL_7:[0-9a-zA-Z_\.]+]] = felt.const  1
// CHECK-NEXT:        %[[VAL_8:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_6]], %[[VAL_7]] : !felt.type, !felt.type
// CHECK-NEXT:        %[[VAL_9:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_4]][@out] : <@Main>, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_9]], %[[VAL_8]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

// -----


// Mutually recursive functions both survive with their calls.
module attributes {llzk.lang} {
  function.def @ping(%x: !felt.type) -> !felt.type {
    %r = function.call @pong(%x) : (!felt.type) -> !felt.type
    function.return %r : !felt.type
  }

  function.def @pong(%x: !felt.type) -> !felt.type {
    %r = function.call @ping(%x) : (!felt.type) -> !felt.type
    function.return %r : !felt.type
  }

  struct.def @Main {
    struct.member @out : !felt.type {llzk.pub}
    function.def @compute(%x: !felt.type) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %x: !felt.type) {
      %r = function.call @ping(%x) : (!felt.type) -> !felt.type
      %o = struct.readm %self[@out] : !struct.type<@Main>, !felt.type
      constrain.eq %o, %r : !felt.type, !felt.type
      function.return
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @ping(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type {
// CHECK-NEXT:      %[[VAL_1:[0-9a-zA-Z_\.]+]] = function.call @pong(%[[VAL_0]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:      function.return %[[VAL_1]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @pong(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type {
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = function.call @ping(%[[VAL_2]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:      function.return %[[VAL_3]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @Main {
// CHECK-NEXT:      struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_4:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:        function.return %[[VAL_5]] : !struct.type<@Main>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_6:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>, %[[VAL_7:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_8:[0-9a-zA-Z_\.]+]] = function.call @ping(%[[VAL_7]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:        %[[VAL_9:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_6]][@out] : <@Main>, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_9]], %[[VAL_8]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

// -----


// A recursive function in a nested module is also detected and skipped
// (instead of hanging the inline loop).
module attributes {llzk.lang} {
  module @lib {
    function.def @loop(%x: !felt.type) -> !felt.type {
      %r = function.call @lib::@loop(%x) : (!felt.type) -> !felt.type
      function.return %r : !felt.type
    }
  }

  struct.def @Main {
    struct.member @out : !felt.type {llzk.pub}
    function.def @compute(%x: !felt.type) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %x: !felt.type) {
      %r = function.call @lib::@loop(%x) : (!felt.type) -> !felt.type
      %o = struct.readm %self[@out] : !struct.type<@Main>, !felt.type
      constrain.eq %o, %r : !felt.type, !felt.type
      function.return
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    module @lib {
// CHECK-NEXT:      function.def @loop(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type {
// CHECK-NEXT:        %[[VAL_1:[0-9a-zA-Z_\.]+]] = function.call @lib::@loop(%[[VAL_0]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:        function.return %[[VAL_1]] : !felt.type
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @Main {
// CHECK-NEXT:      struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_3:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:        function.return %[[VAL_3]] : !struct.type<@Main>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_4:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>, %[[VAL_5:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = function.call @lib::@loop(%[[VAL_5]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:        %[[VAL_7:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_4]][@out] : <@Main>, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_7]], %[[VAL_6]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

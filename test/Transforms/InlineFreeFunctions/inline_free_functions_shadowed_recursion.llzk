// NOTE: Assertions have been autogenerated by scripts/generate-test-checks.py

// The script is designed to make adding checks to
// a test case fast, it is *not* designed to be authoritative
// about what constitutes a good test! The CHECK should be
// minimized and named to reflect the test intent.

// RUN: llzk-opt -llzk-inline-free-functions %s | FileCheck --enable-var-scope %s

// CallGraphAnalysis and the inliner must resolve function.call targets the
// same way. The nested @f shadows the root @f for nearest-symbol lookup, but
// function.call resolves from the LLZK root; the resulting cycle is skipped.
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @f(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type {
// CHECK-NEXT:      %[[VAL_1:[0-9a-zA-Z_\.]+]] = function.call @lib::@g(%[[VAL_0]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:      function.return %[[VAL_1]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:    module @lib {
// CHECK-NEXT:      function.def @f(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type {
// CHECK-NEXT:        function.return %[[VAL_2]] : !felt.type
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @g(%[[VAL_3:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type {
// CHECK-NEXT:        %[[VAL_4:[0-9a-zA-Z_\.]+]] = function.call @f(%[[VAL_3]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:        function.return %[[VAL_4]] : !felt.type
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    struct.def @Main {
// CHECK-NEXT:      struct.member @out : !felt.type {llzk.pub}
// CHECK-NEXT:      function.def @compute(%[[VAL_5:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@Main> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = struct.new : <@Main>
// CHECK-NEXT:        function.return %[[VAL_6]] : !struct.type<@Main>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_7:[0-9a-zA-Z_\.]+]]: !struct.type<@Main>, %[[VAL_8:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_9:[0-9a-zA-Z_\.]+]] = function.call @f(%[[VAL_8]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:        %[[VAL_10:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_7]][@out] : <@Main>, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_10]], %[[VAL_9]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }
module attributes {llzk.lang} {
  function.def @f(%x: !felt.type) -> !felt.type {
    %r = function.call @lib::@g(%x) : (!felt.type) -> !felt.type
    function.return %r : !felt.type
  }

  module @lib {
    function.def @f(%x: !felt.type) -> !felt.type {
      function.return %x : !felt.type
    }
    function.def @g(%x: !felt.type) -> !felt.type {
      %r = function.call @f(%x) : (!felt.type) -> !felt.type
      function.return %r : !felt.type
    }
  }

  struct.def @Main {
    struct.member @out : !felt.type {llzk.pub}
    function.def @compute(%x: !felt.type) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %x: !felt.type) {
      %r = function.call @f(%x) : (!felt.type) -> !felt.type
      %out = struct.readm %self[@out] : !struct.type<@Main>, !felt.type
      constrain.eq %out, %r : !felt.type, !felt.type
      function.return
    }
  }
}

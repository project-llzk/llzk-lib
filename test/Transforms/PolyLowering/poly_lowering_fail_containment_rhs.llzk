  struct.def @AmbiguousContainmentArrayExtractIndex {
    function.def @compute(%a: !felt.type, %b: !felt.type, %c: !felt.type, %d: !felt.type, %i: index) -> !struct.type<@AmbiguousContainmentArrayExtractIndex> {

// CHECK-NEXT:    verif.contract @C for @TContractConcreteSelf_i::@Box (%[[VAL_6:[0-9a-zA-Z_\.]+]]: !struct.type<@TContractConcreteSelf_i::@Box>) {
// CHECK-NEXT:      %[[VAL_7:[0-9a-zA-Z_\.]+]] = struct.readm %[[VAL_6]][@value] : <@TContractConcreteSelf_i::@Box>, index
// CHECK-NEXT:      %[[VAL_8:[0-9a-zA-Z_\.]+]] = arith.constant true

// CHECK-NEXT:    poly.template @TIdentity {
// CHECK-NEXT:      function.def @id(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<4 x index>) -> !array.type<4 x index> {
// CHECK-NEXT:        function.return %[[VAL_0]] : !array.type<4 x index>
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @call_id(%[[VAL_1:[0-9a-zA-Z_\.]+]]: !array.type<4 x index>) -> !array.type<4 x index> {
// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = function.call @TIdentity::@id(%[[VAL_1]]) : (!array.type<4 x index>) -> !array.type<4 x index>
// CHECK-NEXT:      function.return %[[VAL_2]] : !array.type<4 x index>
// CHECK-NEXT:    }
// CHECK-NEXT:  }

    function.def @id(%arg: !poly.tvar<@Element>) -> !poly.tvar<@Element> {
      function.return %arg : !poly.tvar<@Element>
    }
  }

  poly.template @TForwardCallSymbolParam {
    poly.param @T : !poly.tvar<@T>

    function.def @forward(%arg: !poly.tvar<@T>) -> index {
      %forwarded = function.call @TForwardedCallee::@id<[@T]>(%arg) : (!poly.tvar<@T>) -> !poly.tvar<@T>
      %index = poly.unifiable_cast %forwarded : (!poly.tvar<@T>) -> index
      function.return %index : index
    }
  }

  function.def @call_forward(%arg: index) -> index {
    %0 = function.call @TForwardCallSymbolParam::@forward<[index]>(%arg) : (index) -> index
    function.return %0 : index
  }
}

// CHECK-NEXT:      %[[VAL_9:[0-9a-zA-Z_\.]+]] = function.call @TSiblingEntryPoints_f_g(%[[VAL_8]]) : (!felt.type) -> !felt.type
// CHECK-NEXT:      function.return %[[VAL_9]] : !felt.type
// CHECK-NEXT:    }

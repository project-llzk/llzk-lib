module attributes {llzk.lang} {
  poly.template @TCollidingMemberName {
    poly.param @T

    struct.def @Box {
      struct.member @T : !poly.tvar<@T>

      function.def @compute(%arg: !poly.tvar<@T>) -> !struct.type<@TCollidingMemberName::@Box<[@T]>> {
        %self = struct.new : !struct.type<@TCollidingMemberName::@Box<[@T]>>
        struct.writem %self[@T] = %arg : !struct.type<@TCollidingMemberName::@Box<[@T]>>, !poly.tvar<@T>
        function.return %self : !struct.type<@TCollidingMemberName::@Box<[@T]>>
      }

      function.def @constrain(%self: !struct.type<@TCollidingMemberName::@Box<[@T]>>, %arg: !poly.tvar<@T>) {
        %value = struct.readm %self[@T] : !struct.type<@TCollidingMemberName::@Box<[@T]>>, !poly.tvar<@T>
        constrain.eq %value, %arg : !poly.tvar<@T>
        function.return
      }
    }
  }

  function.def @use_box(%arg: !struct.type<@TCollidingMemberName::@Box<[!felt.type]>>) -> !struct.type<@TCollidingMemberName::@Box<[!felt.type]>> {
    function.return %arg : !struct.type<@TCollidingMemberName::@Box<[!felt.type]>>
  }
}

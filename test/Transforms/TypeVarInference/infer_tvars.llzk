module attributes {llzk.lang} {
  poly.template @TSiblingEntryPoints {
    poly.param @T : !poly.tvar<@T>

    function.def @f(%arg: !poly.tvar<@T>) -> index {
      %index = poly.unifiable_cast %arg : (!poly.tvar<@T>) -> index
      function.return %index : index
    }

    function.def @g(%arg: !poly.tvar<@T>) -> !poly.tvar<@T> {
      function.return %arg : !poly.tvar<@T>
    }
  }

  function.def @call_f(%arg: index) -> index {
    %0 = function.call @TSiblingEntryPoints::@f<[index]>(%arg) : (index) -> index
    function.return %0 : index
  }

  function.def @call_g1(%arg: !felt.type) -> !felt.type {
    %0 = function.call @TSiblingEntryPoints::@g<[!felt.type]>(%arg) : (!felt.type) -> !felt.type
    function.return %0 : !felt.type
  }

  function.def @call_g2(%arg: i1) -> i1 {
    %0 = function.call @TSiblingEntryPoints::@g<[i1]>(%arg) : (i1) -> i1
    function.return %0 : i1
  }
}

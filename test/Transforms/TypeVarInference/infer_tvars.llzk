  poly.template @TFunctionCloneNonTypeParam {
    poly.param @T : !poly.tvar<@T>
    poly.param @N

    function.def @with_const(%arg: !poly.tvar<@T>) -> !poly.tvar<@T> {
      %n = poly.read_const @N : index
      function.return %arg : !poly.tvar<@T>
    }
  }

  function.def @call_with_const(%arg: !felt.type) -> !felt.type {
    %0 = function.call @TFunctionCloneNonTypeParam::@with_const<[!felt.type, 7]>(%arg) : (!felt.type) -> !felt.type
    function.return %0 : !felt.type
  }
}

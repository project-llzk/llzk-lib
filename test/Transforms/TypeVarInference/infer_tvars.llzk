// CHECK-NEXT:    poly.template @TArrayElementAccess {
// CHECK-NEXT:      function.def @access(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<3 x index>, %[[VAL_1:[0-9a-zA-Z_\.]+]]: !array.type<2,3 x index>) -> !array.type<3 x index> {
// CHECK-NEXT:        %[[VAL_2:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:        %[[VAL_3:[0-9a-zA-Z_\.]+]] = array.extract %[[VAL_1]]{{\[}}%[[VAL_2]]] : <2,3 x index>
// CHECK-NEXT:        array.insert %[[VAL_1]]{{\[}}%[[VAL_2]]] = %[[VAL_0]] : <2,3 x index>, <3 x index>
// CHECK-NEXT:        function.return %[[VAL_3]] : !array.type<3 x index>
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

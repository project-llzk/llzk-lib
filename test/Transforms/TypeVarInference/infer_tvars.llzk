// CHECK-NEXT:    function.def @TSiblingEntryPoints_i_f(%[[VAL_0:[0-9a-zA-Z_\.]+]]: index) -> index {
// CHECK-NEXT:      function.return %[[VAL_0]] : index
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @TSiblingEntryPoints_f_g(%[[VAL_1:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type {
// CHECK-NEXT:      function.return %[[VAL_1]] : !felt.type

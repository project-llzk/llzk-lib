// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = global.read @g : !felt.type
// CHECK-NEXT:      function.call @mutate_global(%[[VAL_1]]) : (!felt.type) -> ()
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = global.read @g : !felt.type

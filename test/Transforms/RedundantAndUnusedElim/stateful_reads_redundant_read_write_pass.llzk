module attributes {llzk.lang} {
  function.def @ram_load_reuse(%addr: index) -> !felt.type
      attributes {function.allow_witness} {
    %first = ram.load %addr : !felt.type
    %second = ram.load %addr : !felt.type
    %sum = felt.add %first, %second : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @ram_load_reuse(%[[VAL_0:[0-9a-zA-Z_\.]+]]: index) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_1:[0-9a-zA-Z_\.]+]] = ram.load %[[VAL_0]] : !felt.type
// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_1]], %[[VAL_1]] : !felt.type, !felt.type
// CHECK-NEXT:      function.return %[[VAL_2]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// CHECK:  // -----

// -----

module attributes {llzk.lang} {
  function.def @ram_store_updates_known_value(%addr: index, %new: !felt.type) -> !felt.type
      attributes {function.allow_witness} {
    ram.store %addr, %new : !felt.type
    %loaded = ram.load %addr : !felt.type
    function.return %loaded : !felt.type
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @ram_store_updates_known_value(%[[VAL_0:[0-9a-zA-Z_\.]+]]: index, %[[VAL_1:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:      ram.store %[[VAL_0]], %[[VAL_1]] : !felt.type
// CHECK-NEXT:      function.return %[[VAL_1]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// CHECK:  // -----

// -----

module attributes {llzk.lang} {
  function.def @ram_conditional_store_keeps_load(%addr: index, %new: !felt.type, %cond: i1)
      -> !felt.type attributes {function.allow_witness} {
    %before = ram.load %addr : !felt.type
    scf.if %cond {
      ram.store %addr, %new : !felt.type
    }
    %after = ram.load %addr : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @ram_conditional_store_keeps_load(%[[VAL_0:[0-9a-zA-Z_\.]+]]: index, %[[VAL_1:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_2:[0-9a-zA-Z_\.]+]]: i1) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = ram.load %[[VAL_0]] : !felt.type
// CHECK-NEXT:      scf.if %[[VAL_2]] {
// CHECK-NEXT:        ram.store %[[VAL_0]], %[[VAL_1]] : !felt.type
// CHECK-NEXT:      }
// CHECK-NEXT:      %[[VAL_4:[0-9a-zA-Z_\.]+]] = ram.load %[[VAL_0]] : !felt.type
// CHECK-NEXT:      %[[VAL_5:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_3]], %[[VAL_4]] : !felt.type, !felt.type
// CHECK-NEXT:      function.return %[[VAL_5]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:  }

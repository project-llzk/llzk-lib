// RUN: llzk-opt -split-input-file -llzk-duplicate-read-write-elim %s 2>&1 | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @global_read_reuse() -> !felt.type attributes {function.allow_witness} {
    %first = global.read @g : !felt.type
    %second = global.read @g : !felt.type
    %sum = felt.add %first, %second : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    global.def @g : !felt.type =  1
// CHECK-NEXT:    function.def @global_read_reuse() -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_0:[0-9a-zA-Z_\.]+]] = global.read @g : !felt.type
// CHECK-NEXT:      %[[VAL_1:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_0]], %[[VAL_0]] : !felt.type, !felt.type
// CHECK-NEXT:      function.return %[[VAL_1]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// CHECK:  // -----

// -----

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @global_write_updates_known_value(%new: !felt.type) -> !felt.type
      attributes {function.allow_witness} {
    %before = global.read @g : !felt.type
    global.write @g = %new : !felt.type
    %after = global.read @g : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    global.def @g : !felt.type =  1
// CHECK-NEXT:    function.def @global_write_updates_known_value(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_1:[0-9a-zA-Z_\.]+]] = global.read @g : !felt.type
// CHECK-NEXT:      global.write @g = %[[VAL_0]] : !felt.type
// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_1]], %[[VAL_0]] : !felt.type, !felt.type
// CHECK-NEXT:      function.return %[[VAL_2]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// CHECK:  // -----

// -----

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @global_conditional_write_keeps_read(%new: !felt.type, %cond: i1) -> !felt.type
      attributes {function.allow_witness} {
    %before = global.read @g : !felt.type
    scf.if %cond {
      global.write @g = %new : !felt.type
    }
    %after = global.read @g : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    global.def @g : !felt.type =  1
// CHECK-NEXT:    function.def @global_conditional_write_keeps_read(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_1:[0-9a-zA-Z_\.]+]]: i1) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = global.read @g : !felt.type
// CHECK-NEXT:      scf.if %[[VAL_1]] {
// CHECK-NEXT:        global.write @g = %[[VAL_0]] : !felt.type
// CHECK-NEXT:      }
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = global.read @g : !felt.type
// CHECK-NEXT:      %[[VAL_4:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_2]], %[[VAL_3]] : !felt.type, !felt.type
// CHECK-NEXT:      function.return %[[VAL_4]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// CHECK:  // -----

// -----

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1
  global.def @h : !felt.type = 2

  function.def @different_global_write_reuses_read(%new: !felt.type) -> !felt.type
      attributes {function.allow_witness} {
    %first = global.read @g : !felt.type
    global.write @h = %new : !felt.type
    %second = global.read @g : !felt.type
    %sum = felt.add %first, %second : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    global.def @g : !felt.type =  1
// CHECK-NEXT:    global.def @h : !felt.type =  2
// CHECK-NEXT:    function.def @different_global_write_reuses_read(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_1:[0-9a-zA-Z_\.]+]] = global.read @g : !felt.type
// CHECK-NEXT:      global.write @h = %[[VAL_0]] : !felt.type
// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_1]], %[[VAL_1]] : !felt.type, !felt.type
// CHECK-NEXT:      function.return %[[VAL_2]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// CHECK:  // -----

// -----

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @mutate_global(%new: !felt.type)
      attributes {function.allow_witness} {
    global.write @g = %new : !felt.type
    function.return
  }

  function.def @global_call_barrier(%new: !felt.type) -> !felt.type
      attributes {function.allow_witness} {
    %before = global.read @g : !felt.type
    function.call @mutate_global(%new) : (!felt.type) -> ()
    %after = global.read @g : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}


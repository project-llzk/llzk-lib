// -----

module attributes {llzk.lang} {
  function.def @ram_store_unknown_alias(%load_addr: index, %store_addr: index, %new: !felt.type)
      -> !felt.type attributes {function.allow_witness} {
    %before = ram.load %load_addr : !felt.type
    ram.store %store_addr, %new : !felt.type
    %after = ram.load %load_addr : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @ram_store_unknown_alias(%[[VAL_0:[0-9a-zA-Z_\.]+]]: index, %[[VAL_1:[0-9a-zA-Z_\.]+]]: index, %[[VAL_2:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = ram.load %[[VAL_0]] : !felt.type
// CHECK-NEXT:      ram.store %[[VAL_1]], %[[VAL_2]] : !felt.type
// CHECK-NEXT:      %[[VAL_4:[0-9a-zA-Z_\.]+]] = ram.load %[[VAL_0]] : !felt.type
// CHECK-NEXT:      %[[VAL_5:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_3]], %[[VAL_4]] : !felt.type, !felt.type
// CHECK-NEXT:      function.return %[[VAL_5]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// CHECK:  // -----

// -----

module attributes {llzk.lang} {
  function.def @mutate_ram(%addr: index, %new: !felt.type)
      attributes {function.allow_witness} {
    ram.store %addr, %new : !felt.type
    function.return
  }

  function.def @ram_call_barrier(%addr: index, %new: !felt.type) -> !felt.type
      attributes {function.allow_witness} {
    %before = ram.load %addr : !felt.type
    function.call @mutate_ram(%addr, %new) : (index, !felt.type) -> ()
    %after = ram.load %addr : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}


module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @ram_load_conditional_global_write_reuses_load(
      %addr: index, %new: !felt.type, %cond: i1
  ) -> !felt.type attributes {function.allow_witness} {
    %first = ram.load %addr : !felt.type
    scf.if %cond {
      global.write @g = %new : !felt.type
    }
    %second = ram.load %addr : !felt.type
    %sum = felt.add %first, %second : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    global.def @g : !felt.type =  1
// CHECK-NEXT:    function.def @ram_load_conditional_global_write_reuses_load(%[[VAL_0:[0-9a-zA-Z_\.]+]]: index, %[[VAL_1:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_2:[0-9a-zA-Z_\.]+]]: i1) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = ram.load %[[VAL_0]] : !felt.type
// CHECK-NEXT:      scf.if %[[VAL_2]] {
// CHECK-NEXT:        global.write @g = %[[VAL_1]] : !felt.type
// CHECK-NEXT:      }
// CHECK-NEXT:      %[[VAL_4:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_3]], %[[VAL_3]] : !felt.type, !felt.type
// CHECK-NEXT:      function.return %[[VAL_4]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:  }

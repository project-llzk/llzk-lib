// RUN: llzk-opt -split-input-file -llzk-duplicate-read-write-elim %s 2>&1 | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @global_read_reuse() -> !felt.type attributes {function.allow_witness} {
    %first = global.read @g : !felt.type
    %second = global.read @g : !felt.type
    %sum = felt.add %first, %second : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: global.def @g : !felt.type = 1
// CHECK-NEXT:  function.def @global_read_reuse() -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:    %[[READ:.*]] = global.read @g : !felt.type
// CHECK-NEXT:    %[[SUM:.*]] = felt.add %[[READ]], %[[READ]] : !felt.type, !felt.type
// CHECK-NEXT:    function.return %[[SUM]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}

// -----

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @global_write_updates_known_value(%new: !felt.type) -> !felt.type
      attributes {function.allow_witness} {
    %before = global.read @g : !felt.type
    global.write @g = %new : !felt.type
    %after = global.read @g : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: global.def @g : !felt.type = 1
// CHECK-NEXT:  function.def @global_write_updates_known_value(%[[NEW:.*]]: !felt.type) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:    %[[BEFORE:.*]] = global.read @g : !felt.type
// CHECK-NEXT:    global.write @g = %[[NEW]] : !felt.type
// CHECK-NEXT:    %[[SUM:.*]] = felt.add %[[BEFORE]], %[[NEW]] : !felt.type, !felt.type
// CHECK-NEXT:    function.return %[[SUM]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}

// -----

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @global_conditional_write_keeps_read(%new: !felt.type, %cond: i1) -> !felt.type
      attributes {function.allow_witness} {
    %before = global.read @g : !felt.type
    scf.if %cond {
      global.write @g = %new : !felt.type
    }
    %after = global.read @g : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: global.def @g : !felt.type = 1
// CHECK-NEXT:  function.def @global_conditional_write_keeps_read(%[[NEW:.*]]: !felt.type, %[[COND:.*]]: i1) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:    %[[BEFORE:.*]] = global.read @g : !felt.type
// CHECK-NEXT:    scf.if %[[COND]] {
// CHECK-NEXT:      global.write @g = %[[NEW]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:    %[[AFTER:.*]] = global.read @g : !felt.type
// CHECK-NEXT:    %[[SUM:.*]] = felt.add %[[BEFORE]], %[[AFTER]] : !felt.type, !felt.type
// CHECK-NEXT:    function.return %[[SUM]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}

// -----

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1
  global.def @h : !felt.type = 2

  function.def @different_global_write_reuses_read(%new: !felt.type) -> !felt.type
      attributes {function.allow_witness} {
    %first = global.read @g : !felt.type
    global.write @h = %new : !felt.type
    %second = global.read @g : !felt.type
    %sum = felt.add %first, %second : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: global.def @g : !felt.type = 1
// CHECK-NEXT:  global.def @h : !felt.type = 2
// CHECK-NEXT:  function.def @different_global_write_reuses_read(%[[NEW:.*]]: !felt.type) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:    %[[READ:.*]] = global.read @g : !felt.type
// CHECK-NEXT:    global.write @h = %[[NEW]] : !felt.type
// CHECK-NEXT:    %[[SUM:.*]] = felt.add %[[READ]], %[[READ]] : !felt.type, !felt.type
// CHECK-NEXT:    function.return %[[SUM]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}

// -----

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @mutate_global(%new: !felt.type)
      attributes {function.allow_witness} {
    global.write @g = %new : !felt.type
    function.return
  }

  function.def @global_call_barrier(%new: !felt.type) -> !felt.type
      attributes {function.allow_witness} {
    %before = global.read @g : !felt.type
    function.call @mutate_global(%new) : (!felt.type) -> ()
    %after = global.read @g : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: global.def @g : !felt.type = 1
// CHECK-NEXT:  function.def @mutate_global(%[[NEW:.*]]: !felt.type) attributes {function.allow_witness} {
// CHECK-NEXT:    global.write @g = %[[NEW]] : !felt.type
// CHECK-NEXT:    function.return
// CHECK-NEXT:  }
// CHECK-NEXT:  function.def @global_call_barrier(%[[ARG:.*]]: !felt.type) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:    %[[BEFORE:.*]] = global.read @g : !felt.type
// CHECK-NEXT:    function.call @mutate_global(%[[ARG]]) : (!felt.type) -> ()
// CHECK-NEXT:    %[[AFTER:.*]] = global.read @g : !felt.type
// CHECK-NEXT:    %[[SUM:.*]] = felt.add %[[BEFORE]], %[[AFTER]] : !felt.type, !felt.type
// CHECK-NEXT:    function.return %[[SUM]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}

// -----

module attributes {llzk.lang} {
  function.def @ram_load_reuse(%addr: index) -> !felt.type
      attributes {function.allow_witness} {
    %first = ram.load %addr : !felt.type
    %second = ram.load %addr : !felt.type
    %sum = felt.add %first, %second : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: function.def @ram_load_reuse
// CHECK-SAME: (%[[ADDR:.*]]: index) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:    %[[LOAD:.*]] = ram.load %[[ADDR]] : !felt.type
// CHECK-NEXT:    %[[SUM:.*]] = felt.add %[[LOAD]], %[[LOAD]] : !felt.type, !felt.type
// CHECK-NEXT:    function.return %[[SUM]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}

// -----

module attributes {llzk.lang} {
  function.def @ram_store_updates_known_value(%addr: index, %new: !felt.type) -> !felt.type
      attributes {function.allow_witness} {
    ram.store %addr, %new : !felt.type
    %loaded = ram.load %addr : !felt.type
    function.return %loaded : !felt.type
  }
}

// CHECK-LABEL: function.def @ram_store_updates_known_value
// CHECK-SAME: (%[[ADDR:.*]]: index, %[[NEW:.*]]: !felt.type) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:    ram.store %[[ADDR]], %[[NEW]] : !felt.type
// CHECK-NEXT:    function.return %[[NEW]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}

// -----

module attributes {llzk.lang} {
  function.def @ram_conditional_store_keeps_load(%addr: index, %new: !felt.type, %cond: i1)
      -> !felt.type attributes {function.allow_witness} {
    %before = ram.load %addr : !felt.type
    scf.if %cond {
      ram.store %addr, %new : !felt.type
    }
    %after = ram.load %addr : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: function.def @ram_conditional_store_keeps_load
// CHECK-SAME: (%[[ADDR:.*]]: index, %[[NEW:.*]]: !felt.type, %[[COND:.*]]: i1) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:    %[[BEFORE:.*]] = ram.load %[[ADDR]] : !felt.type
// CHECK-NEXT:    scf.if %[[COND]] {
// CHECK-NEXT:      ram.store %[[ADDR]], %[[NEW]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:    %[[AFTER:.*]] = ram.load %[[ADDR]] : !felt.type
// CHECK-NEXT:    %[[SUM:.*]] = felt.add %[[BEFORE]], %[[AFTER]] : !felt.type, !felt.type
// CHECK-NEXT:    function.return %[[SUM]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}

// -----

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @ram_load_conditional_global_write_reuses_load(
      %addr: index, %new: !felt.type, %cond: i1
  ) -> !felt.type attributes {function.allow_witness} {
    %first = ram.load %addr : !felt.type
    scf.if %cond {
      global.write @g = %new : !felt.type
    }
    %second = ram.load %addr : !felt.type
    %sum = felt.add %first, %second : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: global.def @g : !felt.type = 1
// CHECK-NEXT:  function.def @ram_load_conditional_global_write_reuses_load(%[[ADDR:.*]]: index, %[[NEW:.*]]: !felt.type, %[[COND:.*]]: i1) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:    %[[LOAD:.*]] = ram.load %[[ADDR]] : !felt.type
// CHECK-NEXT:    scf.if %[[COND]] {
// CHECK-NEXT:      global.write @g = %[[NEW]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:    %[[SUM:.*]] = felt.add %[[LOAD]], %[[LOAD]] : !felt.type, !felt.type
// CHECK-NEXT:    function.return %[[SUM]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}

// -----

module attributes {llzk.lang} {
  function.def @ram_store_unknown_alias(%load_addr: index, %store_addr: index, %new: !felt.type)
      -> !felt.type attributes {function.allow_witness} {
    %before = ram.load %load_addr : !felt.type
    ram.store %store_addr, %new : !felt.type
    %after = ram.load %load_addr : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: function.def @ram_store_unknown_alias
// CHECK-SAME: (%[[LOAD_ADDR:.*]]: index, %[[STORE_ADDR:.*]]: index, %[[NEW:.*]]: !felt.type) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:    %[[BEFORE:.*]] = ram.load %[[LOAD_ADDR]] : !felt.type
// CHECK-NEXT:    ram.store %[[STORE_ADDR]], %[[NEW]] : !felt.type
// CHECK-NEXT:    %[[AFTER:.*]] = ram.load %[[LOAD_ADDR]] : !felt.type
// CHECK-NEXT:    %[[SUM:.*]] = felt.add %[[BEFORE]], %[[AFTER]] : !felt.type, !felt.type
// CHECK-NEXT:    function.return %[[SUM]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}

// -----

module attributes {llzk.lang} {
  function.def @mutate_ram(%addr: index, %new: !felt.type)
      attributes {function.allow_witness} {
    ram.store %addr, %new : !felt.type
    function.return
  }

  function.def @ram_call_barrier(%addr: index, %new: !felt.type) -> !felt.type
      attributes {function.allow_witness} {
    %before = ram.load %addr : !felt.type
    function.call @mutate_ram(%addr, %new) : (index, !felt.type) -> ()
    %after = ram.load %addr : !felt.type
    %sum = felt.add %before, %after : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}

// CHECK-LABEL: function.def @mutate_ram
// CHECK-SAME: (%[[M_ADDR:.*]]: index, %[[M_NEW:.*]]: !felt.type) attributes {function.allow_witness} {
// CHECK-NEXT:    ram.store %[[M_ADDR]], %[[M_NEW]] : !felt.type
// CHECK-NEXT:    function.return
// CHECK-NEXT:  }
// CHECK-NEXT:  function.def @ram_call_barrier(%[[ADDR:.*]]: index, %[[NEW:.*]]: !felt.type) -> !felt.type attributes {function.allow_witness} {
// CHECK-NEXT:    %[[BEFORE:.*]] = ram.load %[[ADDR]] : !felt.type
// CHECK-NEXT:    function.call @mutate_ram(%[[ADDR]], %[[NEW]]) : (index, !felt.type) -> ()
// CHECK-NEXT:    %[[AFTER:.*]] = ram.load %[[ADDR]] : !felt.type
// CHECK-NEXT:    %[[SUM:.*]] = felt.add %[[BEFORE]], %[[AFTER]] : !felt.type, !felt.type
// CHECK-NEXT:    function.return %[[SUM]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1
  global.def @h : !felt.type = 2

  struct.def @DifferentGlobalWrite {
    struct.member @out : !felt.type

    function.def @compute() -> !struct.type<@DifferentGlobalWrite> {
      %self = struct.new : !struct.type<@DifferentGlobalWrite>
      %new = felt.const 3
      %before = global.read @g : !felt.type
      global.write @h = %new : !felt.type
      %after = global.read @g : !felt.type
      %sum = felt.add %before, %after : !felt.type, !felt.type
      struct.writem %self[@out] = %sum : !struct.type<@DifferentGlobalWrite>, !felt.type
      function.return %self : !struct.type<@DifferentGlobalWrite>
    }

    function.def @constrain(%self: !struct.type<@DifferentGlobalWrite>) {
      function.return
    }
  }
}


module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @global_read_ignores_ram_store(%addr: index, %new: !felt.type)
      -> !felt.type attributes {function.allow_witness} {
    %first = global.read @g : !felt.type
    ram.store %addr, %new : !felt.type
    %second = global.read @g : !felt.type
    %sum = felt.add %first, %second : !felt.type, !felt.type
    function.return %sum : !felt.type
  }
}


// CHECK-NEXT:  global.def @g : !felt.type = 1
// CHECK-NEXT:  function.def @global_read_block_local(%[[COND:.*]]: i1) -> !felt.type {
// CHECK-NEXT:    %[[FIRST:.*]] = global.read @g : !felt.type
// CHECK-NEXT:    %[[SELECTED:.*]] = scf.if %[[COND]] -> (!felt.type) {
// CHECK-NEXT:      %[[SECOND:.*]] = global.read @g : !felt.type
// CHECK-NEXT:      %[[SUM:.*]] = felt.add %[[FIRST]], %[[SECOND]] : !felt.type, !felt.type
// CHECK-NEXT:      scf.yield %[[SUM]] : !felt.type
// CHECK-NEXT:    } else {
// CHECK-NEXT:      scf.yield %[[FIRST]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:    function.return %[[SELECTED]] : !felt.type
// CHECK-NEXT:  }
// CHECK-NEXT:}


module attributes {llzk.lang} {
  struct.def @MemberReadReuse {
    struct.member @cell : !felt.type
    struct.member @out : !felt.type

    function.def @compute() -> !struct.type<@MemberReadReuse> {
      %self = struct.new : !struct.type<@MemberReadReuse>
      %first = struct.readm %self[@cell] : !struct.type<@MemberReadReuse>, !felt.type
      %second = struct.readm %self[@cell] : !struct.type<@MemberReadReuse>, !felt.type
      %sum = felt.add %first, %second : !felt.type, !felt.type
      struct.writem %self[@out] = %sum : !struct.type<@MemberReadReuse>, !felt.type
      function.return %self : !struct.type<@MemberReadReuse>
    }

    function.def @constrain(%self: !struct.type<@MemberReadReuse>) {
      function.return
    }
  }
}


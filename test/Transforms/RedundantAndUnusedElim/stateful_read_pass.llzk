// RUN: llzk-opt -split-input-file -llzk-duplicate-op-elim %s 2>&1 | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  struct.def @GlobalWriteBarrier {
    struct.member @out : !felt.type

    function.def @compute() -> !struct.type<@GlobalWriteBarrier> {
      %self = struct.new : !struct.type<@GlobalWriteBarrier>
      %new = felt.const 2
      %before = global.read @g : !felt.type
      global.write @g = %new : !felt.type
      %after = global.read @g : !felt.type
      %sum = felt.add %before, %after : !felt.type, !felt.type
      struct.writem %self[@out] = %sum : !struct.type<@GlobalWriteBarrier>, !felt.type
      function.return %self : !struct.type<@GlobalWriteBarrier>
    }

    function.def @constrain(%self: !struct.type<@GlobalWriteBarrier>) {
      function.return
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:  global.def @g : !felt.type = 1
// CHECK-NEXT:  struct.def @GlobalWriteBarrier {
// CHECK-NEXT:    struct.member @out : !felt.type
// CHECK-NEXT:    function.def @compute() -> !struct.type<@GlobalWriteBarrier> attributes {function.allow_witness} {
// CHECK-NEXT:      %[[SELF:.*]] = struct.new : <@GlobalWriteBarrier>
// CHECK-NEXT:      %[[NEW:.*]] = felt.const {{ *}}2
// CHECK-NEXT:      %[[BEFORE:.*]] = global.read @g : !felt.type
// CHECK-NEXT:      global.write @g = %[[NEW]] : !felt.type
// CHECK-NEXT:      %[[AFTER:.*]] = global.read @g : !felt.type
// CHECK-NEXT:      %[[SUM:.*]] = felt.add %[[BEFORE]], %[[AFTER]] : !felt.type, !felt.type
// CHECK-NEXT:      struct.writem %[[SELF]][@out] = %[[SUM]] : <@GlobalWriteBarrier>, !felt.type
// CHECK-NEXT:      function.return %[[SELF]] : !struct.type<@GlobalWriteBarrier>
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @constrain(%[[SELF_ARG:.*]]: !struct.type<@GlobalWriteBarrier>) attributes {function.allow_constraint} {
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// CHECK-NEXT:}


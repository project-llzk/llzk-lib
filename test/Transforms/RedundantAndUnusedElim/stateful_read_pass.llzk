module attributes {llzk.lang} {
  function.def @pure_op_reuse(%lhs: !felt.type, %rhs: !felt.type) -> !felt.type {
    %first = felt.add %lhs, %rhs : !felt.type, !felt.type
    %second = felt.add %rhs, %lhs : !felt.type, !felt.type
    %product = felt.mul %first, %second : !felt.type, !felt.type
    function.return %product : !felt.type
  }
}


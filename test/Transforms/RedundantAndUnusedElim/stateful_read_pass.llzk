      attributes {function.allow_witness} {
    %first = ram.load %addr : !felt.type
    %selected = scf.if %cond -> (!felt.type) {
      %second = ram.load %addr : !felt.type
      %sum = felt.add %first, %second : !felt.type, !felt.type
      scf.yield %sum : !felt.type
    } else {
      scf.yield %first : !felt.type
    }
    function.return %selected : !felt.type
  }
}


module attributes {llzk.lang} {
  global.def @g : !felt.type = 1

  function.def @global_read_block_local(%cond: i1) -> !felt.type {
    %first = global.read @g : !felt.type
    %selected = scf.if %cond -> (!felt.type) {
      %second = global.read @g : !felt.type
      %sum = felt.add %first, %second : !felt.type, !felt.type
      scf.yield %sum : !felt.type
    } else {
      scf.yield %first : !felt.type
    }
    function.return %selected : !felt.type
  }
}


// COM: This regression test exercises the deferred array.read resolver when the nearest
// COM: forwardable write stores a bare pod.read-backed array-of-pod value.
!Item = !pod.type<[@x: index]>
!Outer = !pod.type<[@items: !array.type<? x !Item>]>
module attributes {llzk.lang} {
  function.def @forwarded_write_readback(%src: !Outer, %i: index) -> index {
    %items = pod.read %src[@items] : !Outer, !array.type<? x !Item>
    %dst = pod.new : !Outer
    pod.write %dst[@items] = %items : !Outer, !array.type<? x !Item>

    %arr = pod.read %dst[@items] : !Outer, !array.type<? x !Item>
    %item = array.read %arr[%i] : !array.type<? x !Item>, !Item
    %x = pod.read %item[@x] : !Item, index
    function.return %x : index
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @forwarded_write_readback(
// CHECK-SAME:    %[[ARR:[0-9a-zA-Z_\.]+]]: !array.type<? x index>,
// CHECK-SAME:    %[[I:[0-9a-zA-Z_\.]+]]: index
// CHECK-SAME:    ) -> index {
// CHECK-NEXT:      %[[X:[0-9a-zA-Z_\.]+]] = array.read %[[ARR]]{{\[}}%[[I]]] : <? x index>, index
// CHECK-NEXT:      function.return %[[X]] : index
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// -----

#outer = affine_map<()[s0] -> (s0)>
!Item = !pod.type<[@x: index]>
!Outer = !pod.type<[@items: !array.type<#outer x !Item>]>
module attributes {llzk.lang} {
  function.def @nested_if_parent_write(%src: !Outer, %n: index, %i: index, %flag: index) -> index {
    %items = pod.read %src[@items] : !Outer, !array.type<#outer x !Item>
    %p = pod.new()[%n] : !Outer
    pod.write %p[@items] = %items : !Outer, !array.type<#outer x !Item>
    %c0 = arith.constant 0 : index
    %cond = arith.cmpi ne, %flag, %c0 : index
    %ret = scf.if %cond -> (index) {
      %arr = pod.read %p[@items] : !Outer, !array.type<#outer x !Item>
      %item = array.read %arr[%i] : !array.type<#outer x !Item>, !Item
      %x = pod.read %item[@x] : !Item, index
      scf.yield %x : index
    } else {
      scf.yield %c0 : index
    }
    function.return %ret : index
  }

  function.def @nested_if_parent_init(%src: !Outer, %n: index, %i: index, %flag: index) -> index {
    %items = pod.read %src[@items] : !Outer, !array.type<#outer x !Item>
    %p = pod.new { @items = %items }()[%n] : !Outer
    %c0 = arith.constant 0 : index
    %cond = arith.cmpi ne, %flag, %c0 : index
    %ret = scf.if %cond -> (index) {
      %arr = pod.read %p[@items] : !Outer, !array.type<#outer x !Item>
      %item = array.read %arr[%i] : !array.type<#outer x !Item>, !Item
      %x = pod.read %item[@x] : !Item, index
      scf.yield %x : index
    } else {
      scf.yield %c0 : index
    }
    function.return %ret : index
  }
}

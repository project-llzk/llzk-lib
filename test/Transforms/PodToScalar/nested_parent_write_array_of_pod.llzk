// RUN: llzk-opt -llzk-pod-to-scalar %s | FileCheck --enable-var-scope %s

#outer = affine_map<()[s0] -> (s0)>
!Item = !pod.type<[@x: index]>
!Outer = !pod.type<[@items: !array.type<#outer x !Item>]>
module attributes {llzk.lang} {
  function.def @nested_if_parent_write(%src: !Outer, %n: index, %i: index, %flag: index) -> index {
    %items = pod.read %src[@items] : !Outer, !array.type<#outer x !Item>
    %p = pod.new()[%n] : !Outer
    pod.write %p[@items] = %items : !Outer, !array.type<#outer x !Item>
    %c0 = arith.constant 0 : index
    %cond = arith.cmpi ne, %flag, %c0 : index
    %ret = scf.if %cond -> (index) {
      %arr = pod.read %p[@items] : !Outer, !array.type<#outer x !Item>
      %item = array.read %arr[%i] : !array.type<#outer x !Item>, !Item
      %x = pod.read %item[@x] : !Item, index
      scf.yield %x : index
    } else {
      scf.yield %c0 : index
    }
    function.return %ret : index
  }

  function.def @nested_if_parent_init(%src: !Outer, %n: index, %i: index, %flag: index) -> index {
    %items = pod.read %src[@items] : !Outer, !array.type<#outer x !Item>
    %p = pod.new { @items = %items }()[%n] : !Outer
    %c0 = arith.constant 0 : index
    %cond = arith.cmpi ne, %flag, %c0 : index
    %ret = scf.if %cond -> (index) {
      %arr = pod.read %p[@items] : !Outer, !array.type<#outer x !Item>
      %item = array.read %arr[%i] : !array.type<#outer x !Item>, !Item
      %x = pod.read %item[@x] : !Item, index
      scf.yield %x : index
    } else {
      scf.yield %c0 : index
    }
    function.return %ret : index
  }
}
// CHECK: #[[$M:[0-9a-zA-Z_\.]+]] = affine_map<()[s0] -> (s0)>
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @nested_if_parent_write(
// CHECK-SAME:    %[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<#[[$M]] x index>,
// CHECK-SAME:    %[[VAL_1:[0-9a-zA-Z_\.]+]]: index,
// CHECK-SAME:    %[[VAL_2:[0-9a-zA-Z_\.]+]]: index,
// CHECK-SAME:    %[[VAL_3:[0-9a-zA-Z_\.]+]]: index
// CHECK-SAME:    ) -> index {
// CHECK-NEXT:      %[[VAL_4:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[VAL_5:[0-9a-zA-Z_\.]+]] = arith.cmpi ne, %[[VAL_3]], %[[VAL_4]] : index
// CHECK-NEXT:      %[[VAL_6:[0-9a-zA-Z_\.]+]] = scf.if %[[VAL_5]] -> (index) {
// CHECK-NEXT:        %[[VAL_7:[0-9a-zA-Z_\.]+]] = array.read %[[VAL_0]]{{\[}}%[[VAL_2]]] : <#[[$M]] x index>, index
// CHECK-NEXT:        scf.yield %[[VAL_7]] : index
// CHECK-NEXT:      } else {
// CHECK-NEXT:        scf.yield %[[VAL_4]] : index
// CHECK-NEXT:      }
// CHECK-NEXT:      function.return %[[VAL_6]] : index
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @nested_if_parent_init(
// CHECK-SAME:    %[[VAL_8:[0-9a-zA-Z_\.]+]]: !array.type<#[[$M]] x index>,
// CHECK-SAME:    %[[VAL_9:[0-9a-zA-Z_\.]+]]: index,
// CHECK-SAME:    %[[VAL_10:[0-9a-zA-Z_\.]+]]: index,
// CHECK-SAME:    %[[VAL_11:[0-9a-zA-Z_\.]+]]: index
// CHECK-SAME:    ) -> index {
// CHECK-NEXT:      %[[VAL_12:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[VAL_13:[0-9a-zA-Z_\.]+]] = arith.cmpi ne, %[[VAL_11]], %[[VAL_12]] : index
// CHECK-NEXT:      %[[VAL_14:[0-9a-zA-Z_\.]+]] = scf.if %[[VAL_13]] -> (index) {
// CHECK-NEXT:        %[[VAL_15:[0-9a-zA-Z_\.]+]] = array.read %[[VAL_8]]{{\[}}%[[VAL_10]]] : <#[[$M]] x index>, index
// CHECK-NEXT:        scf.yield %[[VAL_15]] : index
// CHECK-NEXT:      } else {
// CHECK-NEXT:        scf.yield %[[VAL_12]] : index
// CHECK-NEXT:      }
// CHECK-NEXT:      function.return %[[VAL_14]] : index
// CHECK-NEXT:    }
// CHECK-NEXT:  }

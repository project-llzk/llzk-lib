// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[SELFARG:[0-9a-zA-Z_\.]+]]: !struct.type<@S>, %[[N2:[0-9a-zA-Z_\.]+]]: index) attributes {function.allow_constraint} {

!counter_pod = !pod.type<[@acc: !felt.type]>
module attributes {llzk.lang} {
  function.def @stateful_pod_accumulator(%init: !felt.type, %step: !felt.type) -> !felt.type {
    %state = pod.new { @acc = %init } : !counter_pod

    %lb = arith.constant 0 : index
    %ub = arith.constant 8 : index
    %one = arith.constant 1 : index

    scf.for %i = %lb to %ub step %one {
      %old_acc = pod.read %state[@acc] : !counter_pod, !felt.type
      %new_acc = felt.add %old_acc, %step : !felt.type
      pod.write %state[@acc] = %new_acc : !counter_pod, !felt.type
    }

    %result = pod.read %state[@acc] : !counter_pod, !felt.type
    function.return %result : !felt.type
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @stateful_pod_accumulator(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_1:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type {
// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = arith.constant 1 : index
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = arith.constant 8 : index
// CHECK-NEXT:      %[[VAL_4:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[VAL_5:[0-9a-zA-Z_\.]+]] = scf.for %[[VAL_6:[0-9a-zA-Z_\.]+]] = %[[VAL_4]] to %[[VAL_3]] step %[[VAL_2]] iter_args(%[[VAL_7:[0-9a-zA-Z_\.]+]] = %[[VAL_0]]) -> (!felt.type) {
// CHECK-NEXT:        %[[VAL_8:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_7]], %[[VAL_1]] : !felt.type, !felt.type
// CHECK-NEXT:        scf.yield %[[VAL_8]] : !felt.type
// CHECK-NEXT:      }
// CHECK-NEXT:      function.return %[[VAL_5]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// -----

!loop_state = !pod.type<[
  @i: !felt.type, // current loop index, as felt
  @sum: !felt.type, // running sum
  @values: !array.type<8 x !felt.type> // array updated on each iteration
]>
module attributes {llzk.lang} {
  function.def @stateful_pod_array_while(
    %lo: !felt.type,
    %hi: !felt.type,
    %step: !felt.type
  ) -> !felt.type attributes {function.allow_non_native_field_ops} {
    %state = pod.new : !loop_state
    %zero_felt = felt.const 0
    %zero_index = arith.constant 0 : index
    %initial_values = array.new : !array.type<8 x !felt.type>

    // Initialize POD records before any reads.
    pod.write %state[@i] = %lo : !loop_state, !felt.type
    pod.write %state[@sum] = %zero_felt : !loop_state, !felt.type
    pod.write %state[@values] = %initial_values : !loop_state, !array.type<8 x !felt.type>

    %final_i = scf.while (%loop_i = %lo) : (!felt.type) -> !felt.type {
      // Read the current loop index from the POD.
      %cur_i = pod.read %state[@i] : !loop_state, !felt.type

      // Continue while cur_i < hi.
      %cond = bool.cmp lt(%cur_i, %hi)
      scf.condition(%cond) %cur_i : !felt.type
    } do {
    ^bb0(%body_i: !felt.type):
      // Read current scalar state.
      %cur_sum = pod.read %state[@sum] : !loop_state, !felt.type

      // Read the array record from the POD.
      %cur_values = pod.read %state[@values] : !loop_state, !array.type<8 x !felt.type>

      // Convert the loop index to an array index and store a value.
      %idx = cast.toindex %body_i
      %next_sum = felt.add %cur_sum, %body_i : !felt.type
      array.write %cur_values[%idx] = %next_sum : !array.type<8 x !felt.type>, !felt.type

      // Write the updated array back into the POD.
      pod.write %state[@values] = %cur_values : !loop_state, !array.type<8 x !felt.type>

      // Update scalar POD records.
      %next_i = felt.add %body_i, %step : !felt.type
      pod.write %state[@sum] = %next_sum : !loop_state, !felt.type
      pod.write %state[@i] = %next_i : !loop_state, !felt.type

      // Yield the next control value.
      scf.yield %next_i : !felt.type
    }

    // Read final state after the loop.
    %final_sum = pod.read %state[@sum] : !loop_state, !felt.type
    %final_values = pod.read %state[@values] : !loop_state, !array.type<8 x !felt.type>

    // Return one value from the final array just to make the array update observable.
    %first = array.read %final_values[%zero_index] : !array.type<8 x !felt.type>, !felt.type

    %result = felt.add %final_sum, %first : !felt.type
    function.return %result : !felt.type
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @stateful_pod_array_while(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_1:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_2:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type attributes {function.allow_non_native_field_ops} {
// CHECK-NEXT:      %[[VAL_3:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[VAL_4:[0-9a-zA-Z_\.]+]] = felt.const  0
// CHECK-NEXT:      %[[VAL_5:[0-9a-zA-Z_\.]+]] = array.new  : <8 x !felt.type>
// CHECK-NEXT:      %[[VAL_6:[0-9a-zA-Z_\.]+]]:3 = scf.while (%[[VAL_7:[0-9a-zA-Z_\.]+]] = %[[VAL_0]], %[[VAL_8:[0-9a-zA-Z_\.]+]] = %[[VAL_4]], %[[VAL_9:[0-9a-zA-Z_\.]+]] = %[[VAL_5]]) : (!felt.type, !felt.type, !array.type<8 x !felt.type>) -> (!felt.type, !felt.type, !array.type<8 x !felt.type>) {
// CHECK-NEXT:        %[[VAL_10:[0-9a-zA-Z_\.]+]] = bool.cmp lt(%[[VAL_7]], %[[VAL_1]]) : !felt.type, !felt.type
// CHECK-NEXT:        scf.condition(%[[VAL_10]]) %[[VAL_7]], %[[VAL_8]], %[[VAL_9]] : !felt.type, !felt.type, !array.type<8 x !felt.type>
// CHECK-NEXT:      } do {
// CHECK-NEXT:      ^bb0(%[[VAL_11:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_12:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_13:[0-9a-zA-Z_\.]+]]: !array.type<8 x !felt.type>):
// CHECK-NEXT:        %[[VAL_14:[0-9a-zA-Z_\.]+]] = cast.toindex %[[VAL_11]] : !felt.type
// CHECK-NEXT:        %[[VAL_15:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_12]], %[[VAL_11]] : !felt.type, !felt.type
// CHECK-NEXT:        array.write %[[VAL_13]]{{\[}}%[[VAL_14]]] = %[[VAL_15]] : <8 x !felt.type>, !felt.type
// CHECK-NEXT:        %[[VAL_16:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_11]], %[[VAL_2]] : !felt.type, !felt.type
// CHECK-NEXT:        scf.yield %[[VAL_16]], %[[VAL_15]], %[[VAL_13]] : !felt.type, !felt.type, !array.type<8 x !felt.type>
// CHECK-NEXT:      }
// CHECK-NEXT:      %[[VAL_17:[0-9a-zA-Z_\.]+]] = array.read %[[VAL_6]]#2{{\[}}%[[VAL_3]]] : <8 x !felt.type>, !felt.type
// CHECK-NEXT:      %[[VAL_18:[0-9a-zA-Z_\.]+]] = felt.add %[[VAL_6]]#1, %[[VAL_17]] : !felt.type, !felt.type
// CHECK-NEXT:      function.return %[[VAL_18]] : !felt.type
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// -----

!Single = !pod.type<[@x: index]>
module attributes {llzk.lang} {
  function.def @virtual_arg_if_write(%p: !Single, %flag: index, %v: index) -> index {
    %c0 = arith.constant 0 : index
    %cond = arith.cmpi sgt, %flag, %c0 : index
    scf.if %cond {
      %sum = arith.addi %v, %flag : index
      pod.write %p[@x] = %sum : !Single, index
    }
    %r = pod.read %p[@x] : !Single, index
    function.return %r : index
  }
}

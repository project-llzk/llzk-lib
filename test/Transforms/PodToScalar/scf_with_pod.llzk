!Single = !pod.type<[@x: index]>
module attributes {llzk.lang} {
  function.def @virtual_arg_for_write(%p: !Single, %start: index) -> index {
    %lb = arith.constant 0 : index
    %ub = arith.constant 4 : index
    %step = arith.constant 1 : index
    scf.for %iv = %lb to %ub step %step {
      %next = arith.addi %start, %iv : index
      pod.write %p[@x] = %next : !Single, index
    }
    %r = pod.read %p[@x] : !Single, index
    function.return %r : index
  }
}

module attributes {llzk.lang} {
  function.def @if_result_and_external_write(%a: index, %b: index) -> index {
    %pod = pod.new : !pod.type<[@value: index]>
    pod.write %pod[@value] = %b : !pod.type<[@value: index]>, index
    %c0 = arith.constant 0 : index
    %cond = arith.cmpi sgt, %a, %c0 : index
    %res = scf.if %cond -> (index) {
      %next0 = arith.addi %a, %b : index
      pod.write %pod[@value] = %next0 : !pod.type<[@value: index]>, index
      scf.yield %next0 : index
    } else {
      %next1 = arith.subi %a, %b : index
      pod.write %pod[@value] = %next1 : !pod.type<[@value: index]>, index
      scf.yield %next1 : index
    }
    %final = pod.read %pod[@value] : !pod.type<[@value: index]>, index
    %sum = arith.addi %res, %final : index
    function.return %sum : index
  }
}

!Inner = !pod.type<[@m: index, @n: index]>
!Outer = !pod.type<[@inner: !Inner]>
module attributes {llzk.lang} {
  function.def @if_write_then_whole_pod_consume(%a: index, %b: index) -> index {
    %c0 = arith.constant 0 : index
    %p = pod.new { @m = %c0, @n = %b } : !Inner
    %outer = pod.new : !Outer

    %cond = arith.cmpi sgt, %a, %c0 : index
    scf.if %cond {
      pod.write %p[@m] = %a : !Inner, index
      pod.write %outer[@inner] = %p : !Outer, !Inner
    } else {
      pod.write %p[@m] = %b : !Inner, index
      pod.write %outer[@inner] = %p : !Outer, !Inner
    }

    %inner = pod.read %outer[@inner] : !Outer, !Inner
    %ret = pod.read %inner[@m] : !Inner, index
    function.return %ret : index
  }
}

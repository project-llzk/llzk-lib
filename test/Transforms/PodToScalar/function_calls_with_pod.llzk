#outer = affine_map<()[s0] -> (s0)>
!Item = !pod.type<[@x: index, @y: !felt.type]>
!Outer = !pod.type<[@items: !array.type<#outer x !Item>]>
module attributes {llzk.lang} {
  function.def @get_items(%p: !Outer) -> !array.type<#outer x !Item> {
    %items = pod.read %p[@items] : !Outer, !array.type<#outer x !Item>
    function.return %items : !array.type<#outer x !Item>
  }
}

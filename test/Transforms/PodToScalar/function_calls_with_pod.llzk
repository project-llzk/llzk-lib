// RUN: llzk-opt -split-input-file -llzk-pod-to-scalar %s | FileCheck --enable-var-scope %s

!Pair = !pod.type<[@lhs: index, @rhs: index]>
module attributes {llzk.lang} {
  function.def @swap_and_add(%pair: !Pair) -> !Pair {
    %lhs = pod.read %pair[@lhs] : !Pair, index
    %rhs = pod.read %pair[@rhs] : !Pair, index
    %sum = arith.addi %lhs, %rhs : index
    %out = pod.new : !Pair
    pod.write %out[@lhs] = %rhs : !Pair, index
    pod.write %out[@rhs] = %sum : !Pair, index
    function.return %out : !Pair
  }

  function.def @main(%x: index, %y: index) -> index {
    %pair = pod.new : !Pair
    pod.write %pair[@lhs] = %x : !Pair, index
    pod.write %pair[@rhs] = %y : !Pair, index
    %swapped = function.call @swap_and_add(%pair) : (!Pair) -> !Pair
    %res = pod.read %swapped[@rhs] : !Pair, index
    function.return %res : index
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @swap_and_add(%[[VAL_0:[0-9a-zA-Z_\.]+]]: index, %[[VAL_1:[0-9a-zA-Z_\.]+]]: index) -> (index, index) {
// CHECK-NEXT:      %[[VAL_2:[0-9a-zA-Z_\.]+]] = arith.addi %[[VAL_0]], %[[VAL_1]] : index
// CHECK-NEXT:      function.return %[[VAL_1]], %[[VAL_2]] : index, index
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @main(%[[VAL_3:[0-9a-zA-Z_\.]+]]: index, %[[VAL_4:[0-9a-zA-Z_\.]+]]: index) -> index {
// CHECK-NEXT:      %[[VAL_5:[0-9a-zA-Z_\.]+]]:2 = function.call @swap_and_add(%[[VAL_3]], %[[VAL_4]]) : (index, index) -> (index, index)
// CHECK-NEXT:      function.return %[[VAL_5]]#1 : index
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// -----

!Pair = !pod.type<[@lhs: index, @rhs: index]>
module attributes {llzk.lang} {
  function.def @mix(%prefix: index, %pair: !Pair, %suffix: index) -> !Pair {
    %lhs = pod.read %pair[@lhs] : !Pair, index
    %rhs = pod.read %pair[@rhs] : !Pair, index
    %lhs2 = arith.addi %prefix, %lhs : index
    %rhs2 = arith.addi %rhs, %suffix : index
    %out = pod.new : !Pair
    pod.write %out[@lhs] = %lhs2 : !Pair, index
    pod.write %out[@rhs] = %rhs2 : !Pair, index
    function.return %out : !Pair
  }

  function.def @main(%a: index, %b: index, %c: index, %d: index) -> index {
    %pair = pod.new : !Pair
    pod.write %pair[@lhs] = %b : !Pair, index
    pod.write %pair[@rhs] = %c : !Pair, index
    %out = function.call @mix(%a, %pair, %d) : (index, !Pair, index) -> !Pair
    %res = pod.read %out[@lhs] : !Pair, index
    function.return %res : index
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @mix(%[[VAL_0:[0-9a-zA-Z_\.]+]]: index, %[[VAL_1:[0-9a-zA-Z_\.]+]]: index, %[[VAL_2:[0-9a-zA-Z_\.]+]]: index, %[[VAL_3:[0-9a-zA-Z_\.]+]]: index) -> (index, index) {
// CHECK-NEXT:      %[[VAL_4:[0-9a-zA-Z_\.]+]] = arith.addi %[[VAL_0]], %[[VAL_1]] : index
// CHECK-NEXT:      %[[VAL_5:[0-9a-zA-Z_\.]+]] = arith.addi %[[VAL_2]], %[[VAL_3]] : index
// CHECK-NEXT:      function.return %[[VAL_4]], %[[VAL_5]] : index, index
// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @main(%[[VAL_6:[0-9a-zA-Z_\.]+]]: index, %[[VAL_7:[0-9a-zA-Z_\.]+]]: index, %[[VAL_8:[0-9a-zA-Z_\.]+]]: index, %[[VAL_9:[0-9a-zA-Z_\.]+]]: index) -> index {
// CHECK-NEXT:      %[[VAL_10:[0-9a-zA-Z_\.]+]]:2 = function.call @mix(%[[VAL_6]], %[[VAL_7]], %[[VAL_8]], %[[VAL_9]]) : (index, index, index, index) -> (index, index)
// CHECK-NEXT:      function.return %[[VAL_10]]#0 : index
// CHECK-NEXT:    }
// CHECK-NEXT:  }

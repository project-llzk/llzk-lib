!Inner = !pod.type<[@x: index]>
!Outer = !pod.type<[@a: !array.type<2 x !Inner>, @b: index]>
module attributes {llzk.lang} {
  function.def @id(
      %arg: !Outer {function.arg_name = "arg"}
  ) -> (!Outer {function.res_name = "out"}) {
    function.return %arg : !Outer
  }

  function.def @main(%arg: !Outer) -> !Outer {
    %res = function.call @id(%arg) : (!Outer) -> !Outer
    function.return %res : !Outer
  }
}

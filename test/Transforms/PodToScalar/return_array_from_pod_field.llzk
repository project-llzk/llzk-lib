// RUN: llzk-opt -llzk-pod-to-scalar %s | FileCheck --enable-var-scope %s

#outer = affine_map<()[s0] -> (s0)>
!Item = !pod.type<[@x: index, @y: !felt.type]>
!Outer = !pod.type<[@items: !array.type<#outer x !Item>]>
module attributes {llzk.lang} {
  function.def @get_items(%p: !Outer) -> !array.type<#outer x !Item> {
    %items = pod.read %p[@items] : !Outer, !array.type<#outer x !Item>
    function.return %items : !array.type<#outer x !Item>
  }
}
// CHECK: #[[$M:[0-9a-zA-Z_\.]+]] = affine_map<()[s0] -> (s0)>
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @get_items(
// CHECK-SAME:    %[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<#[[$M]] x index>,
// CHECK-SAME:    %[[VAL_1:[0-9a-zA-Z_\.]+]]: !array.type<#[[$M]] x !felt.type>
// CHECK-SAME:    ) -> (!array.type<#[[$M]] x index>, !array.type<#[[$M]] x !felt.type>) {
// CHECK-NEXT:      function.return %[[VAL_0]], %[[VAL_1]] : !array.type<#[[$M]] x index>, !array.type<#[[$M]] x !felt.type>
// CHECK-NEXT:    }
// CHECK-NEXT:  }

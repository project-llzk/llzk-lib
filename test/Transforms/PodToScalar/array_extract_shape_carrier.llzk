// RUN: llzk-opt -split-input-file -llzk-pod-to-scalar %s | FileCheck --enable-var-scope %s

!Elem = !pod.type<[@x: index]>
!DynElemMatrix = !array.type<?,? x !Elem>
!DynElemRow = !array.type<? x !Elem>
module attributes {llzk.lang} {
  function.def @extract_dynamic_subarray_len(%src: !DynElemMatrix, %idx: index) -> index {
    %row = array.extract %src[%idx] : !DynElemMatrix
    %c0 = arith.constant 0 : index
    %len = array.len %row, %c0 : !DynElemRow
    function.return %len : index
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @extract_dynamic_subarray_len(%[[SRC_X:[0-9a-zA-Z_\.]+]]: !array.type<?,? x index>, %[[SRC_SHAPE:[0-9a-zA-Z_\.]+]]: !array.type<?,? x none>, %[[IDX:[0-9a-zA-Z_\.]+]]: index) -> index {
// CHECK-NEXT:      %[[ROW_X:[0-9a-zA-Z_\.]+]] = array.extract %[[SRC_X]]{{\[}}%[[IDX]]] : <?,? x index>
// CHECK-NEXT:      %[[ROW_SHAPE:[0-9a-zA-Z_\.]+]] = array.extract %[[SRC_SHAPE]]{{\[}}%[[IDX]]] : <?,? x none>
// CHECK-NEXT:      %[[C0:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[LEN:[0-9a-zA-Z_\.]+]] = array.len %[[ROW_SHAPE]], %[[C0]] : <? x none>
// CHECK-NEXT:      function.return %[[LEN]] : index
// CHECK-NEXT:    }
// CHECK-NEXT:  }

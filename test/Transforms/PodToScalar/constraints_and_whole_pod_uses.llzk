// RUN: llzk-opt -split-input-file -llzk-pod-to-scalar %s | FileCheck --enable-var-scope %s

!Pair = !pod.type<[@x: index, @y: !felt.type]>
module attributes {llzk.lang} {
  function.def @eq_array_pod(
      %lhs: !array.type<2 x !Pair>, %rhs: !array.type<2 x !Pair>
  ) attributes {function.allow_constraint} {
    constrain.eq %lhs, %rhs : !array.type<2 x !Pair>
    function.return
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @eq_array_pod(
// CHECK-SAME:    %[[LHS_X:[0-9a-zA-Z_\.]+]]: !array.type<2 x index>,
// CHECK-SAME:    %[[LHS_Y:[0-9a-zA-Z_\.]+]]: !array.type<2 x !felt.type>,
// CHECK-SAME:    %[[RHS_X:[0-9a-zA-Z_\.]+]]: !array.type<2 x index>,
// CHECK-SAME:    %[[RHS_Y:[0-9a-zA-Z_\.]+]]: !array.type<2 x !felt.type>
// CHECK-SAME:    ) attributes {function.allow_constraint} {
// CHECK-NEXT:      constrain.eq %[[LHS_X]], %[[RHS_X]] : !array.type<2 x index>, !array.type<2 x index>
// CHECK-NEXT:      constrain.eq %[[LHS_Y]], %[[RHS_Y]] : !array.type<2 x !felt.type>, !array.type<2 x !felt.type>
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// -----

!LeafArrayPod = !pod.type<[@vals: !array.type<3 x index>]>
module attributes {llzk.lang} {
  function.def @contains_dynamic_subarray_with_shape_carrier(
      %arr: !array.type<2,? x !LeafArrayPod>, %sub: !array.type<? x !LeafArrayPod>
  ) attributes {function.allow_constraint} {
    constrain.in %arr, %sub : !array.type<2,? x !LeafArrayPod>, !array.type<? x !LeafArrayPod>
    function.return
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @contains_dynamic_subarray_with_shape_carrier(
// CHECK-SAME:    %[[ARR_VALS:[0-9a-zA-Z_\.]+]]: !array.type<2,?,3 x index>,
// CHECK-SAME:    %[[ARR_SHAPE:[0-9a-zA-Z_\.]+]]: !array.type<2,? x none>,
// CHECK-SAME:    %[[SUB_VALS:[0-9a-zA-Z_\.]+]]: !array.type<?,3 x index>,
// CHECK-SAME:    %[[SUB_SHAPE:[0-9a-zA-Z_\.]+]]: !array.type<? x none>
// CHECK-SAME:    ) attributes {function.allow_constraint} {
// CHECK-NEXT:      %[[C0:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[TRUE:[0-9a-zA-Z_\.]+]] = arith.constant true
// CHECK-NEXT:      %[[IDX:[0-9a-zA-Z_\.]+]] = llzk.nondet : index
// CHECK-NEXT:      %[[DIM0:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[LEN:[0-9a-zA-Z_\.]+]] = array.len %[[ARR_SHAPE]], %[[DIM0]] : <2,? x none>
// CHECK-NEXT:      %[[GE0:[0-9a-zA-Z_\.]+]] = arith.cmpi sge, %[[IDX]], %[[C0]] : index
// CHECK-NEXT:      constrain.eq %[[GE0]], %[[TRUE]] : i1, i1
// CHECK-NEXT:      %[[LT_LEN:[0-9a-zA-Z_\.]+]] = arith.cmpi slt, %[[IDX]], %[[LEN]] : index
// CHECK-NEXT:      constrain.eq %[[LT_LEN]], %[[TRUE]] : i1, i1
// CHECK-NEXT:      %[[SEL_SHAPE:[0-9a-zA-Z_\.]+]] = array.extract %[[ARR_SHAPE]]{{\[}}%[[IDX]]] : <2,? x none>
// CHECK-NEXT:      %[[SEL_DIM0:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[SEL_LEN:[0-9a-zA-Z_\.]+]] = array.len %[[SEL_SHAPE]], %[[SEL_DIM0]] : <? x none>
// CHECK-NEXT:      %[[RHS_LEN:[0-9a-zA-Z_\.]+]] = array.len %[[SUB_SHAPE]], %[[SEL_DIM0]] : <? x none>
// CHECK-NEXT:      constrain.eq %[[SEL_LEN]], %[[RHS_LEN]] : index, index
// CHECK-NEXT:      %[[SEL_VALS:[0-9a-zA-Z_\.]+]] = array.extract %[[ARR_VALS]]{{\[}}%[[IDX]]] : <2,?,3 x index>
// CHECK-NEXT:      constrain.eq %[[SEL_VALS]], %[[SUB_VALS]] : !array.type<?,3 x index>, !array.type<?,3 x index>
// CHECK-NEXT:      function.return
// CHECK-NEXT:    }
// CHECK-NEXT:  }
// -----

!Empty = !pod.type<[]>

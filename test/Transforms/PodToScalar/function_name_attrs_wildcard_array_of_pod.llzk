// RUN: llzk-opt -llzk-pod-to-scalar %s | FileCheck --enable-var-scope %s

!Pair = !pod.type<[@lhs: index, @rhs: !felt.type]>
!WildcardPairArray = !array.type<? x !Pair>
module attributes {llzk.lang} {
  function.def @named_wildcard_array(
      %arg: !WildcardPairArray {function.arg_name = "input"}
  ) -> (!WildcardPairArray {function.res_name = "output"}) {
    function.return %arg : !WildcardPairArray
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @named_wildcard_array(
// CHECK-SAME:    %[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<? x index> {function.arg_name = "input.lhs"},
// CHECK-SAME:    %[[VAL_1:[0-9a-zA-Z_\.]+]]: !array.type<? x !felt.type> {function.arg_name = "input.rhs"}
// CHECK-SAME:    ) -> (!array.type<? x index> {function.res_name = "output.lhs"}, !array.type<? x !felt.type> {function.res_name = "output.rhs"}) {
// CHECK-NEXT:      function.return %[[VAL_0]], %[[VAL_1]] : !array.type<? x index>, !array.type<? x !felt.type>
// CHECK-NEXT:    }
// CHECK-NEXT:  }

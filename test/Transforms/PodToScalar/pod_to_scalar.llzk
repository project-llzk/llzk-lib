module attributes {llzk.lang} {
  function.def @nested_if_local_pods(%a: index, %b: index) -> index {
    %c0 = arith.constant 0 : index
    %cond0 = arith.cmpi sgt, %a, %c0 : index
    %ret = scf.if %cond0 -> (index) {
      %cond1 = arith.cmpi sgt, %b, %c0 : index
      %inner = scf.if %cond1 -> (index) {
        %p0 = pod.new : !pod.type<[@m: index]>
        pod.write %p0[@m] = %a : !pod.type<[@m: index]>, index
        %r0 = pod.read %p0[@m] : !pod.type<[@m: index]>, index
        %next0 = arith.addi %r0, %b : index
        scf.yield %next0 : index
      } else {
        %p1 = pod.new : !pod.type<[@m: index]>
        pod.write %p1[@m] = %a : !pod.type<[@m: index]>, index
        %r1 = pod.read %p1[@m] : !pod.type<[@m: index]>, index
        %next1 = arith.subi %r1, %b : index
        scf.yield %next1 : index
      }
      scf.yield %inner : index
    } else {
      %p2 = pod.new : !pod.type<[@m: index]>
      pod.write %p2[@m] = %b : !pod.type<[@m: index]>, index
      %r2 = pod.read %p2[@m] : !pod.type<[@m: index]>, index
      scf.yield %r2 : index
    }
    function.return %ret : index
  }
}

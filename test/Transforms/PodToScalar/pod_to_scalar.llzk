module attributes {llzk.lang} {
  function.def @nested_if_external_new(%a: index, %b: index) -> index {
    %pod = pod.new : !pod.type<[@value: index]>
    %c0 = arith.constant 0 : index
    %cond0 = arith.cmpi sgt, %a, %c0 : index
    scf.if %cond0 {
      %cond1 = arith.cmpi sgt, %b, %c0 : index
      scf.if %cond1 {
        %read0 = pod.read %pod[@value] : !pod.type<[@value: index]>, index
        %next0 = arith.addi %read0, %a : index
        pod.write %pod[@value] = %next0 : !pod.type<[@value: index]>, index
      } else {
        %read1 = pod.read %pod[@value] : !pod.type<[@value: index]>, index
        %next1 = arith.addi %read1, %b : index
        pod.write %pod[@value] = %next1 : !pod.type<[@value: index]>, index
      }
    } else {
      %read2 = pod.read %pod[@value] : !pod.type<[@value: index]>, index
      %next2 = arith.subi %read2, %b : index
      pod.write %pod[@value] = %next2 : !pod.type<[@value: index]>, index
    }
    %ret = pod.read %pod[@value] : !pod.type<[@value: index]>, index
    function.return %ret : index
  }
}

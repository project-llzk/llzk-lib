// CHECK-NEXT:        %[[VAL_13:[0-9a-zA-Z_\.]+]] = array.extract %[[VAL_1]]{{\[}}%[[VAL_10]]] : <?,? x index>
// CHECK-NEXT:        %[[VAL_14:[0-9a-zA-Z_\.]+]] = array.extract %[[VAL_2]]{{\[}}%[[VAL_10]]] : <?,? x none>
// CHECK-NEXT:        %[[VAL_15:[0-9a-zA-Z_\.]+]] = array.read %[[VAL_12]]{{\[}}%[[VAL_7]]] : <? x index>, index
// CHECK-NEXT:        %[[VAL_16:[0-9a-zA-Z_\.]+]] = array.read %[[VAL_13]]{{\[}}%[[VAL_7]]] : <? x index>, index
// CHECK-NEXT:        %[[VAL_17:[0-9a-zA-Z_\.]+]] = arith.cmpi sle, %[[VAL_15]], %[[VAL_3]] : index
// CHECK-NEXT:        %[[VAL_18:[0-9a-zA-Z_\.]+]] = bool.and %[[VAL_17]], %[[VAL_5]] : i1, i1
// CHECK-NEXT:        %[[VAL_19:[0-9a-zA-Z_\.]+]] = bool.and %[[VAL_11]], %[[VAL_18]] : i1, i1

!Pair = !pod.type<[@x: index, @y: index]>
!DynPairMatrix = !array.type<?,? x !Pair>
!DynPairRow = !array.type<? x !Pair>
module attributes {llzk.lang} {
  function.def @forall_exists_dynamic_row_with_payload(
      %arr: !DynPairMatrix, %limit: index
  ) -> i1 attributes {function.allow_non_native_field_ops} {
    %all = bool.forall %sub: !DynPairRow in %arr : !DynPairMatrix {
      %d0 = arith.constant 0 : index
      %len = array.len %sub, %d0 : !DynPairRow
      %head = array.read %sub[%d0] : !DynPairRow, !Pair
      %x = pod.read %head[@x] : !Pair, index
      %lenOk = arith.cmpi eq, %len, %len : index
      %xOk = arith.cmpi sle, %x, %limit : index
      %ok = bool.and %lenOk, %xOk : i1, i1
      bool.yield %ok
    }

    %any = bool.exists %sub: !DynPairRow in %arr : !DynPairMatrix {
      %d0 = arith.constant 0 : index
      %len = array.len %sub, %d0 : !DynPairRow
      %head = array.read %sub[%d0] : !DynPairRow, !Pair
      %y = pod.read %head[@y] : !Pair, index
      %lenOk = arith.cmpi eq, %len, %len : index
      %yOk = arith.cmpi sge, %y, %limit : index
      %ok = bool.and %lenOk, %yOk : i1, i1
      bool.yield %ok
    }

    %result = bool.and %all, %any : i1, i1
    function.return %result : i1
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @forall_exists_dynamic_row_with_payload(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !array.type<?,? x index>, %[[VAL_1:[0-9a-zA-Z_\.]+]]: !array.type<?,? x index>, %[[VAL_2:[0-9a-zA-Z_\.]+]]: !array.type<?,? x none>, %[[VAL_3:[0-9a-zA-Z_\.]+]]: index) -> i1 attributes {function.allow_non_native_field_ops} {
// CHECK-NEXT:      %[[VAL_4:[0-9a-zA-Z_\.]+]] = arith.constant false
// CHECK-NEXT:      %[[VAL_5:[0-9a-zA-Z_\.]+]] = arith.constant true
// CHECK-NEXT:      %[[VAL_6:[0-9a-zA-Z_\.]+]] = arith.constant 1 : index
// CHECK-NEXT:      %[[VAL_7:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:      %[[VAL_8:[0-9a-zA-Z_\.]+]] = array.len %[[VAL_2]], %[[VAL_7]] : <?,? x none>
// CHECK-NEXT:      %[[VAL_9:[0-9a-zA-Z_\.]+]] = scf.for %[[VAL_10:[0-9a-zA-Z_\.]+]] = %[[VAL_7]] to %[[VAL_8]] step %[[VAL_6]] iter_args(%[[VAL_11:[0-9a-zA-Z_\.]+]] = %[[VAL_5]]) -> (i1) {

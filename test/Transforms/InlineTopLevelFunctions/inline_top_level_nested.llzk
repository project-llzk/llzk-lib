// RUN: llzk-opt -llzk-inline-top-level-functions %s | FileCheck --enable-var-scope %s

// Both helpers must be inlined and erased.
module attributes {llzk.lang} {
  function.def @inner(%x: !felt.type) -> !felt.type {
    %one = felt.const 1
    %r = felt.add %x, %one : !felt.type, !felt.type
    function.return %r : !felt.type
  }

  function.def @outer(%x: !felt.type) -> !felt.type {
    %a = function.call @inner(%x) : (!felt.type) -> !felt.type
    %b = function.call @inner(%a) : (!felt.type) -> !felt.type
    function.return %b : !felt.type
  }

  struct.def @Main {
    struct.member @out : !felt.type {llzk.pub}
    function.def @compute(%x: !felt.type) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %x: !felt.type) {
      %r = function.call @outer(%x) : (!felt.type) -> !felt.type
      %o = struct.readm %self[@out] : !struct.type<@Main>, !felt.type
      constrain.eq %o, %r : !felt.type, !felt.type
      function.return
    }
  }
}

// CHECK-NOT: function.def @inner
// CHECK-NOT: function.def @outer
// CHECK-LABEL: struct.def @Main
// CHECK: function.def @constrain
// CHECK-NOT: function.call
// CHECK-COUNT-2: felt.add
// CHECK: constrain.eq

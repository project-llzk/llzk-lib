// RUN: llzk-opt --llzk-enforce-no-overwrite -verify-diagnostics %s

module attributes {llzk.lang} {
    struct.def @A {
        struct.member @foo : !felt.type
        // expected-warning@+1 {{member may not be written to}}
        struct.member @bar : !felt.type
        // expected-warning@+1 {{member may not be written to}}
        struct.member @baz : !felt.type
        // expected-warning@+1 {{member may not be written to}}
        struct.member @wuz : !felt.type
        function.def @product(%x: !felt.type, %y: !felt.type, %b: i1) -> !struct.type<@A> {
            %self = struct.new : <@A>

            scf.if %b {
                struct.writem %self[@foo] = %x : <@A>, !felt.type  
                scf.yield  
            } else {
                // expected-note@+1 {{previously written to here}}
                struct.writem %self[@foo] = %y : <@A>, !felt.type    
                scf.yield
            }

            scf.if %b {
                struct.writem %self[@baz] = %x : <@A>, !felt.type
                scf.yield
            }

            scf.if %b {
                // expected-warning@+1 {{overwriting struct member 'foo'}}
                struct.writem %self[@foo] = %x : <@A>, !felt.type
                scf.yield
            }

            function.return %self : !struct.type<@A>
        }
    }
}

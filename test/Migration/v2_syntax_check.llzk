// RUN: llzk-opt %S/v2_syntax.llzk.bc 2>&1 | FileCheck --enable-var-scope %s

// Read bytecode from `v2_syntax.llzk.bc` and check that it migrates to current dialect version.

// CHECK: #[[$ATTR_0:[0-9a-zA-Z_\.]+]] = affine_map<()[s0, s1] -> (s0 + s1)>

module attributes {llzk.lang} {
  struct.def @BranchLocalAuxPlacement {
    function.def @compute(%a: !felt.type, %b: !felt.type, %cond: i1) -> !struct.type<@BranchLocalAuxPlacement> attributes {function.allow_witness} {
      %self = struct.new : <@BranchLocalAuxPlacement>
      function.return %self : !struct.type<@BranchLocalAuxPlacement>
    }
    function.def @constrain(
        %self: !struct.type<@BranchLocalAuxPlacement>,
        %a: !felt.type,
        %b: !felt.type,
        %cond: i1
    ) attributes {function.allow_constraint} {
      scf.if %cond {
        %then_aux = llzk.aux : !felt.type
        constrain.eq %then_aux, %a : !felt.type, !felt.type
      } else {
        %else_aux = llzk.aux : !felt.type
        constrain.eq %else_aux, %b : !felt.type, !felt.type
      }
      function.return
    }
  }
}

// RUN: llzk-opt -split-input-file --pass-pipeline='builtin.module(cse, canonicalize)' -verify-diagnostics %s | FileCheck --enable-var-scope %s

// Ensures that `cse` and `canonicalize` do not combine multiple generated
// polynomial auxiliary operations. Each `llzk.aux` is a placement-sensitive
// existential value, not a pure constant and not user-level nondeterminism.
module attributes {llzk.lang} {
  struct.def @A {
    function.def @compute() -> !struct.type<@A> attributes {function.allow_witness} {
      %self = struct.new : <@A>
      function.return %self : !struct.type<@A>
    }
    function.def @constrain(%self: !struct.type<@A>) attributes {function.allow_constraint} {
      %0 = llzk.aux : !felt.type
      %1 = llzk.aux : !felt.type
      %c7 = felt.const 7
      %c9 = felt.const 9
      constrain.eq %0, %c7 : !felt.type
      constrain.eq %1, %c9 : !felt.type
      function.return
    }
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    struct.def @A {
// CHECK-NEXT:      function.def @compute() -> !struct.type<@A> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_0:[0-9a-zA-Z_\.]+]] = struct.new : <@A>
// CHECK-NEXT:        function.return %[[VAL_0]] : !struct.type<@A>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_1:[0-9a-zA-Z_\.]+]]: !struct.type<@A>) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_2:[0-9a-zA-Z_\.]+]] = felt.const  9
// CHECK-NEXT:        %[[VAL_3:[0-9a-zA-Z_\.]+]] = felt.const  7
// CHECK-NEXT:        %[[VAL_4:[0-9a-zA-Z_\.]+]] = llzk.aux : !felt.type
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = llzk.aux : !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_4]], %[[VAL_3]] : !felt.type, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_5]], %[[VAL_2]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

// -----

module attributes {llzk.lang} {
  struct.def @LoopAuxPlacement {
    function.def @compute() -> !struct.type<@LoopAuxPlacement> attributes {function.allow_witness} {
      %self = struct.new : <@LoopAuxPlacement>
      function.return %self : !struct.type<@LoopAuxPlacement>
    }
    function.def @constrain(%self: !struct.type<@LoopAuxPlacement>, %a: !felt.type) attributes {function.allow_constraint} {
      %lb = arith.constant 0 : index
      %ub = arith.constant 4 : index
      %step = arith.constant 1 : index
      scf.for %iv = %lb to %ub step %step {
        %aux = llzk.aux : !felt.type
        constrain.eq %aux, %a : !felt.type, !felt.type
      }
      function.return
    }
  }
}
// CHECK-LABEL:    struct.def @LoopAuxPlacement {
// CHECK:          function.def @constrain
// CHECK-NOT:      llzk.aux
// CHECK:          scf.for
// CHECK-NEXT:       %[[LOOP_AUX:[0-9a-zA-Z_\.]+]] = llzk.aux : !felt.type
// CHECK-NEXT:       constrain.eq %[[LOOP_AUX]]

// -----

module attributes {llzk.lang} {
  struct.def @BranchAuxPlacement {
    function.def @compute() -> !struct.type<@BranchAuxPlacement> attributes {function.allow_witness} {
      %self = struct.new : <@BranchAuxPlacement>
      function.return %self : !struct.type<@BranchAuxPlacement>
    }
    function.def @constrain(
        %self: !struct.type<@BranchAuxPlacement>,
        %a: !felt.type,
        %b: !felt.type,
        %cond: i1
    ) attributes {function.allow_constraint} {
      scf.if %cond {
        %then_aux = llzk.aux : !felt.type
        constrain.eq %then_aux, %a : !felt.type, !felt.type
      } else {
        %else_aux = llzk.aux : !felt.type
        constrain.eq %else_aux, %b : !felt.type, !felt.type
      }
      function.return
    }
  }
}
// CHECK-LABEL:    struct.def @BranchAuxPlacement {
// CHECK:          function.def @constrain
// CHECK-NOT:      llzk.aux
// CHECK:          scf.if
// CHECK-NEXT:       %[[THEN_AUX:[0-9a-zA-Z_\.]+]] = llzk.aux : !felt.type
// CHECK-NEXT:       constrain.eq %[[THEN_AUX]]
// CHECK-NEXT:     } else {
// CHECK-NEXT:       %[[ELSE_AUX:[0-9a-zA-Z_\.]+]] = llzk.aux : !felt.type
// CHECK-NEXT:       constrain.eq %[[ELSE_AUX]]

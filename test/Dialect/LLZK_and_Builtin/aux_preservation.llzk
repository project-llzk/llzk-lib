// CHECK-NEXT:          %[[VAL_6:[0-9a-zA-Z_\.]+]]: !felt.type,
// CHECK-NEXT:          %[[VAL_7:[0-9a-zA-Z_\.]+]]: i1
// CHECK-NEXT:      ) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_8:[0-9a-zA-Z_\.]+]] = llzk.aux : !felt.type
// CHECK-NEXT:        scf.if %[[VAL_7]] {
// CHECK-NEXT:          constrain.eq %[[VAL_8]], %[[VAL_5]] : !felt.type, !felt.type
// CHECK-NEXT:        } else {
// CHECK-NEXT:          constrain.eq %[[VAL_5]], %[[VAL_6]] : !felt.type, !felt.type
// CHECK-NEXT:        }
// CHECK-NEXT:        function.return

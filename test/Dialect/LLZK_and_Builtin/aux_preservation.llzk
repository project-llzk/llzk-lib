// RUN: llzk-opt -split-input-file --pass-pipeline='builtin.module(cse, canonicalize, llzk-duplicate-op-elim, loop-invariant-code-motion, control-flow-sink)' -verify-diagnostics %s | FileCheck --enable-var-scope %s

// NOTE: Assertions have been autogenerated by scripts/generate-test-checks.py
//
// The script is designed to make adding checks to
// a test case fast, it is *not* designed to be authoritative
// about what constitutes a good test! The CHECK should be
// minimized and named to reflect the test intent.

// Ensures that cleanup and placement transformations preserve generated
// polynomial auxiliary operations. Each `llzk.aux` is a placement-sensitive
// existential value, not a pure constant and not user-level nondeterminism.
module attributes {llzk.lang} {
  struct.def @A {
    function.def @compute() -> !struct.type<@A> attributes {function.allow_witness} {
      %self = struct.new : <@A>
      function.return %self : !struct.type<@A>
    }
    function.def @constrain(%self: !struct.type<@A>) attributes {function.allow_constraint} {
      %0 = llzk.aux : !felt.type
      %1 = llzk.aux : !felt.type
      %c7 = felt.const 7
      %c9 = felt.const 9
      constrain.eq %0, %c7 : !felt.type
      constrain.eq %1, %c9 : !felt.type
      function.return
    }
  }
}
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    struct.def @A {
// CHECK-NEXT:      function.def @compute() -> !struct.type<@A> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_0:[0-9a-zA-Z_\.]+]] = struct.new : <@A>
// CHECK-NEXT:        function.return %[[VAL_0]] : !struct.type<@A>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_1:[0-9a-zA-Z_\.]+]]: !struct.type<@A>) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_2:[0-9a-zA-Z_\.]+]] = felt.const  9
// CHECK-NEXT:        %[[VAL_3:[0-9a-zA-Z_\.]+]] = felt.const  7
// CHECK-NEXT:        %[[VAL_4:[0-9a-zA-Z_\.]+]] = llzk.aux : !felt.type
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = llzk.aux : !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_4]], %[[VAL_3]] : !felt.type, !felt.type
// CHECK-NEXT:        constrain.eq %[[VAL_5]], %[[VAL_2]] : !felt.type, !felt.type
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

// -----

module attributes {llzk.lang} {
  struct.def @LoopAuxPlacement {
    function.def @compute(%a: !felt.type) -> !struct.type<@LoopAuxPlacement> attributes {function.allow_witness} {
      %self = struct.new : <@LoopAuxPlacement>
      function.return %self : !struct.type<@LoopAuxPlacement>
    }
    function.def @constrain(%self: !struct.type<@LoopAuxPlacement>, %a: !felt.type) attributes {function.allow_constraint} {
      %lb = arith.constant 0 : index
      %ub = arith.constant 4 : index
      %step = arith.constant 1 : index
      scf.for %iv = %lb to %ub step %step {
        %aux = llzk.aux : !felt.type
        constrain.eq %aux, %a : !felt.type, !felt.type
      }
      function.return
    }
  }
}
// `loop-invariant-code-motion` must not hoist an auxiliary out of its loop.
// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    struct.def @LoopAuxPlacement {
// CHECK-NEXT:      function.def @compute(%[[VAL_0:[0-9a-zA-Z_\.]+]]: !felt.type) -> !struct.type<@LoopAuxPlacement> attributes {function.allow_witness} {
// CHECK-NEXT:        %[[VAL_1:[0-9a-zA-Z_\.]+]] = struct.new : <@LoopAuxPlacement>
// CHECK-NEXT:        function.return %[[VAL_1]] : !struct.type<@LoopAuxPlacement>
// CHECK-NEXT:      }
// CHECK-NEXT:      function.def @constrain(%[[VAL_2:[0-9a-zA-Z_\.]+]]: !struct.type<@LoopAuxPlacement>, %[[VAL_3:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_constraint} {
// CHECK-NEXT:        %[[VAL_4:[0-9a-zA-Z_\.]+]] = arith.constant 0 : index
// CHECK-NEXT:        %[[VAL_5:[0-9a-zA-Z_\.]+]] = arith.constant 4 : index
// CHECK-NEXT:        %[[VAL_6:[0-9a-zA-Z_\.]+]] = arith.constant 1 : index
// CHECK-NEXT:        scf.for %[[VAL_7:[0-9a-zA-Z_\.]+]] = %[[VAL_4]] to %[[VAL_5]] step %[[VAL_6]] {
// CHECK-NEXT:          %[[VAL_8:[0-9a-zA-Z_\.]+]] = llzk.aux : !felt.type
// CHECK-NEXT:          constrain.eq %[[VAL_8]], %[[VAL_3]] : !felt.type, !felt.type
// CHECK-NEXT:        }
// CHECK-NEXT:        function.return
// CHECK-NEXT:      }
// CHECK-NEXT:    }
// CHECK-NEXT:  }

// -----

module attributes {llzk.lang} {
  struct.def @BranchSinkAuxPlacement {
    function.def @compute(%a: !felt.type, %b: !felt.type, %cond: i1) -> !struct.type<@BranchSinkAuxPlacement> attributes {function.allow_witness} {
      %self = struct.new : <@BranchSinkAuxPlacement>
      function.return %self : !struct.type<@BranchSinkAuxPlacement>
    }
    function.def @constrain(
        %self: !struct.type<@BranchSinkAuxPlacement>,
        %a: !felt.type,
        %b: !felt.type,
        %cond: i1
    ) attributes {function.allow_constraint} {
      %aux = llzk.aux : !felt.type
      scf.if %cond {
        constrain.eq %aux, %a : !felt.type, !felt.type
      } else {
        constrain.eq %a, %b : !felt.type, !felt.type
      }
      function.return
    }
  }
}
// `control-flow-sink` must not move this auxiliary into the then-region.

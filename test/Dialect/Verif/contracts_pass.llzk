// RUN: llzk-opt -split-input-file %s 2>&1 | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
  struct.def @Top {
    function.def @compute() -> !struct.type<@Top> {
      %self = struct.new : !struct.type<@Top>
      function.return %self : !struct.type<@Top>
    }
    function.def @constrain(%self: !struct.type<@Top>)  {
      function.return
    }
  }

  verif.contract @Foo for @Top (%self: !struct.type<@Top>) {
    %1 = arith.constant true
    verif.ensure_compute %1
  }
}

// -----

module attributes {llzk.lang} {
  struct.def @Top {
    function.def @compute(%a : !felt.type) -> !struct.type<@Top> {
      %self = struct.new : !struct.type<@Top>
      function.return %self : !struct.type<@Top>
    }
    function.def @constrain(%self: !struct.type<@Top>, %a : !felt.type)  {
      function.return
    }
  }

  verif.contract @Foo for @Top (%self: !struct.type<@Top>, %a: !felt.type) {
  }
}

// -----

module attributes {llzk.lang} {
  poly.template @T {
    struct.def @Top {
      function.def @compute(%a : !felt.type) -> !struct.type<@T::@Top> {
        %self = struct.new : !struct.type<@T::@Top>
        function.return %self : !struct.type<@T::@Top>
      }
      function.def @constrain(%self: !struct.type<@T::@Top>, %a : !felt.type)  {
        function.return
      }
    }

    verif.contract @Foo for @T::@Top (%self: !struct.type<@T::@Top>, %a: !felt.type) {
    }
  }
}
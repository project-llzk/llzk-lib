module attributes {llzk.lang} {
  function.def @Bar() attributes {function.allow_witness} {
    scf.while : () -> () {
      %true = arith.constant  true 
      scf.condition(%true)
    } do {
      scf.yield
    } attributes {loop_label = "loopA"}
    function.return
  }

  verif.contract @Foo for @Bar () {
    verif.invariant for @loopA() {
      %true = arith.constant  true
      verif.require_compute %true
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:    function.def @Bar() attributes {function.allow_witness} {

// RUN: llzk-opt -split-input-file -verify-diagnostics %s

module attributes {llzk.lang} {
  function.def @check(%x: index) {
    function.return
  }

  // expected-error@+1 {{'verif.contract' op 'function.arg_name' on argument 0 must be a string attribute}}
  verif.contract @BadArgName for @check (%x: index {function.arg_name = 7 : i64}) {
    %ok = arith.constant true
    verif.ensure_compute %ok
  }
}

// -----

module attributes {llzk.lang} {
  function.def @check(%x: index, %y: index) {
    function.return
  }

  // expected-error@+1 {{'verif.contract' op duplicate 'function.arg_name' value "dup" on argument 1}}
  verif.contract @DupArgName for @check (%x: index {function.arg_name = "dup"}, %y: index {function.arg_name = "dup"}) {
    %ok = arith.constant true
    verif.ensure_compute %ok
  }
}

// -----

module attributes {llzk.lang} {
  function.def @check(%x: index) { // expected-note {{target defined here}}
    function.return
  }

  // expected-error@+1 {{'verif.contract' op contract type does not match target type}}
  verif.contract @BadType for @check (%x: i32) {
    %ok = arith.constant true
    verif.ensure_compute %ok
  }
}

// -----

module attributes {llzk.lang} {
  struct.def @Box { // expected-note {{target defined here}}
    function.def @compute(%x: index) -> !struct.type<@Box> {
      %self = struct.new : !struct.type<@Box>
      function.return %self : !struct.type<@Box>
    }
    function.def @constrain(%self: !struct.type<@Box>, %x: index) {
      function.return
    }
  }

  // expected-error@+1 {{'verif.contract' op contract type does not match target type}}
  verif.contract @WrongStructSig for @Box (%self: !struct.type<@Box>) {
    %ok = arith.constant true
    verif.ensure_compute %ok
  }
}


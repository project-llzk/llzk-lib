module attributes {llzk.lang} {
  struct.def @Box {
    function.def @compute(%x: index) -> !struct.type<@Box> {
      %self = struct.new : !struct.type<@Box>
      function.return %self : !struct.type<@Box>
    }
    function.def @constrain(%self: !struct.type<@Box>, %x: index) { // expected-note {{target defined here}}
      function.return
    }
  }

  // expected-error@+1 {{'verif.contract' op target "@Box::@constrain" is not a supported contract target}}
  verif.contract @CannotTargetStructConstraint for @Box::@constrain (%self: !struct.type<@Box>, %x: index) {
  }
}


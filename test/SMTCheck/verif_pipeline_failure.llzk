// RUN: llzk-opt --llzk-verif-to-smtlib='entry=smt_verif_CheckGate_entry' -o /dev/null %s | not llzk-smt-check - 2>&1 | FileCheck %s

module attributes {llzk.lang} {
  function.def @gate_target(%gate: i1) {
    function.return
  }

  verif.contract @CheckGate for @gate_target (%gate: i1) {
    %true = arith.constant true
    %false = arith.constant false
    verif.require_compute %true
    verif.ensure_compute %false
  }
}

// CHECK: smt_verif_CheckGate_entry/target[0]: unsat (expected unsat)
// CHECK: llzk-smt-check: stage result mismatch:
// CHECK: smt_verif_CheckGate_entry/post[0]: got sat, expected unsat

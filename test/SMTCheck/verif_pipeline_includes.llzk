// RUN: llzk-opt --llzk-verif-to-smtlib='entry=smt_verif_TopGate_entry' -o /dev/null %s | llzk-smt-check - | FileCheck %s

module attributes {llzk.lang} {
  function.def @gate_target(%gate: i1) {
    function.return
  }

  verif.contract @LeafGate for @gate_target (%gate: i1) {
    %true = arith.constant true
    verif.require_compute %true
    verif.ensure_compute %true
  }

  verif.contract @TopGate for @gate_target (%gate: i1) {
    verif.include @LeafGate(%gate) : (i1) -> ()
  }
}

// CHECK: smt_verif_TopGate_entry/target[0]: unsat (expected unsat)
// CHECK-NEXT: smt_verif_TopGate_entry/pre: unsat (expected unsat)
// CHECK-NEXT: smt_verif_TopGate_entry/target[1]: unsat (expected unsat)
// CHECK-NEXT: smt_verif_TopGate_entry/post[0]: unsat (expected unsat)
// CHECK-NEXT: smt_verif_TopGate_entry/post[1]: unsat (expected unsat)
// CHECK-NEXT: smt_verif_TopGate_entry/pre: unsat (expected unsat)
// CHECK-NEXT: smt_verif_TopGate_entry/target[0]: unsat (expected unsat)
// CHECK-NEXT: smt_verif_TopGate_entry/post[0]: unsat (expected unsat)
// CHECK-NEXT: smt_verif_TopGate_entry/post[1]: unsat (expected unsat)
// CHECK-NEXT: smt_verif_TopGate_entry/post[2]: unsat (expected unsat)
// CHECK-NEXT: smt_verif_TopGate_entry/post[3]: unsat (expected unsat)

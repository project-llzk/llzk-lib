module attributes {pcl.prime = #pcl.prime<7>} {
  func.func @and() -> !pcl.bool {
    %0 = pcl.true
    %1 = pcl.var "a" true 
    %2 = pcl.const 1 
    %3 = pcl.eq %1, %2
    %4 = pcl.and %0, %3
    return %4 : !pcl.bool
  }
}


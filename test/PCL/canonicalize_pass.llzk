// REQUIRES: with-pcl
// RUN: llzk-opt -split-input-file -canonicalize -verify-diagnostics %s | FileCheck --enable-var-scope %s

module attributes {pcl.prime = #pcl.prime<7>} {
  func.func @add() -> !pcl.felt {
    %0 = pcl.const 5
    %1 = pcl.const 1 
    %2 = pcl.add %0, %1
    return %2 : !pcl.felt
  }
}

// CHECK-LABEL: module attributes {pcl.prime = #pcl.prime<7>} {
// CHECK-NEXT:    func.func @add() -> !pcl.felt {
// CHECK-NEXT:      %[[VAL_0:[0-9a-zA-Z_\.]+]] = pcl.const 6
// CHECK-NEXT:      return %[[VAL_0]] : !pcl.felt
// CHECK-NEXT:    }
// CHECK-NEXT:  }

// -----

module attributes {pcl.prime = #pcl.prime<7>} {
  func.func @add() -> !pcl.felt {
    %0 = pcl.const 5
    %1 = pcl.const 10 
    %2 = pcl.add %0, %1 // 15 mod 7 = 1
    return %2 : !pcl.felt
  }
}

// CHECK-LABEL: module attributes {pcl.prime = #pcl.prime<7>} {
// CHECK-NEXT:    func.func @add() -> !pcl.felt {
// CHECK-NEXT:      %[[VAL_0:[0-9a-zA-Z_\.]+]] = pcl.const 1
// CHECK-NEXT:      return %[[VAL_0]] : !pcl.felt
// CHECK-NEXT:    }
// CHECK-NEXT:  }

// -----

module attributes {pcl.prime = #pcl.prime<7>} {
  func.func @add() -> !pcl.felt {
    %0 = pcl.const 0
    %1 = pcl.var "a" true
    %2 = pcl.add %0, %1
    return %2 : !pcl.felt
  }
}

// CHECK-LABEL: module attributes {pcl.prime = #pcl.prime<7>} {
// CHECK-NEXT:    func.func @add() -> !pcl.felt {

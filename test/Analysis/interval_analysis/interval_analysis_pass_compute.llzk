module attributes {llzk.lang} {
  struct.def @ArithSelectConstraint {
    struct.member @cond : i1
    struct.member @value : !felt.type

    function.def @compute(%a: !felt.type, %b: !felt.type) -> !struct.type<@ArithSelectConstraint> attributes {function.allow_non_native_field_ops} {
      %self = struct.new : !struct.type<@ArithSelectConstraint>

      %10 = felt.const 10
      %11 = felt.const 11
      %12 = felt.const 12
      %20 = felt.const 20
      %22 = felt.const 22

      %cmp0 = bool.cmp ge(%a, %10)
      bool.assert %cmp0
      %cmp1 = bool.cmp le(%a, %12)
      bool.assert %cmp1
      %cmp2 = bool.cmp ge(%b, %20)
      bool.assert %cmp2
      %cmp3 = bool.cmp le(%b, %22)
      bool.assert %cmp3

      %cond = bool.cmp le(%a, %11)
      %value = arith.select %cond, %a, %b : !felt.type
      %cmp4 = bool.cmp le(%value, %12)
      bool.assert %cmp4

      struct.writem %self[@cond] = %cond : <@ArithSelectConstraint>, i1
      struct.writem %self[@value] = %value : <@ArithSelectConstraint>, !felt.type

      function.return %self : !struct.type<@ArithSelectConstraint>
    }

    function.def @constrain(%self: !struct.type<@ArithSelectConstraint>, %a: !felt.type, %b: !felt.type) {
      function.return
    }
  }
}


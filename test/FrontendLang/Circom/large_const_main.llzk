// RUN: llzk-opt %s 2>&1 | FileCheck --enable-var-scope %s

//////////////////////////////////////////////////////////////////////////////////
// Circom source:
//
// template CompConstant(ct) {
//     signal input in;
//     signal output out;
//     out <== ct * in;
// }
//
// component main = CompConstant(10944121435919637611123202872628637544274182200208017171849102093287904247808);
//
//////////////////////////////////////////////////////////////////////////////////

module attributes {llzk.lang, llzk.main = !struct.type<@CompConstant::@CompConstant<[#felt<const 10944121435919637611123202872628637544274182200208017171849102093287904247808>]>>} {
  poly.template @CompConstant {
    poly.param @ct
    struct.def @CompConstant {
      struct.member @out : !felt.type<"bn128"> {llzk.pub}
      function.def @compute(%0: !felt.type<"bn128">) -> !struct.type<@CompConstant::@CompConstant<[@ct]>> attributes {function.allow_non_native_field_ops, function.allow_witness} {
        %1 = struct.new : <@CompConstant::@CompConstant<[@ct]>>
        %2 = poly.read_const @ct : !felt.type<"bn128">
        %3 = felt.mul %2, %0 : !felt.type<"bn128">, !felt.type<"bn128">
        struct.writem %1[@out] = %3 : <@CompConstant::@CompConstant<[@ct]>>, !felt.type<"bn128">
        function.return %1 : !struct.type<@CompConstant::@CompConstant<[@ct]>>
      }
      function.def @constrain(%4: !struct.type<@CompConstant::@CompConstant<[@ct]>>, %5: !felt.type<"bn128">) attributes {function.allow_constraint, function.allow_non_native_field_ops} {
        %6 = poly.read_const @ct : !felt.type<"bn128">
        %7 = struct.readm %4[@out] : <@CompConstant::@CompConstant<[@ct]>>, !felt.type<"bn128">
        %8 = felt.mul %6, %5 : !felt.type<"bn128">, !felt.type<"bn128">
        constrain.eq %7, %8 : !felt.type<"bn128">, !felt.type<"bn128">
        function.return
      }
    }
  }
}


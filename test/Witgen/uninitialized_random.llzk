// RUN: split-file %s %t
// RUN: llzk-witgen %t/test.llzk --inputs %t/input.json --uninitialized-behavior=random --uninitialized-seed=123 | FileCheck %s
// RUN: llzk-witgen %t/test.llzk --inputs %t/input.json --backend=execution-engine --uninitialized-behavior=random --uninitialized-seed=123 | FileCheck %s

//--- test.llzk

module attributes {llzk.lang, llzk.main = !struct.type<@Main>} {
  struct.def @Main {
    struct.member @out : !felt.type<"babybear"> {llzk.pub}
    function.def @compute() -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %x = llzk.nondet : !felt.type<"babybear">
      struct.writem %self[@out] = %x : !struct.type<@Main>, !felt.type<"babybear">
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>) {
      function.return
    }
  }
}

// CHECK: {
// CHECK-NEXT:   "out": "256824811"
// CHECK-NEXT: }

//--- input.json
{}

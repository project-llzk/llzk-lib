// RUN: split-file %s %t
// RUN: llzk-witgen %t/test.llzk --inputs %t/input.json --output-scope=full-witness | FileCheck %s
// RUN: llzk-witgen %t/test.llzk --inputs %t/input.json --backend=execution-engine --output-scope=full-witness | FileCheck %s

//--- test.llzk

module attributes {llzk.lang, llzk.main = !struct.type<@Main>} {
  struct.def @Main {
    struct.member @sum : !felt.type<"babybear"> {llzk.pub}
    function.def @compute(%lhs: !felt.type<"babybear">, %rhs: !felt.type<"babybear">) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %sum = felt.add %lhs, %rhs : !felt.type<"babybear">, !felt.type<"babybear">
      struct.writem %self[@sum] = %sum : !struct.type<@Main>, !felt.type<"babybear">
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(%self: !struct.type<@Main>, %lhs: !felt.type<"babybear">, %rhs: !felt.type<"babybear">) {
      function.return
    }
  }
}

// CHECK: {
// CHECK-NEXT:   "inputs": {
// CHECK-NEXT:     "arg0": "8",
// CHECK-NEXT:     "arg1": "13"
// CHECK-NEXT:   },
// CHECK-NEXT:   "signals": {
// CHECK-NEXT:     "sum": "21"
// CHECK-NEXT:   }
// CHECK-NEXT: }

//--- input.json
[8, 13]

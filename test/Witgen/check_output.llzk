// RUN: split-file %s %t
// RUN: llzk-witgen %t/test.llzk --inputs %t/input.json --check-output %t/public-expected.json
// RUN: llzk-witgen %t/test.llzk --inputs %t/input.json --backend=execution-engine --check-output %t/public-expected.json
// RUN: llzk-witgen %t/test.llzk --inputs %t/input.json --output-scope=full-witness --check-output %t/full-expected.json
// RUN: llzk-witgen %t/test.llzk --inputs %t/input.json --backend=execution-engine --output-scope=full-witness --check-output %t/full-expected.json
// RUN: llzk-witgen %t/test.llzk --inputs %t/input.json --check-output %t/negative-expected.json
// RUN: llzk-witgen %t/test.llzk --inputs %t/input.json --backend=execution-engine --check-output %t/negative-expected.json
// RUN: not llzk-witgen %t/test.llzk --inputs %t/input.json --check-output %t/mismatch.json 2>&1 | FileCheck %s --check-prefix=MISMATCH
// RUN: not llzk-witgen %t/test.llzk --inputs %t/input.json --check-output %t/bad.json 2>&1 | FileCheck %s --check-prefix=BADJSON
// RUN: not llzk-witgen %t/test.llzk --inputs %t/input.json --check-output %t/missing.json 2>&1 | FileCheck %s --check-prefix=MISSING

//--- test.llzk

module attributes {llzk.lang, llzk.main = !struct.type<@Main>} {
  struct.def @Main {
    struct.member @sum : !felt.type<"babybear"> {llzk.pub}
    struct.member @arr : !array.type<2 x !felt.type<"babybear">> {llzk.pub}
    struct.member @secret : !felt.type<"babybear"> {signal}
    function.def @compute(
      %lhs: !felt.type<"babybear"> {function.arg_name = "lhs"},
      %rhs: !felt.type<"babybear"> {function.arg_name = "rhs"}
    ) -> !struct.type<@Main> {
      %self = struct.new : !struct.type<@Main>
      %sum = felt.add %lhs, %rhs : !felt.type<"babybear">, !felt.type<"babybear">
      %arr = array.new %lhs, %rhs : <2 x !felt.type<"babybear">>
      struct.writem %self[@sum] = %sum : !struct.type<@Main>, !felt.type<"babybear">
      struct.writem %self[@arr] = %arr : !struct.type<@Main>, !array.type<2 x !felt.type<"babybear">>
      struct.writem %self[@secret] = %lhs : !struct.type<@Main>, !felt.type<"babybear">
      function.return %self : !struct.type<@Main>
    }
    function.def @constrain(
      %self: !struct.type<@Main>, %lhs: !felt.type<"babybear">, %rhs: !felt.type<"babybear">
    ) {
      function.return
    }
  }
}


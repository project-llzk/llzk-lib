module attributes {llzk.lang} {
  function.def @field_ops(%a: !felt.type<"bn128">, %b: !felt.type<"bn128">) {
    function.return
  }

  verif.contract @CheckFieldOps for @field_ops (%a: !felt.type<"bn128">, %b: !felt.type<"bn128">) {
    %sum = felt.add %a, %b : !felt.type<"bn128">, !felt.type<"bn128">
    %diff = felt.sub %a, %b : !felt.type<"bn128">, !felt.type<"bn128">
    %prod = felt.mul %sum, %diff : !felt.type<"bn128">, !felt.type<"bn128">
    %ok = bool.cmp eq(%prod, %prod) : !felt.type<"bn128">, !felt.type<"bn128">
    verif.ensure_compute %ok
  }
}

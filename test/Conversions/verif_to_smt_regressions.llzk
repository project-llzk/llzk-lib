// CHECK-NEXT: // -----
module attributes {llzk.lang} {
  struct.def @Box {
    struct.member @value : !felt.type {llzk.pub}

    function.def @compute(%x: !felt.type) -> !struct.type<@Box> {
      %self = struct.new : !struct.type<@Box>
      struct.writem %self[@value] = %x : !struct.type<@Box>, !felt.type
      function.return %self : !struct.type<@Box>
    }

    function.def @constrain(%self: !struct.type<@Box>, %x: !felt.type) {
      function.return
    }
  }

  function.def @observe_pair(%lhs: !struct.type<@Box>, %rhs: !struct.type<@Box>) {
    function.return
  }

  verif.contract @CheckPair for @observe_pair (%lhs: !struct.type<@Box>, %rhs: !struct.type<@Box>) {
    %lhs_value = struct.readm %lhs[@value] : !struct.type<@Box>, !felt.type
    %rhs_value = struct.readm %rhs[@value] : !struct.type<@Box>, !felt.type
    %ok = bool.cmp eq(%lhs_value, %rhs_value) : !felt.type, !felt.type
    verif.ensure_compute %ok
  }
}



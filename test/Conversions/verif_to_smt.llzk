// -----

module attributes {llzk.lang} {
  function.def @id_felt(%arg: !felt.type) -> !felt.type {
    function.return %arg : !felt.type
  }

  verif.contract @CheckIdFelt for @id_felt (%arg: !felt.type, %ret: !felt.type) {
    %true = arith.constant true
    verif.require_compute %true
    verif.require_constrain %true
    verif.ensure_compute %true
    verif.ensure_constrain %true
  }
}



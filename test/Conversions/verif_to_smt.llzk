// CHECK-NEXT:   function.def @select_value(%[[ARG0_12:[0-9A-Za-z_\.]+]]: !felt.type, %[[ARG1_11:[0-9A-Za-z_\.]+]]: !felt.type, %[[ARG2_9:[0-9A-Za-z_\.]+]]: i1) -> !felt.type {
// CHECK-NEXT:     %[[VAL_0_3:[0-9A-Za-z_\.]+]] = scf.if %[[ARG2_9]] -> (!felt.type) {
// CHECK-NEXT:       scf.yield %[[ARG0_12]] : !felt.type
// CHECK-NEXT:     } else {
// CHECK-NEXT:       scf.yield %[[ARG1_11]] : !felt.type
// CHECK-NEXT:     }
// CHECK-NEXT:     function.return %[[VAL_0_3]] : !felt.type
// CHECK-NEXT:   }
// CHECK-NEXT:   func.func @smt_select_value(%[[ARG0_13:[0-9A-Za-z_\.]+]]: !smt.int, %[[ARG1_12:[0-9A-Za-z_\.]+]]: !smt.int, %[[ARG2_10:[0-9A-Za-z_\.]+]]: !smt.bool) -> !smt.int {
// CHECK-NEXT:     %[[ITE:[0-9A-Za-z_\.]+]] = smt.ite %[[ARG2_10]], %[[ARG0_13]], %[[ARG1_12]] : !smt.int
// CHECK-NEXT:     return %[[ITE]] : !smt.int
// CHECK-NOT: scf.if


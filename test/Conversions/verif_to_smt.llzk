// CHECK-NEXT:       smt.assert %[[VAL_0_1]]
// CHECK-NEXT:     }
// CHECK-NEXT:     %[[VAL_2_1:[0-9A-Za-z_\.]+]] = call @smt_verif_CheckBox_target(%[[ARG0_5]], %[[ARG1_4]]) : (!smt.int, !smt.int) -> !smt.bool
// CHECK-NEXT:     smt.push 1

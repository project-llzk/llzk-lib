module attributes {llzk.lang} {
  poly.template @ScalarFeltOps {
    poly.param @shift

    struct.def @Box {
      struct.member @value : !felt.type<"bn128">

      function.def @compute(%x: !felt.type<"bn128">) -> !struct.type<@ScalarFeltOps::@Box<[@shift]>> {
        %self = struct.new : !struct.type<@ScalarFeltOps::@Box<[@shift]>>
        struct.writem %self[@value] = %x : !struct.type<@ScalarFeltOps::@Box<[@shift]>>, !felt.type<"bn128">
        function.return %self : !struct.type<@ScalarFeltOps::@Box<[@shift]>>
      }

      function.def @constrain(%self: !struct.type<@ScalarFeltOps::@Box<[@shift]>>, %x: !felt.type<"bn128">) {
        function.return
      }
    }

    verif.contract @FeltOps for @ScalarFeltOps::@Box (
        %self: !struct.type<@ScalarFeltOps::@Box<[@shift]>>, %x: !felt.type<"bn128">
    ) {
      %shift = poly.read_const @shift : !felt.type<"bn128">
      %a = felt.uintdiv %x, %shift : !felt.type<"bn128">, !felt.type<"bn128">
      %b = felt.umod %x, %shift : !felt.type<"bn128">, !felt.type<"bn128">
      %c = felt.sintdiv %x, %shift : !felt.type<"bn128">, !felt.type<"bn128">
      %d = felt.smod %x, %shift : !felt.type<"bn128">, !felt.type<"bn128">
      %e = felt.neg %x : !felt.type<"bn128">
      %f = felt.bit_and %x, %shift : !felt.type<"bn128">, !felt.type<"bn128">
      %g = felt.bit_or %x, %shift : !felt.type<"bn128">, !felt.type<"bn128">
      %h = felt.bit_xor %x, %shift : !felt.type<"bn128">, !felt.type<"bn128">
      %i = felt.bit_not %x : !felt.type<"bn128">
      %j = felt.shl %x, %shift : !felt.type<"bn128">, !felt.type<"bn128">
      %k = felt.shr %x, %shift : !felt.type<"bn128">, !felt.type<"bn128">
      %l = felt.pow %x, %shift : !felt.type<"bn128">, !felt.type<"bn128">
      %m = felt.div %x, %shift : !felt.type<"bn128">, !felt.type<"bn128">
      %n = felt.inv %shift : !felt.type<"bn128">
      %o = felt.add %a, %b : !felt.type<"bn128">, !felt.type<"bn128">
      %p = felt.add %o, %c : !felt.type<"bn128">, !felt.type<"bn128">
      %q = felt.add %p, %d : !felt.type<"bn128">, !felt.type<"bn128">
      %r = felt.add %q, %e : !felt.type<"bn128">, !felt.type<"bn128">
      %s = felt.add %r, %f : !felt.type<"bn128">, !felt.type<"bn128">
      %t = felt.add %s, %g : !felt.type<"bn128">, !felt.type<"bn128">
      %u = felt.add %t, %h : !felt.type<"bn128">, !felt.type<"bn128">
      %v = felt.add %u, %i : !felt.type<"bn128">, !felt.type<"bn128">
      %w = felt.add %v, %j : !felt.type<"bn128">, !felt.type<"bn128">
      %x2 = felt.add %w, %k : !felt.type<"bn128">, !felt.type<"bn128">
      %y2 = felt.add %x2, %l : !felt.type<"bn128">, !felt.type<"bn128">
      %z2 = felt.add %y2, %m : !felt.type<"bn128">, !felt.type<"bn128">
      %sum = felt.add %z2, %n : !felt.type<"bn128">, !felt.type<"bn128">
      %ok = bool.cmp eq(%sum, %sum) : !felt.type<"bn128">, !felt.type<"bn128">
      verif.ensure_compute %ok
    }
  }
}


// CHECK: smt.int.div
// CHECK: smt.int.mod
// CHECK: smt.int.neg
// CHECK: smt.int2bv
// CHECK: smt.bv.and
// CHECK: smt.bv.or
// CHECK: smt.bv.xor
// CHECK: smt.bv.not
// CHECK: smt.bv.shl
// CHECK: smt.bv.lshr
// CHECK-NOT: smt.bv2int {{.*}} signed
// CHECK: smt.declare_fun "felt_div_
// CHECK: smt.declare_fun "felt_inv_
// CHECK: func.func @smt_verif_FeltOps_target(%[[TARGET_SELF:[0-9A-Za-z_\.]+]]: !smt.int, %[[TARGET_X:[0-9A-Za-z_\.]+]]: !smt.int, %[[TARGET_SHIFT:[0-9A-Za-z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK: call @smt_Box_compute(%[[TARGET_X]], %[[TARGET_SHIFT]])
// CHECK: func.func @smt_verif_FeltOps_entry(
// CHECK: return
// CHECK-NOT: felt.
// CHECK-NOT: poly.read_const


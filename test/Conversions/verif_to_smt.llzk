module attributes {llzk.lang} {
  function.def @leaf_target(%gate: i1) {
    function.return
  }

  function.def @wrapper_target(%gate: i1) {
    function.return
  }

  verif.contract @Leaf for @leaf_target (%gate: i1) {
    verif.require_compute %gate
  }

  verif.contract @Wrapper for @wrapper_target (%gate: i1) {
    verif.include @Leaf(%gate) : (i1) -> ()
  }
}


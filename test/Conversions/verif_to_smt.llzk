module attributes {llzk.lang} {
  function.def @leaf_gate(%gate: i1) {
    function.return
  }

  function.def @middle_gate(%gate: i1) {
    function.return
  }

  function.def @top_gate(%gate: i1) {
    function.return
  }

  verif.contract @LeafGate for @leaf_gate (%gate: i1) {
    verif.require_compute %gate
  }

  verif.contract @MiddleGate for @middle_gate (%gate: i1) {
    verif.include @LeafGate(%gate) : (i1) -> ()
    verif.ensure_compute %gate
  }

  verif.contract @TopGate for @top_gate (%gate: i1) {
    verif.include @MiddleGate(%gate) : (i1) -> ()
    verif.require_compute %gate
    verif.ensure_compute %gate
  }
}


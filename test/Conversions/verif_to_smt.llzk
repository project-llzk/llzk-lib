module attributes {llzk.lang} {
  function.def @select_value(%a: !felt.type, %b: !felt.type, %gate: i1) -> !felt.type {
    %selected = scf.if %gate -> (!felt.type) {
      scf.yield %a : !felt.type
    } else {
      scf.yield %b : !felt.type
    }
    function.return %selected : !felt.type
  }

  verif.contract @ResultIfTarget for @select_value (%a: !felt.type, %b: !felt.type, %gate: i1, %ret_value: !felt.type) {
    %ok = arith.constant true
    verif.ensure_compute %ok
  }
}


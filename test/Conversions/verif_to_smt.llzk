module attributes {llzk.lang} {
  function.def @check_nested_guard(%outer: i1, %inner: i1) {
    function.return
  }

  verif.contract @NestedGuardedPre for @check_nested_guard (%outer: i1, %inner: i1) {
    %true = arith.constant true
    scf.if %outer {
      scf.if %inner {
        verif.require_compute %true
      }
    }
  }
}


module attributes {llzk.lang} {
  struct.def @Pair {
    struct.member @left : !felt.type
    struct.member @right : !felt.type

    function.def @compute(%x: !felt.type, %y: !felt.type) -> !struct.type<@Pair> {
      %self = struct.new : !struct.type<@Pair>
      struct.writem %self[@left] = %x : !struct.type<@Pair>, !felt.type
      struct.writem %self[@right] = %y : !struct.type<@Pair>, !felt.type
      function.return %self : !struct.type<@Pair>
    }

    function.def @constrain(%self: !struct.type<@Pair>, %x: !felt.type, %y: !felt.type) {
      function.return
    }
  }

  verif.contract @CheckPair for @Pair (%self: !struct.type<@Pair>, %x: !felt.type, %y: !felt.type) {
    %left = struct.readm %self[@left] : !struct.type<@Pair>, !felt.type
    %right = struct.readm %self[@right] : !struct.type<@Pair>, !felt.type
    %left_ok = bool.cmp eq(%left, %x) : !felt.type, !felt.type
    %right_ok = bool.cmp eq(%right, %y) : !felt.type, !felt.type
    verif.ensure_compute %left_ok
    verif.ensure_constrain %right_ok
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_Pair_compute(%[[PAIR_X:[0-9a-zA-Z_\.]+]]: !smt.int, %[[PAIR_Y:[0-9a-zA-Z_\.]+]]: !smt.int) -> (!smt.int, !smt.int) {
// CHECK:   return %[[PAIR_X]], %[[PAIR_Y]] : !smt.int, !smt.int
// CHECK: }
// CHECK: func.func @smt_Pair_constrain(%[[SELF_LEFT:[0-9a-zA-Z_\.]+]]: !smt.int, %[[SELF_RIGHT:[0-9a-zA-Z_\.]+]]: !smt.int, %[[PAIR_ARG_X:[0-9a-zA-Z_\.]+]]: !smt.int, %[[PAIR_ARG_Y:[0-9a-zA-Z_\.]+]]: !smt.int) -> (!smt.int, !smt.int) {
// CHECK:   return %[[SELF_LEFT]], %[[SELF_RIGHT]] : !smt.int, !smt.int
// CHECK: }
// CHECK: func.func @smt_verif_CheckPair_pre(%[[PRE_LEFT:[0-9a-zA-Z_\.]+]]: !smt.int, %[[PRE_RIGHT:[0-9a-zA-Z_\.]+]]: !smt.int, %[[PRE_X:[0-9a-zA-Z_\.]+]]: !smt.int, %[[PRE_Y:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[PRE_TRUE:[0-9a-zA-Z_\.]+]] = smt.constant true
// CHECK:   return %[[PRE_TRUE]] : !smt.bool
// CHECK: }
// CHECK: func.func @smt_verif_CheckPair_post(%[[POST_LEFT:[0-9a-zA-Z_\.]+]]: !smt.int, %[[POST_RIGHT:[0-9a-zA-Z_\.]+]]: !smt.int, %[[POST_X:[0-9a-zA-Z_\.]+]]: !smt.int, %[[POST_Y:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[POST_LEFT_EQ:[0-9a-zA-Z_\.]+]] = smt.eq %[[POST_LEFT]], %[[POST_X]] : !smt.int
// CHECK:   %[[POST_EQ:[0-9a-zA-Z_\.]+]] = smt.eq %[[POST_RIGHT]], %[[POST_Y]] : !smt.int
// CHECK:   %[[POST_AND:[0-9a-zA-Z_\.]+]] = smt.and %[[POST_LEFT_EQ]], %[[POST_EQ]]
// CHECK:   return %[[POST_AND]] : !smt.bool
// CHECK: }
// CHECK: func.func @smt_verif_CheckPair_target(%[[TARGET_LEFT:[0-9a-zA-Z_\.]+]]: !smt.int, %[[TARGET_RIGHT:[0-9a-zA-Z_\.]+]]: !smt.int, %[[TARGET_X:[0-9a-zA-Z_\.]+]]: !smt.int, %[[TARGET_Y:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[PAIR_COMP:[0-9a-zA-Z_\.]+]]:2 = call @smt_Pair_compute(%[[TARGET_X]], %[[TARGET_Y]]) : (!smt.int, !smt.int) -> (!smt.int, !smt.int)
// CHECK:   %[[PAIR_COMP_EQ0:[0-9a-zA-Z_\.]+]] = smt.eq %[[PAIR_COMP]]#0, %[[TARGET_LEFT]] : !smt.int
// CHECK:   %[[PAIR_COMP_EQ1:[0-9a-zA-Z_\.]+]] = smt.eq %[[PAIR_COMP]]#1, %[[TARGET_RIGHT]] : !smt.int
// CHECK:   %[[PAIR_CONSTR:[0-9a-zA-Z_\.]+]]:2 = call @smt_Pair_constrain(%[[TARGET_LEFT]], %[[TARGET_RIGHT]], %[[TARGET_X]], %[[TARGET_Y]]) : (!smt.int, !smt.int, !smt.int, !smt.int) -> (!smt.int, !smt.int)
// CHECK:   %[[PAIR_CONSTR_EQ0:[0-9a-zA-Z_\.]+]] = smt.eq %[[PAIR_CONSTR]]#0, %[[TARGET_LEFT]] : !smt.int
// CHECK:   %[[PAIR_CONSTR_EQ1:[0-9a-zA-Z_\.]+]] = smt.eq %[[PAIR_CONSTR]]#1, %[[TARGET_RIGHT]] : !smt.int
// CHECK:   %[[PAIR_AND0:[0-9a-zA-Z_\.]+]] = smt.and %[[PAIR_COMP_EQ0]], %[[PAIR_COMP_EQ1]]
// CHECK:   %[[PAIR_AND1:[0-9a-zA-Z_\.]+]] = smt.and %[[PAIR_AND0]], %[[PAIR_CONSTR_EQ0]]
// CHECK:   %[[PAIR_AND2:[0-9a-zA-Z_\.]+]] = smt.and %[[PAIR_AND1]], %[[PAIR_CONSTR_EQ1]]
// CHECK:   return %[[PAIR_AND2]] : !smt.bool
// CHECK: }


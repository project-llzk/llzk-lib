// CHECK: }
// CHECK: func.func @smt_verif_CheckOuter_post(%[[OUTER_POST_INNER:[0-9a-zA-Z_\.]+]]: !struct.type<@Inner>, %[[OUTER_POST_FLAG:[0-9a-zA-Z_\.]+]]: !smt.int, %[[OUTER_POST_EXPECTED:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[OUTER_EQ:[0-9a-zA-Z_\.]+]] = smt.eq %[[OUTER_POST_FLAG]], %[[OUTER_POST_EXPECTED]] : !smt.int
// CHECK:   return %[[OUTER_EQ]] : !smt.bool
// CHECK: }
// CHECK: func.func @smt_verif_CheckOuter_target(%[[OUTER_TARGET_INNER:[0-9a-zA-Z_\.]+]]: !struct.type<@Inner>, %[[OUTER_TARGET_FLAG:[0-9a-zA-Z_\.]+]]: !smt.int, %[[OUTER_TARGET_EXPECTED:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   call @smt_observe_outer(%[[OUTER_TARGET_INNER]], %[[OUTER_TARGET_FLAG]], %[[OUTER_TARGET_EXPECTED]]) : (!struct.type<@Inner>, !smt.int, !smt.int) -> ()
// CHECK:   %[[OUTER_TARGET_TRUE:[0-9a-zA-Z_\.]+]] = smt.constant true

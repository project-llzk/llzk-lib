module attributes {llzk.lang} {
  struct.def @Inner {
    struct.member @value : !felt.type

    function.def @compute() -> !struct.type<@Inner> {
      %self = struct.new : !struct.type<@Inner>
      function.return %self : !struct.type<@Inner>
    }

    function.def @constrain(%self: !struct.type<@Inner>) {
      function.return
    }
  }

  struct.def @Outer {
    struct.member @inner : !struct.type<@Inner>
    struct.member @flag : !felt.type {llzk.pub}

    function.def @compute() -> !struct.type<@Outer> {
      %self = struct.new : !struct.type<@Outer>
      function.return %self : !struct.type<@Outer>
    }

    function.def @constrain(%self: !struct.type<@Outer>) {
      function.return
    }
  }

  function.def @observe_outer(%self: !struct.type<@Outer>, %expected: !felt.type) {
    function.return
  }

  verif.contract @CheckOuter for @observe_outer (%self: !struct.type<@Outer>, %expected: !felt.type) {
    %flag = struct.readm %self[@flag] : !struct.type<@Outer>, !felt.type
    %flag_ok = bool.cmp eq(%flag, %expected) : !felt.type, !felt.type
    verif.ensure_compute %flag_ok
  }
}


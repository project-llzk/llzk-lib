module attributes {llzk.lang} {
  function.def @first_leaf(%lhs: i1) {
    function.return
  }

  function.def @second_leaf(%rhs: i1) {
    function.return
  }

  function.def @multi_include_target(%lhs: i1, %rhs: i1) {
    function.return
  }

  verif.contract @FirstLeaf for @first_leaf (%lhs: i1) {
    verif.require_compute %lhs
  }

  verif.contract @SecondLeaf for @second_leaf (%rhs: i1) {
    verif.ensure_compute %rhs
  }

  verif.contract @MultiInclude for @multi_include_target (%lhs: i1, %rhs: i1) {
    verif.include @FirstLeaf(%lhs) : (i1) -> ()
    verif.include @SecondLeaf(%rhs) : (i1) -> ()
  }
}


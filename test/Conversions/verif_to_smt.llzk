module attributes {llzk.lang} {
  function.def @check_guard_else(%gate: i1, %fallback: i1) {
    function.return
  }

  verif.contract @GuardedPreElse for @check_guard_else (%gate: i1, %fallback: i1) {
    %true = arith.constant true
    scf.if %gate {
      verif.require_compute %true
    } else {
      verif.require_compute %fallback
    }
  }
}


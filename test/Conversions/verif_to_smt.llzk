// RUN: llzk-opt --llzk-scalar-verif-to-smt %s -split-input-file | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
  struct.def @Box {
    struct.member @value : !felt.type

    function.def @compute(%x: !felt.type) -> !struct.type<@Box> {
      %self = struct.new : !struct.type<@Box>
      struct.writem %self[@value] = %x : !struct.type<@Box>, !felt.type
      function.return %self : !struct.type<@Box>
    }

    function.def @constrain(%self: !struct.type<@Box>, %x: !felt.type) {
      function.return
    }
  }

  verif.contract @CheckBox for @Box (%self: !struct.type<@Box>, %x: !felt.type) {
    %ok = arith.constant true
    verif.require_compute %ok
    verif.ensure_compute %ok
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_Box_compute(%[[X:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.int {
// CHECK:   return %[[X]] : !smt.int
// CHECK: }
// CHECK: func.func @smt_Box_constrain(%[[SELF_VALUE:[0-9a-zA-Z_\.]+]]: !smt.int, %[[ARG:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.int {
// CHECK:   return %[[SELF_VALUE]] : !smt.int
// CHECK: }
// CHECK: func.func @smt_verif_CheckBox_pre(%[[PRE_SELF:[0-9a-zA-Z_\.]+]]: !smt.int, %[[PRE_ARG:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[TRUE0:[0-9a-zA-Z_\.]+]] = smt.constant true
// CHECK:   return %[[TRUE0]] : !smt.bool
// CHECK: }
// CHECK: func.func @smt_verif_CheckBox_post(%[[POST_SELF:[0-9a-zA-Z_\.]+]]: !smt.int, %[[POST_ARG:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[TRUE1:[0-9a-zA-Z_\.]+]] = smt.constant true
// CHECK:   return %[[TRUE1]] : !smt.bool
// CHECK: }
// CHECK: func.func @smt_verif_CheckBox_target(%[[TARGET_SELF:[0-9a-zA-Z_\.]+]]: !smt.int, %[[TARGET_ARG:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[BOX_COMPUTED:[0-9a-zA-Z_\.]+]] = call @smt_Box_compute(%[[TARGET_ARG]]) : (!smt.int) -> !smt.int
// CHECK:   %[[BOX_EQ:[0-9a-zA-Z_\.]+]] = smt.eq %[[BOX_COMPUTED]], %[[TARGET_SELF]] : !smt.int
// CHECK:   return %[[BOX_EQ]] : !smt.bool
// CHECK: }
// CHECK-NOT: verif.contract


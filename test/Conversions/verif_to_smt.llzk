// -----

module attributes {llzk.lang} {
  function.def @leaf(%gate: i1) {
    function.return
  }

  function.def @wrapper(%gate: i1) {
    function.return
  }

  verif.contract @Leaf for @leaf (%gate: i1) {
    %ok = arith.constant true
    verif.ensure_compute %ok
  }

  verif.contract @Wrapper for @wrapper (%gate: i1) {
    verif.include @Leaf(%gate) : (i1) -> ()
  }
}



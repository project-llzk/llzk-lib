// CHECK-NEXT:   func.func @smt_Box_compute(%[[ARG0:[0-9A-Za-z_\.]+]]: !smt.int) -> !smt.int {
// CHECK-NEXT:     return %[[ARG0]] : !smt.int
// CHECK-NEXT:   }
// CHECK-NEXT:   func.func @smt_Box_constrain(%[[ARG0_1:[0-9A-Za-z_\.]+]]: !smt.int, %[[ARG1:[0-9A-Za-z_\.]+]]: !smt.int) -> !smt.int {
// CHECK-NEXT:     return %[[ARG0_1]] : !smt.int
// CHECK-NEXT:   }
// CHECK-NEXT:   func.func @smt_verif_CheckBox_pre(%[[ARG0_2:[0-9A-Za-z_\.]+]]: !smt.int, %[[ARG1_1:[0-9A-Za-z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK-NEXT:     %[[TRUE:[0-9A-Za-z_\.]+]] = smt.constant true
// CHECK-NEXT:     return %[[TRUE]] : !smt.bool
// CHECK-NEXT:   }
// CHECK-NEXT:   func.func @smt_verif_CheckBox_post(%[[ARG0_3:[0-9A-Za-z_\.]+]]: !smt.int, %[[ARG1_2:[0-9A-Za-z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK-NEXT:     %[[TRUE_1:[0-9A-Za-z_\.]+]] = smt.constant true
// CHECK-NEXT:     return %[[TRUE_1]] : !smt.bool
// CHECK-NEXT:   }
// CHECK-NEXT:   func.func @smt_verif_CheckBox_target(%[[ARG0_4:[0-9A-Za-z_\.]+]]: !smt.int, %[[ARG1_3:[0-9A-Za-z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK-NEXT:     %[[VAL_0:[0-9A-Za-z_\.]+]] = call @smt_Box_compute(%[[ARG1_3]]) : (!smt.int) -> !smt.int
// CHECK-NEXT:     %[[VAL_1:[0-9A-Za-z_\.]+]] = smt.eq %[[VAL_0]], %[[ARG0_4]] : !smt.int
// CHECK-NEXT:     %[[VAL_2:[0-9A-Za-z_\.]+]] = call @smt_Box_constrain(%[[ARG0_4]], %[[ARG1_3]]) : (!smt.int, !smt.int) -> !smt.int
// CHECK-NEXT:     %[[VAL_3:[0-9A-Za-z_\.]+]] = smt.eq %[[VAL_2]], %[[ARG0_4]] : !smt.int
// CHECK-NEXT:     %[[VAL_4:[0-9A-Za-z_\.]+]] = smt.and %[[VAL_1]], %[[VAL_3]]
// CHECK-NEXT:     return %[[VAL_4]] : !smt.bool
// CHECK-NEXT:   }
// CHECK-NEXT:   func.func @smt_verif_CheckBox_entry(%[[ARG0_5:[0-9A-Za-z_\.]+]]: !smt.int, %[[ARG1_4:[0-9A-Za-z_\.]+]]: !smt.int) {

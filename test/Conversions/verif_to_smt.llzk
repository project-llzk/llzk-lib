// RUN: llzk-opt --llzk-scalar-verif-to-smt %s -split-input-file | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
  struct.def @Box {
    struct.member @value : !felt.type

    function.def @compute(%x: !felt.type) -> !struct.type<@Box> {
      %self = struct.new : !struct.type<@Box>
      struct.writem %self[@value] = %x : !struct.type<@Box>, !felt.type
      function.return %self : !struct.type<@Box>
    }

    function.def @constrain(%self: !struct.type<@Box>, %x: !felt.type) {
      function.return
    }
  }

  verif.contract @CheckBox for @Box (%self: !struct.type<@Box>, %x: !felt.type) {
    %ok = arith.constant true
    verif.require_compute %ok
    verif.ensure_compute %ok
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_verif_CheckBox_target(%[[SELF:[0-9a-zA-Z_\.]+]]: !smt.int, %[[ARG:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[BOX_COMPUTED:[0-9a-zA-Z_\.]+]] = call @smt_Box_compute(%[[ARG]]) : (!smt.int) -> !smt.int
// CHECK:   %[[BOX_EQ:[0-9a-zA-Z_\.]+]] = smt.eq %[[BOX_COMPUTED]], %[[SELF]] : !smt.int
// CHECK:   return %[[BOX_EQ]] : !smt.bool
// CHECK: }
// CHECK: func.func @smt_verif_CheckBox_entry(%[[ENTRY_SELF:[0-9a-zA-Z_\.]+]]: !smt.int, %[[ENTRY_ARG:[0-9a-zA-Z_\.]+]]: !smt.int) {
// CHECK:   %[[PRE:[0-9a-zA-Z_\.]+]] = call @smt_verif_CheckBox_pre(%[[ENTRY_SELF]], %[[ENTRY_ARG]]) : (!smt.int, !smt.int) -> !smt.bool
// CHECK:   smt.push 1
// CHECK:   %[[NOT_PRE:[0-9a-zA-Z_\.]+]] = smt.not %[[PRE]]
// CHECK:   smt.assert %[[NOT_PRE]]
// CHECK:   smt.check sat {
// CHECK:     smt.pop 1
// CHECK:   } unknown {
// CHECK:     smt.pop 1
// CHECK:   } unsat {
// CHECK:     smt.pop 1
// CHECK:     smt.assert %[[PRE]]
// CHECK:   }
// CHECK:   %[[TARGET:[0-9a-zA-Z_\.]+]] = call @smt_verif_CheckBox_target(%[[ENTRY_SELF]], %[[ENTRY_ARG]]) : (!smt.int, !smt.int) -> !smt.bool
// CHECK:   %[[POST:[0-9a-zA-Z_\.]+]] = call @smt_verif_CheckBox_post(%[[ENTRY_SELF]], %[[ENTRY_ARG]]) : (!smt.int, !smt.int) -> !smt.bool
// CHECK:   return
// CHECK: }
// CHECK-NOT: verif.contract

// -----

module attributes {llzk.lang} {
  function.def @same(%a: !felt.type) -> !felt.type {
    function.return %a : !felt.type
  }

  verif.contract @CheckSame for @same (%a: !felt.type, %ret_value: !felt.type) {
    %ok = arith.constant true
    verif.ensure_compute %ok
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_verif_CheckSame_target(%[[TARGET_IN:[0-9a-zA-Z_\.]+]]: !smt.int, %[[TARGET_RET:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[SAME_RET:[0-9a-zA-Z_\.]+]] = call @smt_same(%[[TARGET_IN]]) : (!smt.int) -> !smt.int
// CHECK:   %[[SAME_EQ:[0-9a-zA-Z_\.]+]] = smt.eq %[[SAME_RET]], %[[TARGET_RET]] : !smt.int
// CHECK:   return %[[SAME_EQ]] : !smt.bool
// CHECK: }
// CHECK: func.func @smt_verif_CheckSame_entry(
// CHECK:   smt.check sat {
// CHECK:   } unknown {
// CHECK:   } unsat {
// CHECK:   }
// CHECK: }

// -----

module attributes {llzk.lang} {
  function.def @leaf_target(%gate: i1) {
    function.return
  }

  function.def @wrapper_target(%gate: i1) {
    function.return
  }

  verif.contract @Leaf for @leaf_target (%gate: i1) {
    verif.require_compute %gate
  }

  verif.contract @Wrapper for @wrapper_target (%gate: i1) {
    verif.include @Leaf(%gate) : (i1) -> ()
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_verif_Leaf_entry(%[[LEAF_GATE:[0-9a-zA-Z_\.]+]]: !smt.bool) {
// CHECK:   %[[LEAF_PRE:[0-9a-zA-Z_\.]+]] = call @smt_verif_Leaf_pre(%[[LEAF_GATE]]) : (!smt.bool) -> !smt.bool
// CHECK:   smt.push 1
// CHECK:   %[[LEAF_NOT_PRE:[0-9a-zA-Z_\.]+]] = smt.not %[[LEAF_PRE]]
// CHECK:   smt.assert %[[LEAF_NOT_PRE]]
// CHECK:   smt.check sat {
// CHECK:   } unknown {
// CHECK:   } unsat {
// CHECK:     smt.assert %[[LEAF_PRE]]
// CHECK:   }
// CHECK: }
// CHECK: func.func @smt_verif_Wrapper_include_0(%[[WRAP_INCLUDE_GATE:[0-9a-zA-Z_\.]+]]: !smt.bool) {
// CHECK:   call @smt_verif_Leaf_entry(%[[WRAP_INCLUDE_GATE]]) : (!smt.bool) -> ()
// CHECK:   return
// CHECK: }
// CHECK: func.func @smt_verif_Wrapper_entry(%[[WRAP_GATE:[0-9a-zA-Z_\.]+]]: !smt.bool) {
// CHECK:   call @smt_verif_Wrapper_include_0(%[[WRAP_GATE]]) : (!smt.bool) -> ()
// CHECK:   return
// CHECK: }

// -----

module attributes {llzk.lang} {
  struct.def @Pair {
    struct.member @left : !felt.type
    struct.member @right : !felt.type

    function.def @compute(%x: !felt.type, %y: !felt.type) -> !struct.type<@Pair> {
      %self = struct.new : !struct.type<@Pair>
      struct.writem %self[@left] = %x : !struct.type<@Pair>, !felt.type
      struct.writem %self[@right] = %y : !struct.type<@Pair>, !felt.type
      function.return %self : !struct.type<@Pair>
    }

    function.def @constrain(%self: !struct.type<@Pair>, %x: !felt.type, %y: !felt.type) {
      function.return
    }
  }

  verif.contract @CheckPair for @Pair (%self: !struct.type<@Pair>, %x: !felt.type, %y: !felt.type) {
    %left = struct.readm %self[@left] : !struct.type<@Pair>, !felt.type
    %right = struct.readm %self[@right] : !struct.type<@Pair>, !felt.type
    %left_ok = bool.cmp eq(%left, %x) : !felt.type, !felt.type
    %right_ok = bool.cmp eq(%right, %y) : !felt.type, !felt.type
    verif.ensure_compute %left_ok
    verif.ensure_constrain %right_ok
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_verif_CheckPair_target(%[[LEFT:[0-9a-zA-Z_\.]+]]: !smt.int, %[[RIGHT:[0-9a-zA-Z_\.]+]]: !smt.int, %[[X:[0-9a-zA-Z_\.]+]]: !smt.int, %[[Y:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[PAIR_COMP:[0-9a-zA-Z_\.]+]]:2 = call @smt_Pair_compute(%[[X]], %[[Y]]) : (!smt.int, !smt.int) -> (!smt.int, !smt.int)
// CHECK:   %[[PAIR_CONSTR:[0-9a-zA-Z_\.]+]]:2 = call @smt_Pair_constrain(%[[LEFT]], %[[RIGHT]], %[[X]], %[[Y]]) : (!smt.int, !smt.int, !smt.int, !smt.int) -> (!smt.int, !smt.int)
// CHECK:   %[[PAIR_AND2:[0-9a-zA-Z_\.]+]] = smt.and
// CHECK:   return %{{[0-9a-zA-Z_\.]+}} : !smt.bool
// CHECK: }
// CHECK: func.func @smt_verif_CheckPair_entry(
// CHECK:   %[[PAIR_POST:[0-9a-zA-Z_\.]+]] = call @smt_verif_CheckPair_post
// CHECK:   smt.push 1
// CHECK:   %[[PAIR_NOT_POST:[0-9a-zA-Z_\.]+]] = smt.not %[[PAIR_POST]]
// CHECK:   smt.assert %[[PAIR_NOT_POST]]
// CHECK: }

// -----

module attributes {llzk.lang} {
  struct.def @Inner {
    struct.member @value : !felt.type

    function.def @compute() -> !struct.type<@Inner> {
      %self = struct.new : !struct.type<@Inner>
      function.return %self : !struct.type<@Inner>
    }

    function.def @constrain(%self: !struct.type<@Inner>) {
      function.return
    }
  }

  struct.def @Outer {
    struct.member @inner : !struct.type<@Inner>
    struct.member @flag : !felt.type {llzk.pub}

    function.def @compute() -> !struct.type<@Outer> {
      %self = struct.new : !struct.type<@Outer>
      function.return %self : !struct.type<@Outer>
    }

    function.def @constrain(%self: !struct.type<@Outer>) {
      function.return
    }
  }

  function.def @observe_outer(%self: !struct.type<@Outer>, %expected: !felt.type) {
    function.return
  }

  verif.contract @CheckOuter for @observe_outer (%self: !struct.type<@Outer>, %expected: !felt.type) {
    %flag = struct.readm %self[@flag] : !struct.type<@Outer>, !felt.type
    %flag_ok = bool.cmp eq(%flag, %expected) : !felt.type, !felt.type
    verif.ensure_compute %flag_ok
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_verif_CheckOuter_entry(%[[INNER:[0-9a-zA-Z_\.]+]]: !struct.type<@Inner>, %[[FLAG:[0-9a-zA-Z_\.]+]]: !smt.int, %[[EXPECTED:[0-9a-zA-Z_\.]+]]: !smt.int) {
// CHECK:   %[[OUTER_POST:[0-9a-zA-Z_\.]+]] = call @smt_verif_CheckOuter_post(%[[INNER]], %[[FLAG]], %[[EXPECTED]]) : (!struct.type<@Inner>, !smt.int, !smt.int) -> !smt.bool
// CHECK:   %[[OUTER_NOT_POST:[0-9a-zA-Z_\.]+]] = smt.not %[[OUTER_POST]]
// CHECK:   smt.assert %[[OUTER_NOT_POST]]
// CHECK:   return
// CHECK: }

// -----

module attributes {llzk.lang} {
  function.def @leaf_gate(%gate: i1) {
    function.return
  }

  function.def @middle_gate(%gate: i1) {
    function.return
  }

  function.def @top_gate(%gate: i1) {
    function.return
  }

  verif.contract @LeafGate for @leaf_gate (%gate: i1) {
    verif.require_compute %gate
  }

  verif.contract @MiddleGate for @middle_gate (%gate: i1) {
    verif.include @LeafGate(%gate) : (i1) -> ()
    verif.ensure_compute %gate
  }

  verif.contract @TopGate for @top_gate (%gate: i1) {
    verif.include @MiddleGate(%gate) : (i1) -> ()
    verif.require_compute %gate
    verif.ensure_compute %gate
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_verif_MiddleGate_include_0(%[[MID_GATE:[0-9a-zA-Z_\.]+]]: !smt.bool) {
// CHECK:   call @smt_verif_LeafGate_entry(%[[MID_GATE]]) : (!smt.bool) -> ()
// CHECK:   return
// CHECK: }
// CHECK: func.func @smt_verif_TopGate_include_0(%[[TOP_GATE:[0-9a-zA-Z_\.]+]]: !smt.bool) {
// CHECK:   call @smt_verif_MiddleGate_entry(%[[TOP_GATE]]) : (!smt.bool) -> ()
// CHECK:   return
// CHECK: }
// CHECK: func.func @smt_verif_TopGate_entry(%[[TOP_ENTRY_GATE:[0-9a-zA-Z_\.]+]]: !smt.bool) {
// CHECK:   call @smt_verif_TopGate_include_0(%[[TOP_ENTRY_GATE]]) : (!smt.bool) -> ()
// CHECK:   return
// CHECK: }

// -----

module attributes {llzk.lang} {
  function.def @first_leaf(%lhs: i1) {
    function.return
  }

  function.def @second_leaf(%rhs: i1) {
    function.return
  }

  function.def @multi_include_target(%lhs: i1, %rhs: i1) {
    function.return
  }

  verif.contract @FirstLeaf for @first_leaf (%lhs: i1) {
    verif.require_compute %lhs
  }

  verif.contract @SecondLeaf for @second_leaf (%rhs: i1) {
    verif.ensure_compute %rhs
  }

  verif.contract @MultiInclude for @multi_include_target (%lhs: i1, %rhs: i1) {
    verif.include @FirstLeaf(%lhs) : (i1) -> ()
    verif.include @SecondLeaf(%rhs) : (i1) -> ()
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_verif_MultiInclude_include_0(%[[LHS:[0-9a-zA-Z_\.]+]]: !smt.bool) {
// CHECK:   call @smt_verif_FirstLeaf_entry(%[[LHS]]) : (!smt.bool) -> ()
// CHECK:   return
// CHECK: }
// CHECK: func.func @smt_verif_MultiInclude_include_1(%[[RHS:[0-9a-zA-Z_\.]+]]: !smt.bool) {
// CHECK:   call @smt_verif_SecondLeaf_entry(%[[RHS]]) : (!smt.bool) -> ()
// CHECK:   return
// CHECK: }
// CHECK: func.func @smt_verif_MultiInclude_entry(%[[ENTRY_LHS:[0-9a-zA-Z_\.]+]]: !smt.bool, %[[ENTRY_RHS:[0-9a-zA-Z_\.]+]]: !smt.bool) {
// CHECK:   call @smt_verif_MultiInclude_include_0(%[[ENTRY_LHS]]) : (!smt.bool) -> ()
// CHECK:   call @smt_verif_MultiInclude_include_1(%[[ENTRY_RHS]]) : (!smt.bool) -> ()
// CHECK:   return
// CHECK: }

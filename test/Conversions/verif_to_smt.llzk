// CHECK-NEXT:     %[[VAL_1_1:[0-9A-Za-z_\.]+]] = smt.not %[[VAL_0_1]]
// CHECK-NEXT:     smt.assert %[[VAL_1_1]]
// CHECK-NEXT:     smt.check sat {
// CHECK-NEXT:       smt.pop 1
// CHECK-NEXT:       %[[FALSE:[0-9A-Za-z_\.]+]] = arith.constant false
// CHECK-NEXT:       bool.assert %[[FALSE]], "verification failed in CheckBox pre: counterexample found"
// CHECK-NEXT:     } unknown {
// CHECK-NEXT:       smt.pop 1
// CHECK-NEXT:       %[[FALSE_1:[0-9A-Za-z_\.]+]] = arith.constant false
// CHECK-NEXT:       bool.assert %[[FALSE_1]], "verification failed in CheckBox pre: condition unprovable"
// CHECK-NEXT:     } unsat {

module attributes {llzk.lang} {
  function.def @same(%a: !felt.type) -> !felt.type {
    function.return %a : !felt.type
  }

  verif.contract @CheckSame for @same (%a: !felt.type, %ret_value: !felt.type) {
    %ok = arith.constant true
    verif.ensure_compute %ok
  }
}


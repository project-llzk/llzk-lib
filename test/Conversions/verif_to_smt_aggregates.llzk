// RUN: llzk-opt --llzk-verif-to-smt %s -split-input-file | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
  function.def @id_array(%arg: !array.type<2 x !felt.type>) -> !array.type<2 x !felt.type> {
    function.return %arg : !array.type<2 x !felt.type>
  }

  verif.contract @CheckArray for @id_array (
      %arg: !array.type<2 x !felt.type>,
      %ret: !array.type<2 x !felt.type>
  ) {
    %ok = arith.constant true
    verif.ensure_compute %ok
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_id_array(%[[ARG0:[0-9a-zA-Z_\.]+]]: !smt.int, %[[ARG1:[0-9a-zA-Z_\.]+]]: !smt.int) -> (!smt.int, !smt.int) {
// CHECK:   return %[[ARG0]], %[[ARG1]] : !smt.int, !smt.int
// CHECK: }
// CHECK: func.func @smt_verif_CheckArray_target(%[[IN0:[0-9a-zA-Z_\.]+]]: !smt.int, %[[IN1:[0-9a-zA-Z_\.]+]]: !smt.int, %[[RET0:[0-9a-zA-Z_\.]+]]: !smt.int, %[[RET1:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[CALL:[0-9a-zA-Z_\.]+]]:2 = call @smt_id_array(%[[IN0]], %[[IN1]]) : (!smt.int, !smt.int) -> (!smt.int, !smt.int)
// CHECK:   %[[EQ0:[0-9a-zA-Z_\.]+]] = smt.eq %[[CALL]]#0, %[[RET0]] : !smt.int
// CHECK:   %[[EQ1:[0-9a-zA-Z_\.]+]] = smt.eq %[[CALL]]#1, %[[RET1]] : !smt.int
// CHECK:   %[[AND:[0-9a-zA-Z_\.]+]] = smt.and %[[EQ0]], %[[EQ1]]
// CHECK:   return %[[AND]] : !smt.bool
// CHECK: }

// -----

module attributes {llzk.lang} {
  struct.def @ArrayBox {
    struct.member @left : !array.type<2 x !felt.type>
    struct.member @right : !array.type<2 x !felt.type>

    function.def @compute(
        %left: !array.type<2 x !felt.type>, %right: !array.type<2 x !felt.type>
    ) -> !struct.type<@ArrayBox> {
      %self = struct.new : !struct.type<@ArrayBox>
      struct.writem %self[@left] = %left : !struct.type<@ArrayBox>, !array.type<2 x !felt.type>
      struct.writem %self[@right] = %right : !struct.type<@ArrayBox>, !array.type<2 x !felt.type>
      function.return %self : !struct.type<@ArrayBox>
    }

    function.def @constrain(
        %self: !struct.type<@ArrayBox>,
        %left: !array.type<2 x !felt.type>,
        %right: !array.type<2 x !felt.type>
    ) {
      function.return
    }
  }

  verif.contract @CheckArrayBox for @ArrayBox (
      %self: !struct.type<@ArrayBox>,
      %left: !array.type<2 x !felt.type>,
      %right: !array.type<2 x !felt.type>
  ) {
    %ok = arith.constant true
    verif.require_compute %ok
    verif.ensure_constrain %ok
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_ArrayBox_compute(%[[L0:[0-9a-zA-Z_\.]+]]: !smt.int, %[[L1:[0-9a-zA-Z_\.]+]]: !smt.int, %[[R0:[0-9a-zA-Z_\.]+]]: !smt.int, %[[R1:[0-9a-zA-Z_\.]+]]: !smt.int) -> (!smt.int, !smt.int, !smt.int, !smt.int) {
// CHECK:   return %[[L0]], %[[L1]], %[[R0]], %[[R1]] : !smt.int, !smt.int, !smt.int, !smt.int
// CHECK: }
// CHECK: func.func @smt_verif_CheckArrayBox_target(%[[SELF0:[0-9a-zA-Z_\.]+]]: !smt.int, %[[SELF1:[0-9a-zA-Z_\.]+]]: !smt.int, %[[SELF2:[0-9a-zA-Z_\.]+]]: !smt.int, %[[SELF3:[0-9a-zA-Z_\.]+]]: !smt.int, %[[ARG0:[0-9a-zA-Z_\.]+]]: !smt.int, %[[ARG1:[0-9a-zA-Z_\.]+]]: !smt.int, %[[ARG2:[0-9a-zA-Z_\.]+]]: !smt.int, %[[ARG3:[0-9a-zA-Z_\.]+]]: !smt.int) -> !smt.bool {
// CHECK:   %[[COMP:[0-9a-zA-Z_\.]+]]:4 = call @smt_ArrayBox_compute(%[[ARG0]], %[[ARG1]], %[[ARG2]], %[[ARG3]]) : (!smt.int, !smt.int, !smt.int, !smt.int) -> (!smt.int, !smt.int, !smt.int, !smt.int)
// CHECK:   %[[EQ0:[0-9a-zA-Z_\.]+]] = smt.eq %[[COMP]]#0, %[[SELF0]] : !smt.int
// CHECK:   %[[CONSTR:[0-9a-zA-Z_\.]+]]:4 = call @smt_ArrayBox_constrain(%[[SELF0]], %[[SELF1]], %[[SELF2]], %[[SELF3]], %[[ARG0]], %[[ARG1]], %[[ARG2]], %[[ARG3]]) : (!smt.int, !smt.int, !smt.int, !smt.int, !smt.int, !smt.int, !smt.int, !smt.int) -> (!smt.int, !smt.int, !smt.int, !smt.int)
// CHECK:   %[[EQ7:[0-9a-zA-Z_\.]+]] = smt.eq %[[CONSTR]]#3, %[[SELF3]] : !smt.int
// CHECK:   return %{{[0-9a-zA-Z_\.]+}} : !smt.bool
// CHECK: }


// CHECK-NEXT:     call @smt_check_guard(%[[ARG0_49]]) : (!smt.bool) -> ()
// CHECK-NEXT:     %[[TRUE_16:[0-9A-Za-z_\.]+]] = smt.constant true
// CHECK-NEXT:     return %[[TRUE_16]] : !smt.bool
// CHECK-NEXT:   }
// CHECK-NEXT:   func.func @smt_verif_GuardedPrePipeline_entry(%[[ARG0_50:[0-9A-Za-z_\.]+]]: !smt.bool) {
// CHECK:        %[[PRE_0:[0-9A-Za-z_\.]+]] = call @smt_verif_GuardedPrePipeline_pre(%[[ARG0_50]]) : (!smt.bool) -> !smt.bool

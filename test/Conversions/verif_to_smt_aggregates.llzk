module attributes {llzk.lang = "circom"} {
  poly.template @LessThanPower {
    poly.param @base

    struct.def @LessThanPower {
      struct.member @out : !felt.type<"bn128"> {llzk.pub}

      function.def @compute(%in: !felt.type<"bn128">) -> !struct.type<@LessThanPower::@LessThanPower<[@base]>> attributes {function.allow_non_native_field_ops} {
        %self = struct.new : !struct.type<@LessThanPower::@LessThanPower<[@base]>>
        %base = poly.read_const @base : !felt.type<"bn128">
        %shifted = felt.shr %in, %base : !felt.type<"bn128">, !felt.type<"bn128">
        %zero = felt.const 0 : <"bn128">
        %gt = bool.cmp gt(%shifted, %zero) : !felt.type<"bn128">, !felt.type<"bn128">
        %out = scf.if %gt -> (!felt.type<"bn128">) {
          %false = felt.const 0 : <"bn128">
          scf.yield %false : !felt.type<"bn128">
        } else {
          %true = felt.const 1 : <"bn128">
          scf.yield %true : !felt.type<"bn128">
        }
        struct.writem %self[@out] = %out : !struct.type<@LessThanPower::@LessThanPower<[@base]>>, !felt.type<"bn128">
        function.return %self : !struct.type<@LessThanPower::@LessThanPower<[@base]>>
      }

      function.def @constrain(%self: !struct.type<@LessThanPower::@LessThanPower<[@base]>>, %in: !felt.type<"bn128">) {
        function.return
      }
    }

    verif.contract @LessThanPowerContract for @LessThanPower::@LessThanPower (
        %self: !struct.type<@LessThanPower::@LessThanPower<[@base]>>, %in: !felt.type<"bn128">
    ) {
      %base = poly.read_const @base : !felt.type<"bn128">
      %out = struct.readm %self[@out] : !struct.type<@LessThanPower::@LessThanPower<[@base]>>, !felt.type<"bn128">
      %two = felt.const 2 : <"bn128">
      %limit = felt.pow %two, %base : !felt.type<"bn128">, !felt.type<"bn128">
      %lt = bool.cmp lt(%in, %limit) : !felt.type<"bn128">, !felt.type<"bn128">
      %expected = scf.if %lt -> (!felt.type<"bn128">) {
        %one = felt.const 1 : <"bn128">
        scf.yield %one : !felt.type<"bn128">
      } else {
        %zero = felt.const 0 : <"bn128">
        scf.yield %zero : !felt.type<"bn128">
      }
      %ok = bool.cmp eq(%out, %expected) : !felt.type<"bn128">, !felt.type<"bn128">
      verif.ensure_compute %ok
    }
  }
}


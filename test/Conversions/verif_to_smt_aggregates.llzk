// -----

!Pair = !pod.type<[@lhs: !felt.type, @rhs: !felt.type]>
module attributes {llzk.lang} {
  function.def @id_pair(%pair: !Pair) -> !Pair {
    function.return %pair : !Pair
  }

  verif.contract @CheckPairPod for @id_pair (%pair: !Pair, %ret: !Pair) {
    %ok = arith.constant true
    verif.ensure_compute %ok
  }

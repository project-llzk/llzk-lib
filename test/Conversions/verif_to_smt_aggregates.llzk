module attributes {llzk.lang} {
  struct.def @ArrayBox {
    struct.member @left : !array.type<2 x !felt.type>
    struct.member @right : !array.type<2 x !felt.type>

    function.def @compute(
        %left: !array.type<2 x !felt.type>, %right: !array.type<2 x !felt.type>
    ) -> !struct.type<@ArrayBox> {
      %self = struct.new : !struct.type<@ArrayBox>
      struct.writem %self[@left] = %left : !struct.type<@ArrayBox>, !array.type<2 x !felt.type>
      struct.writem %self[@right] = %right : !struct.type<@ArrayBox>, !array.type<2 x !felt.type>
      function.return %self : !struct.type<@ArrayBox>
    }

    function.def @constrain(
        %self: !struct.type<@ArrayBox>,
        %left: !array.type<2 x !felt.type>,
        %right: !array.type<2 x !felt.type>
    ) {
      function.return
    }
  }

  verif.contract @CheckArrayBox for @ArrayBox (
      %self: !struct.type<@ArrayBox>,
      %left: !array.type<2 x !felt.type>,
      %right: !array.type<2 x !felt.type>
  ) {
    %ok = arith.constant true
    verif.require_compute %ok
    verif.ensure_constrain %ok
  }
}


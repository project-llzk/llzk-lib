module attributes {llzk.lang} {
  function.def @check_guard(%gate: i1) {
    function.return
  }

  verif.contract @GuardedPrePipeline for @check_guard (%gate: i1) {
    %true = arith.constant true
    scf.if %gate {
      verif.require_compute %true
    }
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK-NEXT:   function.def @check_guard(%[[ARG0_45:[0-9A-Za-z_\.]+]]: i1) {
// CHECK-NEXT:     function.return
// CHECK-NEXT:   }

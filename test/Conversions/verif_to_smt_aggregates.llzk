// CHECK-EMPTY:
// CHECK-NEXT: // -----
module attributes {llzk.lang} {
  function.def @id_array(%arg: !array.type<2 x !felt.type>) -> !array.type<2 x !felt.type> {
    function.return %arg : !array.type<2 x !felt.type>
  }

  verif.contract @CheckArray for @id_array (
      %arg: !array.type<2 x !felt.type>,
      %ret: !array.type<2 x !felt.type>
  ) {
    %ok = arith.constant true
    verif.ensure_compute %ok
    verif.ensure_constrain %ok
  }
}



module attributes {llzk.lang} {
  function.def @leaf_array(%arg: !array.type<2 x !felt.type>) -> !array.type<2 x !felt.type> {
    function.return %arg : !array.type<2 x !felt.type>
  }

  function.def @wrap_array(%arg: !array.type<2 x !felt.type>) -> !array.type<2 x !felt.type> {
    function.return %arg : !array.type<2 x !felt.type>
  }

  verif.contract @LeafArray for @leaf_array (
      %arg: !array.type<2 x !felt.type>,
      %ret: !array.type<2 x !felt.type>
  ) {
    %ok = arith.constant true
    verif.ensure_compute %ok
  }

  verif.contract @WrapArray for @wrap_array (
      %arg: !array.type<2 x !felt.type>,
      %ret: !array.type<2 x !felt.type>
  ) {
    verif.include @LeafArray(%arg, %ret) : (!array.type<2 x !felt.type>, !array.type<2 x !felt.type>) -> ()
  }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_verif_WrapArray_includes(%[[WRAP0:[0-9a-zA-Z_\.]+]]: !smt.int, %[[WRAP1:[0-9a-zA-Z_\.]+]]: !smt.int, %[[WRAP_RET0:[0-9a-zA-Z_\.]+]]: !smt.int, %[[WRAP_RET1:[0-9a-zA-Z_\.]+]]: !smt.int) {
// CHECK:   %[[PRE:[0-9a-zA-Z_\.]+]] = call @smt_verif_LeafArray_pre(%[[WRAP0]], %[[WRAP1]], %[[WRAP_RET0]], %[[WRAP_RET1]]) : (!smt.int, !smt.int, !smt.int, !smt.int) -> !smt.bool
// CHECK:   %[[TARGET:[0-9a-zA-Z_\.]+]] = call @smt_verif_LeafArray_target(%[[WRAP0]], %[[WRAP1]], %[[WRAP_RET0]], %[[WRAP_RET1]]) : (!smt.int, !smt.int, !smt.int, !smt.int) -> !smt.bool
// CHECK:   %[[POST:[0-9a-zA-Z_\.]+]] = call @smt_verif_LeafArray_post(%[[WRAP0]], %[[WRAP1]], %[[WRAP_RET0]], %[[WRAP_RET1]]) : (!smt.int, !smt.int, !smt.int, !smt.int) -> !smt.bool
// CHECK:   %[[ANT:[0-9a-zA-Z_\.]+]] = smt.and %[[PRE]], %[[TARGET]]
// CHECK:   %[[IMPL:[0-9a-zA-Z_\.]+]] = smt.implies %[[ANT]], %[[POST]]
// CHECK:   smt.assert %[[IMPL]]
// CHECK:   return
// CHECK: }

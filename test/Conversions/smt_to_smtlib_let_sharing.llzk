// RUN: llzk-opt --smt-to-smtlib='entry=main' -o /dev/null %s | FileCheck %s

module {
  func.func @square_chain(%x: !smt.int) -> !smt.int {
    %sq0 = smt.int.mul %x, %x
    %sq1 = smt.int.mul %sq0, %sq0
    %sq2 = smt.int.mul %sq1, %sq1
    return %sq2 : !smt.int
  }

  func.func @main(%x: !smt.int) {
    %value = call @square_chain(%x) : (!smt.int) -> !smt.int
    %symbol = smt.declare_fun "result" : !smt.int
    %ok = smt.eq %symbol, %value : !smt.int
    smt.assert %ok
    return
  }
}

// CHECK:      (set-logic ALL)
// CHECK-NEXT: (set-info :llzk-root "main")
// CHECK-NEXT: (declare-const main__arg0 Int)
// CHECK-NEXT: (define-fun square_chain ((square_chain__arg0 Int)) Int (let ((__let0 (* square_chain__arg0 square_chain__arg0))) (let ((__let1 (* __let0 __let0))) (let ((__let2 (* __let1 __let1))) __let2))))
// CHECK-NEXT: (declare-fun result () Int)
// CHECK-NEXT: (assert (= result (square_chain main__arg0)))

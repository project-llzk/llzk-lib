// RUN: llzk-translate --smt-to-smtlib  %s | FileCheck %s
// Purpose: self-recursive pure helper emission with SMT-LIB define-fun-rec.

module {
  func.func @helper(%x: !smt.int) -> !smt.int {
    %zero = smt.int.constant 0
    %is_zero = smt.eq %x, %zero : !smt.int
    %one = smt.int.constant 1
    %dec = smt.int.sub %x, %one
    %next = func.call @helper(%dec) : (!smt.int) -> !smt.int
    %result = smt.ite %is_zero, %zero, %next : !smt.int
    return %result : !smt.int
  }

  smt.solver () : () -> () {
    %x = smt.declare_fun "x" : !smt.int
    %value = func.call @helper(%x) : (!smt.int) -> !smt.int
    %symbol = smt.declare_fun "result" : !smt.int
    %ok = smt.eq %symbol, %value : !smt.int
    smt.assert %ok
    smt.yield
  }
}

// CHECK:      (set-logic ALL)
// CHECK-NEXT: (declare-fun x () Int)
// CHECK-NEXT: (define-fun-rec helper ((helper__arg0 Int)) Int
// CHECK-SAME:   (let ((__let0 (= helper__arg0 0)))
// CHECK-SAME:   (let ((__let1 (- helper__arg0 1)))
// CHECK-SAME:   (let ((__let2 (ite __let0 0 (helper __let1)))) __let2)))
// CHECK-NEXT: (declare-fun result () Int)
// CHECK-NEXT: (assert (= result (helper x)))

// RUN: llzk-opt --smt-to-smtlib='entry=main' -o /dev/null %s | FileCheck %s

module {
  func.func @main(%x: !smt.int, %y: !smt.int, %z: !smt.int) {
    %abs = smt.int.abs %x
    %distinct = smt.distinct %x, %y, %z : !smt.int
    %abs_symbol = smt.declare_fun "abs_result" : !smt.int
    %distinct_symbol = smt.declare_fun "all_distinct" : !smt.bool
    %abs_ok = smt.eq %abs_symbol, %abs : !smt.int
    %distinct_ok = smt.eq %distinct_symbol, %distinct : !smt.bool
    smt.assert %abs_ok
    smt.assert %distinct_ok
    return
  }
}

// CHECK:      (set-logic ALL)
// CHECK-NEXT: (set-info :llzk-root "main")
// CHECK-NEXT: (declare-const main__arg0 Int)
// CHECK-NEXT: (declare-const main__arg1 Int)
// CHECK-NEXT: (declare-const main__arg2 Int)
// CHECK-NEXT: (declare-fun abs_result () Int)
// CHECK-NEXT: (declare-fun all_distinct () Bool)
// CHECK-NEXT: (assert (= abs_result (abs main__arg0)))
// CHECK-NEXT: (assert (= all_distinct (distinct main__arg0 main__arg1 main__arg2)))

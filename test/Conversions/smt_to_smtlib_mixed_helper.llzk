// RUN: llzk-opt --smt-to-smtlib='entry=main' -o /dev/null %s | FileCheck %s

module {
  func.func @pure_add(%x: !smt.int) -> !smt.int {
    %one = smt.int.constant 1
    %sum = smt.int.add %x, %one
    return %sum : !smt.int
  }

  func.func @script_check(%x: !smt.int) {
    smt.push 1
    %value = call @pure_add(%x) : (!smt.int) -> !smt.int
    %zero = smt.int.constant 0
    %ok = smt.eq %value, %zero : !smt.int
    smt.assert %ok
    smt.check sat {
      smt.yield
    } unknown {
      %false = arith.constant false
      bool.assert %false
      smt.yield
    } unsat {
      %false = arith.constant false
      bool.assert %false
      smt.yield
    }
    smt.pop 1
    return
  }

  func.func @main(%x: !smt.int) {
    call @script_check(%x) : (!smt.int) -> ()
    return
  }
}

// CHECK:      (set-logic ALL)
// CHECK-NEXT: (set-info :llzk-root "main")
// CHECK-NEXT: (declare-const main__arg0 Int)
// CHECK-NEXT: (push 1)
// CHECK-NEXT: (define-fun pure_add ((pure_add__arg0 Int)) Int (let ((__let0 (+ pure_add__arg0 1))) __let0))
// CHECK-NEXT: (assert (= (pure_add main__arg0) 0))
// CHECK-NEXT: (set-info :status sat)
// CHECK-NEXT: (check-sat)
// CHECK-NEXT: (pop 1)

// RUN: llzk-opt --llzk-to-smt-no-cf='field=babybear' %s | FileCheck --enable-var-scope %s

module attributes {llzk.lang} {
    struct.def @A {
        struct.member @foo : !felt.type
        function.def @product(%a: !felt.type, %b: !felt.type) -> !struct.type<@A> {
            %self = struct.new : <@A>

            %0 = felt.const 0
            %lt = bool.cmp lt (%a, %0)
            scf.if %lt {
                struct.writem %self[@foo] = %a : <@A>, !felt.type
            } else {
                struct.writem %self[@foo] = %b : <@A>, !felt.type
            }

            function.return %self : !struct.type<@A>
        }
    }
}

// CHECK-LABEL: module attributes {llzk.lang} {
// CHECK: func.func @smt_A(%[[A:[0-9a-zA-Z_\.]+]]: !smt.int, %[[B:[0-9a-zA-Z_\.]+]]: !smt.int) {
// CHECK: %[[A_LO:[0-9a-zA-Z_\.]+]] = smt.int.constant 0
// CHECK: %[[A_HI:[0-9a-zA-Z_\.]+]] = smt.int.constant 2013265920
// CHECK: %[[A_GE:[0-9a-zA-Z_\.]+]] = smt.int.cmp ge %[[A]], %[[A_LO]]
// CHECK: %[[A_LE:[0-9a-zA-Z_\.]+]] = smt.int.cmp le %[[A]], %[[A_HI]]
// CHECK: smt.assert %[[A_GE]]
// CHECK: smt.assert %[[A_LE]]
// CHECK-DAG: %[[FOOC:[0-9a-zA-Z_\.]+]] = smt.declare_fun "foo_c" : !smt.int
// CHECK-DAG: %[[FOOW:[0-9a-zA-Z_\.]+]] = smt.declare_fun "foo_w" : !smt.int
// CHECK: %[[CMP:[0-9a-zA-Z_\.]+]] = smt.int.cmp lt %[[A]], %{{[0-9a-zA-Z_\.]+}}
// CHECK: %[[COND:[0-9a-zA-Z_\.]+]] = builtin.unrealized_conversion_cast %[[CMP]] : !smt.bool to i1
// CHECK: scf.if %[[COND]] {
// CHECK:   %[[EQ0:[0-9a-zA-Z_\.]+]] = smt.eq %[[FOOW]], %[[A]] : !smt.int
// CHECK:   smt.assert %[[EQ0]]
// CHECK: } else {
// CHECK:   %[[EQ1:[0-9a-zA-Z_\.]+]] = smt.eq %[[FOOW]], %[[B]] : !smt.int
// CHECK:   smt.assert %[[EQ1]]
// CHECK: }
// CHECK-NOT: smt.int.mod
// CHECK: return

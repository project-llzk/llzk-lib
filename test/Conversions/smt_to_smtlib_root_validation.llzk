// RUN: split-file %s %t
// RUN: not llzk-opt --smt-to-smtlib -o /dev/null %t/no-solver.mlir 2>&1 | FileCheck %s --check-prefix=NO-SOLVER
// RUN: not llzk-opt --smt-to-smtlib -o /dev/null %t/multiple-solvers.mlir 2>&1 | FileCheck %s --check-prefix=MULTI-SOLVER
// RUN: not llzk-opt --smt-to-smtlib -o /dev/null %t/nested-only.mlir 2>&1 | FileCheck %s --check-prefix=NESTED-ONLY
// RUN: not llzk-opt --smt-to-smtlib -o /dev/null %t/solver-inputs.mlir 2>&1 | FileCheck %s --check-prefix=SOLVER-INPUTS
// RUN: not llzk-opt --smt-to-smtlib -o /dev/null %t/solver-results.mlir 2>&1 | FileCheck %s --check-prefix=SOLVER-RESULTS
// RUN: not llzk-opt --smt-to-smtlib -o /dev/null %t/direct-nested.mlir 2>&1 | grep -F "use push/pop if same-solver nesting was intended"
// RUN: not llzk-opt --smt-to-smtlib -o /dev/null %t/helper-nested.mlir 2>&1 | grep -F "use push/pop if same-solver nesting was intended"

//--- no-solver.mlir
module {
  func.func @helper_only(%x: !smt.int) -> !smt.int {
    return %x : !smt.int
  }
}

// NO-SOLVER: error: smt-to-smtlib could not find a top-level smt.solver in the root module

//--- multiple-solvers.mlir
module {
  smt.solver () : () -> () {
    smt.yield
  }

  smt.solver () : () -> () {
    smt.yield
  }
}

// MULTI-SOLVER: error: smt-to-smtlib requires exactly one top-level smt.solver in the root module

//--- nested-only.mlir
module {
  func.func @nested_only() {
    smt.solver () : () -> () {
      smt.yield
    }
    return
  }
}

// NESTED-ONLY: error: smt-to-smtlib could not find a top-level smt.solver in the root module

//--- solver-inputs.mlir
module {
  %zero = arith.constant 0 : i32
  smt.solver (%zero) : (i32) -> () {
  ^bb0(%arg0: i32):
    smt.yield
  }
}

// SOLVER-INPUTS: error: SMT-LIB scripts have no standard parameter channel; the selected top-level smt.solver must be a closed script

//--- solver-results.mlir
module {
  %value = smt.solver () : () -> (i32) {
    %zero = arith.constant 0 : i32
    smt.yield %zero : i32
  }
}

// SOLVER-RESULTS: error: SMT-LIB scripts have no standard return channel; the selected top-level smt.solver must not return results

//--- direct-nested.mlir
module {
  smt.solver () : () -> () {
    smt.solver () : () -> () {
      smt.yield
    }
    smt.yield
  }
}

//--- helper-nested.mlir
module {
  func.func @nested_helper() {
    smt.solver () : () -> () {
      smt.yield
    }
    return
  }

  smt.solver () : () -> () {
    func.call @nested_helper() : () -> ()
    smt.yield
  }
}

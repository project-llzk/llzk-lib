// RUN: llzk-opt --smt-to-smtlib -o /dev/null %s | FileCheck %s

module {
  smt.solver () : () -> () {
    %x = smt.declare_fun "x" : !smt.int
    %f = smt.declare_fun "f" : !smt.func<(!smt.int) !smt.int>
    %value = smt.apply_func %f(%x) : !smt.func<(!smt.int) !smt.int>
    %symbol = smt.declare_fun "result" : !smt.int
    %ok = smt.eq %symbol, %value : !smt.int
    smt.assert %ok
    smt.yield
  }
}

// CHECK:      (set-logic ALL)
// CHECK-NEXT: (set-info :llzk-root "module")
// CHECK-NEXT: (declare-fun x () Int)
// CHECK-NEXT: (declare-fun f (Int) Int)
// CHECK-NEXT: (declare-fun result () Int)
// CHECK-NEXT: (assert (= result (f x)))

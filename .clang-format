---
# Formatter for .td files
Language: TableGen
BasedOnStyle: LLVM
IndentWidth: 2
---
# Formatter for .h, .cpp, etc.
Language: Cpp
BasedOnStyle: LLVM
IndentWidth: 2
ColumnLimit: 100
LambdaBodyIndentation: OuterScope
AlignAfterOpenBracket: BlockIndent
SpaceBeforeCpp11BracedList: true
InsertBraces: true
SortIncludes: true
IncludeBlocks: Regroup
IncludeCategories:
  # The "main" header for a file has implicit priority 0.
  # see https://clang.llvm.org/docs/ClangFormatStyleOptions.html#includecategories
  # After that, includes are generally listed from specific/local to general.
  # The regex patterns are matched in order with first match winning, hence the
  # "Everything else" pattern is last even though they are sorted earlier.
  - Regex: '^("|<)llzk-c/.*("|>)$' # LLZK C API headers
    Priority: 2
  - Regex: '^("|<)llzk/.*("|>)$'   # LLZK headers
    Priority: 3
  - Regex: '^<pcl/.*>$'            # PCL headers
    Priority: 4
  - Regex: '^<mlir-c/.*>$'         # MLIR C API headers
    Priority: 5
  - Regex: '^<mlir/.*>$'           # MLIR headers
    Priority: 6
  - Regex: '^<llvm/.*>$'           # LLVM headers
    Priority: 7
  - Regex: '^".*(\.inc)"$'         # Generated by tablegen
    Priority: 9
  - Regex: '^<.*(\.h)?>$'          # Standard library headers
    Priority: 8
  - Regex: '^.*$'                  # Everything else (ex: the backends `pcl`, `r1cs`, `zklean`, etc.)
    Priority: 1
InsertNewlineAtEOF: true
---
Language: Json
DisableFormat: true
---
Language: JavaScript
DisableFormat: true
